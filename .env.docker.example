# Docker Environment Variables
# Copy this file to .env.docker and fill in secure values
# NEVER commit .env.docker to version control

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
POSTGRES_USER=synthex_user
POSTGRES_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD
POSTGRES_DB=synthex_dev

# =============================================================================
# Cache (Redis)
# =============================================================================
REDIS_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD

# =============================================================================
# Monitoring (Grafana)
# =============================================================================
GRAFANA_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD

# =============================================================================
# Application Secrets (copy from your .env.local)
# =============================================================================
# JWT_SECRET=your_jwt_secret
# OPENAI_API_KEY=your_openai_key
# OPENROUTER_API_KEY=your_openrouter_key

# =============================================================================
# IMPORTANT SECURITY NOTES
# =============================================================================
# 1. Generate strong passwords using: openssl rand -base64 32
# 2. Never use default passwords in any environment
# 3. Use different passwords for dev, staging, and production
# 4. Rotate passwords regularly
# 5. Never commit this file with real credentials
