EMAIL_RETRY_ATTEMPTS=3
EMAIL_RETRY_DELAY_MS=5000
EMAIL_RATE_LIMIT_MAX=100
EMAIL_RATE_LIMIT_WINDOW_MS=3600000
EMAIL_TEST_MODE=false
EMAIL_TRACK_OPENS=false
EMAIL_TRACK_CLICKS=false
EMAIL_TRACK_BOUNCES=false
EMAIL_WEBHOOK_URL=
EMAIL_WEBHOOK_SECRET=

# ========== AUTH AUDIT (OPTIONAL) ==========
# Enable detailed auth event audit logging
# Security: INTERNAL [OPTIONAL]
ENABLE_AUTH_AUDIT=true

# ========== FACEBOOK (PLATFORM API) ==========
# Facebook App credentials for direct Graph API access
# Note: FACEBOOK_CLIENT_ID / FACEBOOK_CLIENT_SECRET above are for OAuth
# These are the same app — some APIs use APP_ID/APP_SECRET naming
FACEBOOK_APP_ID=1234567890123456
FACEBOOK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FACEBOOK_WEBHOOK_SECRET=your-facebook-webhook-secret
FACEBOOK_WEBHOOK_VERIFY_TOKEN=your-verify-token

# ========== GEMINI (GOOGLE AI) ==========
# Google Gemini API key (alternative to GOOGLE_AI_API_KEY)
# Security: SECRET [OPTIONAL]
GEMINI_API_KEY=

# ========== GITHUB WEBHOOK ==========
# Secret for verifying GitHub webhook payloads
# Security: SECRET [OPTIONAL]
GITHUB_WEBHOOK_SECRET=

# ========== GOOGLE WEBHOOK ==========
# Secret for verifying Google webhook payloads
# Security: SECRET [OPTIONAL]
GOOGLE_WEBHOOK_SECRET=

# ========== INSTAGRAM WEBHOOK ==========
# Secret for verifying Instagram webhook payloads
# Security: SECRET [OPTIONAL]
INSTAGRAM_WEBHOOK_SECRET=

# ========== INTERNAL API KEY ==========
# Key for internal service-to-service communication
# Security: CRITICAL [OPTIONAL]
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=
INTERNAL_WEBHOOK_SECRET=

# ========== MAILGUN (EMAIL PROVIDER) ==========
# Mailgun credentials (for EMAIL_PROVIDER=mailgun)
# Security: SECRET [OPTIONAL]
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_HOST=api.mailgun.net

# ========== META (UNIFIED) ==========
# Meta (Facebook/Instagram) unified app credentials
# Note: Duplicates of FACEBOOK_* for code paths that use META_* naming
META_CLIENT_ID=1234567890123456
META_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========== APP DOMAIN (PUBLIC) ==========
# Public-facing domain without protocol (used for OG, sitemap, etc.)
# Security: PUBLIC [OPTIONAL]
NEXT_PUBLIC_APP_DOMAIN=synthex.vercel.app

# ========== NEXT PUBLIC CRON SECRET ==========
# Public cron secret for client-triggered cron calls (if applicable)
# Security: INTERNAL [OPTIONAL — prefer server-only CRON_SECRET]
NEXT_PUBLIC_CRON_SECRET=

# ========== PAPER BANANA (VISUALISATIONS) ==========
# Paper Banana service for chart/infographic generation
# Security: SECRET [OPTIONAL]
PAPER_BANANA_API_KEY=
PAPER_BANANA_SERVICE_URL=https://api.paperbanana.com

# ========== PINTEREST (PLATFORM) ==========
# Pinterest App credentials (APP_ID/APP_SECRET naming)
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_WEBHOOK_SECRET=

# ========== POSTMARK (EMAIL PROVIDER) ==========
# Postmark credentials (for EMAIL_PROVIDER=postmark)
# Security: SECRET [OPTIONAL]
POSTMARK_API_KEY=
POSTMARK_SERVER_TOKEN=
POSTMARK_MESSAGE_STREAM=outbound

# ========== PRISMA DEBUG ==========
# Enable Prisma query logging
# Security: INTERNAL [OPTIONAL — dev only]
PRISMA_LOG_QUERIES=false

# ========== REDDIT WEBHOOK ==========
REDDIT_WEBHOOK_SECRET=

# ========== REDIS TOKEN (UPSTASH ALTERNATE) ==========
# Alternative to UPSTASH_REDIS_REST_TOKEN for some Upstash integrations
# Security: SECRET [OPTIONAL]
REDIS_TOKEN=

# ========== RUNWAY ML (VIDEO AI) ==========
# Runway ML API key for AI video generation
# Security: SECRET [OPTIONAL]
# Get from: https://app.runwayml.com/settings
RUNWAY_API_KEY=

# ========== SENDGRID TEMPLATES ==========
# Transactional email template IDs in SendGrid
# Security: INTERNAL [OPTIONAL — required if using SendGrid]
SENDGRID_WELCOME_TEMPLATE_ID=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_VERIFICATION_TEMPLATE_ID=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_RESET_PASSWORD_TEMPLATE_ID=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_WEBHOOK_VERIFICATION_KEY=

# ========== SLACK SIGNING SECRET ==========
# Used to verify inbound Slack webhook signatures
# Security: SECRET [OPTIONAL]
SLACK_SIGNING_SECRET=

# ========== SMTP ADDITIONAL SETTINGS ==========
# Additional SMTP settings not covered by existing entries
SMTP_PASSWORD=your-smtp-password
SMTP_SECURE=true

# ========== STABILITY AI (IMAGE AI) ==========
# Stability AI API key for AI image generation
# Security: SECRET [OPTIONAL]
# Get from: https://platform.stability.ai/account/keys
STABILITY_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========== STRIPE ADDITIONAL PRICE IDs ==========
# Growth, Pro, and Scale plan Stripe price IDs
# Security: INTERNAL [OPTIONAL — required if these plans are offered]
STRIPE_GROWTH_PRICE_ID=price_1xxxxxxxxxxxxxxxxx
STRIPE_PRO_PRICE_ID=price_1xxxxxxxxxxxxxxxxx
STRIPE_SCALE_PRICE_ID=price_1xxxxxxxxxxxxxxxxx

# Stripe price ID for the Authority Ranking add-on (Phase 86)
# Security: INTERNAL [OPTIONAL — required for deep authority validation]
# Get from: Stripe Dashboard > Products > Authority Ranking Add-on > Price ID
STRIPE_AUTHORITY_ADDON_PRICE_ID=

# ========== SEMANTIC SCHOLAR (AUTHORITY ENGINE) ==========
# API key for Semantic Scholar academic paper search (authority source connector)
# Security: SECRET [OPTIONAL — connector falls back to anonymous access at lower rate limits]
# Get from: https://api.semanticscholar.org/
SEMANTIC_SCHOLAR_API_KEY=

# ========== SYNTHESIA (VIDEO AI) ==========
# Synthesia API key for AI presenter video generation
# Security: SECRET [OPTIONAL]
# Get from: https://app.synthesia.io/#/account/api
SYNTHESIA_API_KEY=

# ========== THREADS (META) ==========
# Threads APP credentials (some code uses APP_ID/APP_SECRET)
THREADS_APP_ID=
THREADS_APP_SECRET=

# ========== TIKTOK WEBHOOK ==========
TIKTOK_WEBHOOK_SECRET=

# ========== UPSTASH REDIS (ALTERNATIVE URL) ==========
# UPSTASH_REDIS_URL is an alternative format to UPSTASH_REDIS_REST_URL
# Security: SECRET [OPTIONAL]
UPSTASH_REDIS_URL=

# ========== VERCEL RUNTIME VARS (AUTO-SET) ==========
# These are injected automatically by Vercel at build/runtime — do not set manually
# VERCEL_URL — deployment URL set by Vercel
# VERCEL_REGION — region (e.g., iad1)
# VERCEL_GIT_COMMIT_SHA — current commit SHA
VERCEL_URL=
VERCEL_REGION=
VERCEL_GIT_COMMIT_SHA=

# ========== WEBHOOK SIGNING (OUTBOUND) ==========
# Secret for signing outbound webhooks sent to third parties
# Security: SECRET [OPTIONAL]
WEBHOOK_SIGNING_SECRET=

# ========== WORKFLOW ENGINE ==========
# Maximum concurrent workflow executions
# Security: INTERNAL [OPTIONAL — defaults to 5]
WORKFLOW_CONCURRENCY=5

# ========== ZAPIER INTEGRATION ==========
# Secret for verifying Zapier webhook payloads
# Security: SECRET [OPTIONAL]
ZAPIER_WEBHOOK_SECRET=

# ===========================================
# DEPLOYMENT CHECKLIST
# ===========================================
#
# REQUIRED for all environments:
#   [x] DATABASE_URL
#   [x] JWT_SECRET
#   [x] FIELD_ENCRYPTION_KEY (for OAuth token encryption)
#   [x] OAUTH_STATE_SECRET (for OAuth CSRF protection)
#   [x] NEXT_PUBLIC_SUPABASE_URL
#   [x] NEXT_PUBLIC_SUPABASE_ANON_KEY
#   [x] OPENROUTER_API_KEY
#
# REQUIRED for billing:
#   [x] STRIPE_SECRET_KEY (server-side API calls)
#   [x] NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY (client-side Checkout)
#   [x] STRIPE_WEBHOOK_SECRET (webhook signature verification)
#   [x] STRIPE_PROFESSIONAL_PRICE_ID (real Stripe price ID)
#   [x] STRIPE_BUSINESS_PRICE_ID (real Stripe price ID)
#
# REQUIRED for production:
#   [x] All above
#   [x] SENTRY_DSN (for error tracking)
#   [x] OAuth credentials (for social login)
#
# Development (.env.local):
#   - Copy this file to .env.local
#   - Fill in values for local Supabase/Postgres
#   - Use test Stripe keys (sk_test_*, pk_test_*)
#
# Staging:
#   - Use separate Supabase project
#   - Use test Stripe keys
#   - Set NEXT_PUBLIC_APP_URL to staging URL
#
# Production:
#   - Set all CRITICAL vars in Vercel dashboard
#   - Use live Stripe keys (sk_live_*, pk_live_*)
#   - Enable Sentry for error tracking
#   - Configure all OAuth providers
#
# ===========================================

# ========== BRAND BUILDER (Phase 91) ==========
# Brand mention monitoring APIs (all optional — GDELT works without auth)
# Security: SECRET [OPTIONAL]

# NewsData.io — 200 req/day free tier
# Get from: https://newsdata.io/api-key
NEWSDATA_API_KEY=

# GNews.io — 100 req/day free tier
# Get from: https://gnews.io/
GNEWS_API_KEY=

# The Guardian — 500 req/day free tier
# Get from: https://open-platform.theguardian.com/
GUARDIAN_API_KEY=

# Google Knowledge Graph Search API — 100 req/day free
# Get from: Google Cloud Console > APIs & Services > Knowledge Graph Search API
# KG check gracefully skipped if not configured
GOOGLE_KG_API_KEY=

# ========== AI BACKLINK PROSPECTOR (Phase 95) ==========
# Security: SECRET [OPTIONAL — graceful fallback to heuristics if not set]

# OpenPageRank.com API — 100 requests/day free
# Used for domain authority scoring of backlink prospects
# Get from: https://www.openpagerank.com/resources/api-documentation/
OPEN_PAGE_RANK_API_KEY=

# Google Custom Search JSON API — 100 queries/day free, $5 per 1,000 beyond
# Used to find resource pages, guest post opportunities, broken link targets
# Get API key from: https://developers.google.com/custom-search/v1/introduction
GOOGLE_CSE_KEY=

# Google Custom Search Engine ID
# Create at: https://programmablesearchengine.google.com/controlpanel/create
GOOGLE_CSE_ID=
