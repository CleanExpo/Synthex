# ================================
# SYNTHEX PLATFORM CONFIGURATION
# ================================
# These are the platform-level environment variables
# Users will enter their own social media credentials through the UI

# Database Configuration (Required)
# Get these from https://supabase.com
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Authentication (Required)
JWT_SECRET=generate_a_random_32_char_string
NEXTAUTH_URL=https://synthex.social
NEXTAUTH_SECRET=generate_another_random_32_char_string

# AI Services (Required for content generation)
# Get from https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key

# Optional: Alternative AI provider
# OPENAI_API_KEY=your_openai_api_key

# Error Tracking (Optional but recommended)
# Get from https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
SENTRY_DSN=your_sentry_dsn
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=your_sentry_project

# Email Service (For user notifications)
# Choose one provider:
RESEND_API_KEY=your_resend_api_key
# OR
SENDGRID_API_KEY=your_sendgrid_api_key

# Encryption (Required for storing user credentials)
# Generate a 32-character encryption key
ENCRYPTION_KEY=generate_a_32_char_encryption_key

# Environment Settings
NODE_ENV=production
DEMO_MODE=false

# ================================
# DO NOT ADD SOCIAL MEDIA API KEYS HERE
# ================================
# Users will enter their own social media credentials
# through the dashboard at /dashboard/integrations
# 
# Each user's credentials are:
# - Entered through the UI
# - Encrypted with ENCRYPTION_KEY
# - Stored in the database per user
# - Used only for that user's posts