# ============================================
# SYNTHEX Environment Variables Template
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# ============================================

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database Configuration
DATABASE_PROVIDER=postgresql
DATABASE_URL=your-database-url-here
DIRECT_DATABASE_URL=your-direct-database-url-here
POSTGRES_URL_POOLING=your-pooling-url-here

# Authentication
JWT_SECRET=generate-a-secure-64-character-secret

# Google OAuth Configuration (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://your-domain/auth/google/callback

# OpenRouter API Configuration
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://your-domain
OPENROUTER_SITE_NAME=SYNTHEX

# Optional Model API Keys
OPENAI_API_KEY=sk-proj-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
GOOGLE_API_KEY=your-google-api-key

# GitHub OAuth (Optional)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Cost Management
DAILY_BUDGET_LIMIT=50.00
MONTHLY_BUDGET_LIMIT=1000.00

# Email Service Configuration (Optional)
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@synthex.ai
FRONTEND_URL=https://your-domain.com

# SMTP Settings (if using EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# SendGrid Settings (if using EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=your-sendgrid-api-key

# Gmail Settings (if using EMAIL_PROVIDER=gmail)
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# Performance Settings
MAX_CONCURRENT_REQUESTS=5
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600

# Environment
NODE_ENV=development
PORT=3000

# ============================================
# Phase 3 Integration - Security & Middleware
# ============================================

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=synthex
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MAX=20

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Security Settings
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
SESSION_SECRET=generate-a-secure-session-secret
API_KEY_SALT=generate-a-secure-api-key-salt

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Internationalization
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,es,fr,de,zh,ja,ko,pt,ru,ar

# Feature Flags
ENABLE_WHITE_LABEL=false
ENABLE_AI_CONTENT=true
ENABLE_AB_TESTING=true
ENABLE_COMPETITOR_ANALYSIS=true
ENABLE_ADVANCED_ANALYTICS=true

# Platform API Limits
TWITTER_API_LIMIT=300
INSTAGRAM_API_LIMIT=200
LINKEDIN_API_LIMIT=100
TIKTOK_API_LIMIT=60

# User Tier Limits
TIER_FREE_LIMIT=50
TIER_BASIC_LIMIT=200
TIER_PRO_LIMIT=500
TIER_ENTERPRISE_LIMIT=2000

# Security Headers
ENABLE_HELMET=true
ENABLE_CORS=true
ENABLE_RATE_LIMITING=true
ENABLE_REQUEST_SANITIZATION=true

# Monitoring
ENABLE_REQUEST_LOGGING=true
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_ERROR_TRACKING=true

# Application Version
APP_VERSION=2.0.0
