# ============================================
# SYNTHEX Environment Variables Template
# Copy this to .env and fill in your values
# ============================================

# Core Configuration
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://synthex.social

# Supabase (Get these from your Supabase project settings)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (CRITICAL: Use your actual Supabase password!)
# Get from: Supabase Dashboard > Settings > Database > Connection string
DATABASE_URL=postgresql://postgres:YOUR_ACTUAL_PASSWORD@db.your-project.supabase.co:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:YOUR_ACTUAL_PASSWORD@db.your-project.supabase.co:5432/postgres

# Authentication
JWT_SECRET=generate-a-secure-random-string-minimum-32-characters

# ============================================
# AI Services
# ============================================
# OpenRouter API for AI content generation
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key

# ============================================
# Payment Processing (Stripe)
# ============================================
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PROFESSIONAL_PRICE_ID=price_your-professional-plan-id
STRIPE_BUSINESS_PRICE_ID=price_your-business-plan-id
STRIPE_CUSTOM_PRICE_ID=price_your-custom-plan-id

# ============================================
# Email Service (Optional - uses mock if not configured)
# ============================================
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=your-sendgrid-api-key

# ============================================
# Caching (Redis - Optional)
# ============================================
# Uses memory fallback if not configured
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ============================================
# Monitoring & Error Tracking (Optional)
# ============================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================
# Security & Admin
# ============================================
ADMIN_API_KEY=generate-a-secure-admin-api-key
CRON_SECRET=generate-a-secure-cron-secret

# ============================================
# OAuth Platform Credentials (Optional)
# Configure only the platforms you need
# ============================================
# Twitter/X
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret

# LinkedIn
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# Instagram
INSTAGRAM_CLIENT_ID=your-instagram-client-id
INSTAGRAM_CLIENT_SECRET=your-instagram-client-secret

# Facebook
FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret

# TikTok
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret

# ============================================
# Google Cloud / VEO3 Video Generation (Optional)
# ============================================
# For AI-powered video generation with Google VEO3
# Get credentials from: Google Cloud Console > IAM > Service Accounts

# Google Cloud Project Configuration
GOOGLE_CLOUD_PROJECT_ID=your-google-cloud-project-id
GOOGLE_CLOUD_REGION=us-central1

# Path to service account JSON credentials file
# Create a credentials folder and store your JSON key there
# IMPORTANT: Add credentials/ to .gitignore!
GOOGLE_APPLICATION_CREDENTIALS=./credentials/synthex-veo3-credentials.json

# VEO3 Output Path (optional)
VEO3_OUTPUT_PATH=./data/videos
