# ============================================
# SYNTHEX ENVIRONMENT VARIABLES
# ============================================
# Generated: 2025-08-15T04:25:20.796Z
# 
# ⚠️  SECURITY WARNINGS:
# 1. NEVER commit this file with real values
# 2. NEVER expose SECRET/CRITICAL vars to client
# 3. ALWAYS use strong, random values for secrets
# 4. ALWAYS validate env vars at startup
# ============================================


# ========== DATABASE ==========
# PostgreSQL connection string with credentials
# Security Level: CRITICAL [REQUIRED]
DATABASE_URL=postgresql://user:password@host:5432/dbname


# ========== AUTHENTICATION ==========
# Secret key for signing JWT tokens (min 32 chars)
# Security Level: CRITICAL [REQUIRED]
JWT_SECRET=base64EncodedRandomStringAtLeast32CharsLong==

# NextAuth.js secret for session encryption
# Security Level: CRITICAL [OPTIONAL]
# Depends on: NEXTAUTH_URL
NEXTAUTH_SECRET=generated-random-string-for-nextauth

# Canonical URL of the site for NextAuth
# Security Level: INTERNAL [OPTIONAL]
NEXTAUTH_URL=https://synthex.vercel.app


# ========== AI_SERVICES ==========
# OpenRouter API key for AI services
# Security Level: SECRET [REQUIRED]
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxx

# OpenAI API key (alternative to OpenRouter)
# Security Level: SECRET [OPTIONAL]
# Conflicts with: ANTHROPIC_API_KEY
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic Claude API key
# Security Level: SECRET [OPTIONAL]
# Conflicts with: OPENAI_API_KEY
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx


# ========== PAYMENT ==========
# Stripe secret key for payment processing
# Security Level: CRITICAL [OPTIONAL]
# Depends on: STRIPE_PUBLISHABLE_KEY, STRIPE_WEBHOOK_SECRET
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxx

# Stripe publishable key (safe for client)
# Security Level: PUBLIC [OPTIONAL]
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxx

# Stripe webhook endpoint secret
# Security Level: SECRET [OPTIONAL]
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxx


# ========== EMAIL ==========
# Email service provider
# Security Level: INTERNAL [OPTIONAL]
# Depends on: SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS
EMAIL_PROVIDER=smtp

# SMTP server hostname
# Security Level: INTERNAL [OPTIONAL]
SMTP_HOST=smtp.gmail.com

# SMTP server port
# Security Level: INTERNAL [OPTIONAL]
SMTP_PORT=587

# SMTP authentication username
# Security Level: SECRET [OPTIONAL]
SMTP_USER=your-email@gmail.com

# SMTP authentication password
# Security Level: SECRET [OPTIONAL]
SMTP_PASS=your-app-specific-password


# ========== OAUTH ==========
# Google OAuth client ID
# Security Level: INTERNAL [OPTIONAL]
# Depends on: GOOGLE_CLIENT_SECRET
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# Google OAuth client secret
# Security Level: SECRET [OPTIONAL]
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxx


# ========== MONITORING ==========
# Sentry error tracking DSN
# Security Level: INTERNAL [OPTIONAL]
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Sentry DSN for client-side
# Security Level: PUBLIC [OPTIONAL]
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Google Analytics tracking ID
# Security Level: PUBLIC [OPTIONAL]
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX


# ========== APPLICATION ==========
# Public application URL
# Security Level: PUBLIC [OPTIONAL]
NEXT_PUBLIC_APP_URL=https://synthex.vercel.app

# Node environment
# Security Level: INTERNAL [OPTIONAL]
NODE_ENV=production


# ========== OTHER ==========
# Supabase project URL (public)
# Security Level: PUBLIC [REQUIRED]
NEXT_PUBLIC_SUPABASE_URL=https://project.supabase.co

# Supabase anonymous/public key (safe for client)
# Security Level: PUBLIC [REQUIRED]
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key (NEVER expose to client)
# Security Level: CRITICAL [OPTIONAL]
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Redis connection URL for caching
# Security Level: SECRET [OPTIONAL]
REDIS_URL=redis://username:password@host:6379

# Maximum requests per window
# Security Level: INTERNAL [OPTIONAL]
RATE_LIMIT_MAX=100

# Rate limit window in milliseconds
# Security Level: INTERNAL [OPTIONAL]
RATE_LIMIT_WINDOW_MS=900000

