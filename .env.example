# Synthex Configuration
# Official Website: https://synthex.social
# Support Email: support@synthex.social

# Supabase Configuration (Required for production)
# Get these from your Supabase project settings: https://app.supabase.com
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: Leave empty to use demo mode
# Demo credentials: demo@synthex.com / demo123

# OpenRouter API (Required for AI features)
OPENROUTER_API_KEY=your_openrouter_api_key
# Added for explicit configuration
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=gpt-5-thinking

# JWT Secret (Required for production)
JWT_SECRET=your_jwt_secret_key

# Application URL (Required for OAuth redirects)
NEXT_PUBLIC_APP_URL=https://synthex.social

# Contact Information
SUPPORT_EMAIL=support@synthex.social
LEGAL_EMAIL=legal@synthex.social
PRIVACY_EMAIL=privacy@synthex.social

# Required: Database URL for Prisma (Supabase connection)
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
# Get this from: Supabase Dashboard > Settings > Database > Connection string
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
# Direct connection URL (same as DATABASE_URL for Supabase)
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Optional: Sentry DSN for error tracking (client-side)
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
# Server-side Sentry (recommended)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Email Provider Configuration (choose one provider and fill required fields)
EMAIL_PROVIDER=smtp
EMAIL_FROM=support@synthex.social

# SMTP (if EMAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Gmail (if EMAIL_PROVIDER=gmail; enable 2FA and use an App Password)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# SendGrid (if EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=

# OAuth Providers (optional — only if using provider sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# NextAuth (optional — only if adopting NextAuth)
NEXTAUTH_URL=${NEXT_PUBLIC_APP_URL}
NEXTAUTH_SECRET=

# Development Mode Settings
NODE_ENV=development
