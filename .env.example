# ============================================
# SYNTHEX Environment Variables Template
# Copy this to .env and fill in your values
# ============================================

# Core Configuration
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://synthex.social

# Supabase (Get these from your Supabase project settings)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (CRITICAL: Use your actual Supabase password!)
# Get from: Supabase Dashboard > Settings > Database > Connection string
DATABASE_URL=postgresql://postgres:YOUR_ACTUAL_PASSWORD@db.your-project.supabase.co:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:YOUR_ACTUAL_PASSWORD@db.your-project.supabase.co:5432/postgres

# Authentication
JWT_SECRET=generate-a-secure-random-string-here

# Email Service (Optional - uses mock email if not configured)
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=your-sendgrid-api-key
