# SYNTHEX Production Environment Variables
# Copy these to Vercel Dashboard > Settings > Environment Variables

# ============================================
# REQUIRED - Must be set for production
# ============================================

# API Keys (Get from respective platforms)
ANTHROPIC_API_KEY=your_production_anthropic_api_key_here
OPENROUTER_API_KEY=your_production_openrouter_api_key_here

# Server Configuration
NODE_ENV=production
PORT=3000

# ============================================
# RECOMMENDED - Enhance production performance
# ============================================

# Rate Limiting (Production values)
RATE_LIMIT_WINDOW_GENERAL=900000  # 15 minutes
RATE_LIMIT_MAX_GENERAL=100        # Requests per window
RATE_LIMIT_WINDOW_API=60000       # 1 minute
RATE_LIMIT_MAX_API=50             # API requests per minute
RATE_LIMIT_WINDOW_CONTENT=60000   # 1 minute
RATE_LIMIT_MAX_CONTENT=20         # Content generation per minute

# MCP Configuration
MCP_SEQUENTIAL_THINKING_ENABLED=true
MCP_CONTEXT7_ENABLED=true
MCP_MAX_CONTEXT_WINDOWS=7
MCP_MAX_TOKENS_PER_WINDOW=4000
MCP_MEMORY_RETENTION=0.95

# MLE Star Configuration
MLE_STAR_MIN_PRODUCTION_SCORE=70
MLE_STAR_AUTO_EVALUATE=true
MLE_STAR_MONITORING_ENABLED=true

# Analytics Configuration
ANALYTICS_ENABLED=true
ANALYTICS_RETENTION_DAYS=90
ANALYTICS_BATCH_SIZE=100

# ============================================
# OPTIONAL - Advanced production features
# ============================================

# Security
CORS_ALLOWED_ORIGINS=https://synthex.vercel.app,https://synthex.dev
HELMET_ENABLED=true
CSRF_PROTECTION=true
API_KEY_ROTATION_DAYS=30

# Performance
CACHE_ENABLED=true
CACHE_TTL=3600
COMPRESSION_ENABLED=true
REQUEST_TIMEOUT=30000

# Monitoring (Add your monitoring service keys)
SENTRY_DSN=
NEW_RELIC_LICENSE_KEY=
DATADOG_API_KEY=
LOG_LEVEL=error

# Database Configuration (REQUIRED for production)
DATABASE_PROVIDER=postgresql
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?pgbouncer=true
DATABASE_POOL_SIZE=10
DATABASE_SSL=true

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL=3600

# For cloud providers (Upstash, Redis Cloud, etc.):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Deployment
AUTO_ROLLBACK_ENABLED=true
HEALTH_CHECK_INTERVAL=60000
HEALTH_CHECK_TIMEOUT=5000
MAX_DEPLOY_TIME=300000
GRACEFUL_SHUTDOWN_TIMEOUT=30000

# Feature Flags - Platform Optimizers
REACT_APP_GLASSMORPHIC=true
REACT_APP_OPTIMIZERS=true
REACT_APP_ANALYTICS=true
REACT_APP_CALENDAR=true
REACT_APP_CHARTS=true
REACT_APP_FILE_UPLOAD=true
REACT_APP_NOTIFICATIONS=true

# Platform Optimizer Features
REACT_APP_INSTAGRAM=true
REACT_APP_FACEBOOK=true
REACT_APP_TWITTER=true
REACT_APP_LINKEDIN=true
REACT_APP_TIKTOK=true
REACT_APP_PINTEREST=true
REACT_APP_YOUTUBE=true
REACT_APP_REDDIT=true

# Advanced Feature Flags
FEATURE_AB_TESTING=false
FEATURE_SMART_SCHEDULING=false
FEATURE_COMPETITOR_ANALYSIS=false
FEATURE_MULTI_LANGUAGE=false
FEATURE_VOICE_CONTENT=false

# External Integrations (Optional)
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
ZAPIER_WEBHOOK_URL=
WEBHOOK_SECRET=

# Email Notifications (Optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL=

# CDN Configuration
CDN_ENABLED=true
CDN_PROVIDER=vercel
CDN_URL=https://synthex.social
CDN_IMAGE_OPTIMIZATION=true
CDN_IMAGE_QUALITY=85
CDN_CSS_OPTIMIZATION=true
CDN_JS_OPTIMIZATION=true

# Backup Configuration (Optional)
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30