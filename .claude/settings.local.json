{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm run *)",
      "Bash(npm test*)",
      "Bash(npm install*)",
      "Bash(npx prisma generate)",
      "Bash(npx prisma db push)",
      "Bash(npx prisma migrate dev*)",
      "Bash(npx prisma studio)",
      "Bash(npx tsc*)",
      "Bash(node *)",
      "Bash(powershell *)",
      "Skill(gsd:progress)",
      "Skill(gsd:complete-milestone)",
      "Bash(python -c \"import sys,json; data=json.load\\(sys.stdin\\); issues=[json.loads\\(item[''text'']\\) if item.get\\(''type''\\)==''text'' else item for item in data]; print\\(json.dumps\\(issues, indent=2\\)[:3000]\\)\")",
      "Skill(commit-commands:commit)",
      "Skill(commit-commands:commit:*)",
      "mcp__2f101dc2-2ac2-4d93-9846-ffe27a392a3e__get_issue",
      "Bash(gh api:*)",
      "Bash(git:*)",
      "Bash(gh run:*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git branch -D *)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf .*)",
      "Bash(rmdir /s /q *)",
      "Bash(prisma migrate reset*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "linear"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"C:\\Synthex\\.claude\\hooks\\guard-destructive.ps1\" -ToolInput \"$TOOL_INPUT\""
          },
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"C:\\Synthex\\.claude\\hooks\\pre-build-validate.ps1\" -ToolInput \"$TOOL_INPUT\""
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"C:\\Synthex\\.claude\\hooks\\pre-write-validate.ps1\" -ToolInput \"$TOOL_INPUT\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"C:\\Synthex\\.claude\\hooks\\post-write-quality.ps1\" -ToolInput \"$TOOL_INPUT\""
          },
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"C:\\Synthex\\.claude\\hooks\\post-research-capture.ps1\" -ToolInput \"$TOOL_INPUT\""
          }
        ]
      }
    ]
  }
}
