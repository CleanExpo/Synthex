{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "typeRoots": ["node_modules/@types", "src/types"]
  },
  "include": ["src", "src/types/**/*.d.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/architecture/**/*",
    "src/business/**/*",
    "src/data/**/*",
    "src/infrastructure/**/*",
    "src/presentation/**/*",
    "src/testing/**/*"
  ]
}
