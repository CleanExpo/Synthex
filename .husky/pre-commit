#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# SECURITY PRE-COMMIT CHECKS
echo "🔒 Running security checks before commit..."

# =============================================================================
# 1. Block .env files and credential files from being committed
# =============================================================================
echo "Checking for sensitive files..."
BLOCKED_FILES=$(git diff --cached --name-only | grep -iE '\.env$|\.env\.[a-z]+$|\.pem$|\.key$|\.p12$|\.pfx$|\.jks$|credentials\.json|service[-_]account.*\.json' | grep -v '\.example$' | grep -v '\.test$')
if [ -n "$BLOCKED_FILES" ]; then
  echo "❌ SECURITY ERROR: Attempting to commit sensitive files!"
  echo "Blocked files:"
  echo "$BLOCKED_FILES"
  echo ""
  echo "These files must NEVER be committed to version control."
  echo "Add them to .gitignore if not already listed."
  exit 1
fi

# =============================================================================
# 2. Scan staged files for hardcoded secrets
# =============================================================================
echo "Scanning for hardcoded secrets..."

# Get only staged file content (not filenames) to check for secret patterns
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx|js|jsx|json|yaml|yml|sh|py|env)$' | grep -v 'node_modules' | grep -v '\.test\.' | grep -v '__tests__' | grep -v 'test/' | grep -v 'tests/' | grep -v '\.example' | grep -v '\.md$')

if [ -n "$STAGED_FILES" ]; then
  # Check for high-confidence secret patterns (real API keys, not variable names)
  SECRET_MATCHES=$(echo "$STAGED_FILES" | xargs git diff --cached -- 2>/dev/null | grep '^+' | grep -v '^+++' | grep -iE '(sk_live_[a-zA-Z0-9]{20,}|sk_test_[a-zA-Z0-9]{20,}|pk_live_[a-zA-Z0-9]{20,}|AKIA[A-Z0-9]{16}|ghp_[A-Za-z0-9]{36}|gho_[A-Za-z0-9]{36}|glpat-[A-Za-z0-9\-]{20}|xoxb-[0-9]{10,}|xoxp-[0-9]{10,}|AIzaSy[A-Za-z0-9\-_]{33}|-----BEGIN (RSA |EC )?PRIVATE KEY|eyJ[A-Za-z0-9_-]{20,}\.[A-Za-z0-9_-]{20,}\.)' 2>/dev/null)

  if [ -n "$SECRET_MATCHES" ]; then
    echo "❌ SECURITY ERROR: Hardcoded secrets detected in staged changes!"
    echo ""
    echo "Matches found (showing patterns, not values):"
    echo "$SECRET_MATCHES" | head -5
    echo ""
    echo "Remove these secrets and use environment variables instead."
    echo "Production secrets belong in Vercel dashboard, not in code."
    exit 1
  fi

  # Check for common secret assignment patterns (lower confidence, warn only)
  SUSPICIOUS=$(echo "$STAGED_FILES" | xargs git diff --cached -- 2>/dev/null | grep '^+' | grep -v '^+++' | grep -iE '(password|secret|token|api_key)\s*[:=]\s*["\x27][^"\x27]{8,}' | grep -v 'process\.env' | grep -v 'example' | grep -v 'placeholder' | grep -v 'your_' | grep -v 'xxx' | head -5)

  if [ -n "$SUSPICIOUS" ]; then
    echo "⚠️  Warning: Possible hardcoded credentials detected:"
    echo "$SUSPICIOUS"
    echo ""
    echo "If these are test values or examples, you can proceed."
    echo "If they are real secrets, remove them NOW."
  fi
fi

# =============================================================================
# 3. Check for accidentally large files (>5MB) that might contain data dumps
# =============================================================================
LARGE_FILES=$(git diff --cached --name-only --diff-filter=ACMR | while read -r f; do
  if [ -f "$f" ]; then
    SIZE=$(wc -c < "$f" 2>/dev/null || echo 0)
    if [ "$SIZE" -gt 5242880 ]; then
      echo "$f ($(( SIZE / 1048576 ))MB)"
    fi
  fi
done)

if [ -n "$LARGE_FILES" ]; then
  echo "⚠️  Warning: Large files staged for commit:"
  echo "$LARGE_FILES"
  echo "Consider adding these to .gitignore if they contain data."
fi

echo "✅ Security checks passed!"
