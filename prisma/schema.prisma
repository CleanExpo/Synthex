// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Google OAuth fields
  googleId        String?  @unique
  avatar          String?
  authProvider    String   @default("local") // 'local', 'google'
  emailVerified   Boolean  @default(false)
  lastLogin       DateTime?
  
  // API Keys (encrypted)
  openrouterApiKey String?
  anthropicApiKey  String?
  
  // User settings
  preferences      Json?
  
  // Password reset fields
  resetCode        String?
  resetCodeExpires DateTime?
  resetToken       String?
  resetTokenExpires DateTime?
  
  // Email verification
  verificationCode String?
  verificationExpires DateTime?
  
  // Relations
  campaigns        Campaign[]
  projects         Project[]
  apiUsage         ApiUsage[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  platformConnections PlatformConnection[]
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id])
  teamInvitations  TeamInvitation[]
  brandGenerations BrandGeneration[]
  psychologyPreferences UserPsychologyPreference?
  
  @@map("users")
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  description String?
  platform    String   // 'instagram', 'twitter', 'linkedin', etc.
  status      String   @default("draft") // 'draft', 'active', 'paused', 'completed'
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Campaign data
  content     Json?    // Generated content, variations, etc.
  analytics   Json?    // Performance metrics
  settings    Json?    // Platform-specific settings

  // Relations
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts       Post[]

  // Organization (multi-tenant)
  organizationId String?
  organization   Organization? @relation("OrganizationCampaigns", fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@map("campaigns")
}

model Post {
  id         String   @id @default(cuid())
  content    String
  platform   String
  status     String   @default("draft") // 'draft', 'scheduled', 'published', 'failed'
  scheduledAt DateTime?
  publishedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Post data
  metadata   Json?    // Images, hashtags, mentions, etc.
  analytics  Json?    // Engagement metrics

  // Relations
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  // Performance indices for common queries
  @@index([campaignId, createdAt(sort: Desc)])
  @@index([platform, status])
  @@index([scheduledAt])
  @@map("posts")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   // 'marketing', 'content', 'analytics'
  data        Json?    // Project configuration and data
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("projects")
}

model ApiUsage {
  id        String   @id @default(cuid())
  endpoint  String
  model     String?  // AI model used
  tokens    Int?     // Tokens consumed
  cost      Float?   // Cost in USD
  status    String   // 'success', 'error', 'rate_limited'
  createdAt DateTime @default(now())
  
  // Request/Response data
  requestData  Json?
  responseData Json?
  errorMessage String?
  
  // Relations
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("api_usage")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  @@map("sessions")
}

model Notification {
  id          String   @id @default(cuid())
  type        String   // 'info', 'warning', 'error', 'success'
  title       String
  message     String
  read        Boolean  @default(false)
  data        Json?    // Additional notification data
  createdAt   DateTime @default(now())
  
  // Relations
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("notifications")
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String   // 'user_login', 'post_publish', 'password_change', etc.
  resource    String   // 'authentication', 'user', 'post', 'api_key', etc.
  resourceId  String?  // ID of the affected resource
  entity      String?  // Backward compatibility - deprecated
  entityId    String?  // Backward compatibility - deprecated
  details     Json?    // Additional details about the action
  ipAddress   String?
  userAgent   String?
  severity    String   @default("medium") // 'low', 'medium', 'high', 'critical'
  category    String   @default("system") // 'auth', 'data', 'system', 'security', 'compliance', 'api'
  outcome     String   @default("success") // 'success', 'failure', 'warning'
  createdAt   DateTime @default(now())
  
  // Relations
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("audit_logs")
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  plan        String   @default("free") // 'free', 'starter', 'pro', 'enterprise'
  status      String   @default("active") // 'active', 'suspended', 'pending', 'deleted'
  settings    Json?    // Organization-wide settings
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Domain configuration (multi-tenant)
  domain       String?  @unique // Primary subdomain (e.g., acme.synthex.app)
  customDomain String?  @unique // Custom domain (e.g., marketing.acme.com)

  // Branding
  logo         String?
  primaryColor String?
  favicon      String?

  // Billing
  stripeCustomerId String?
  billingEmail     String?
  billingStatus    String @default("active") // 'active', 'past_due', 'canceled'

  // Usage limits
  maxUsers      Int @default(5)
  maxPosts      Int @default(500)
  maxCampaigns  Int @default(10)

  // Relations
  users             User[]
  teamInvitations   TeamInvitation[]
  roles             Role[]
  campaigns         Campaign[]       @relation("OrganizationCampaigns")

  // Indices for multi-tenant queries
  @@index([slug])
  @@index([status])
  @@index([plan])
  @@map("organizations")
}

// Platform Integration Models
model PlatformConnection {
  id           String   @id @default(cuid())
  userId       String
  platform     String   // 'facebook', 'instagram', 'twitter', 'linkedin', 'tiktok', 'youtube', 'pinterest', 'reddit'
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  scope        String?  // Platform-specific permissions
  profileId    String?  // Platform user/page ID
  profileName  String?  // Platform username/page name
  isActive     Boolean  @default(true)
  lastSync     DateTime?
  metadata     Json?    // Platform-specific data
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  // Relations
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platformPosts PlatformPost[]
  
  @@unique([userId, platform, profileId])
  @@map("platform_connections")
}

model PlatformPost {
  id           String   @id @default(cuid())
  connectionId String
  platformId   String   // ID on the platform
  content      String   @db.Text
  mediaUrls    String[]
  hashtags     String[]
  mentions     String[]
  status       String   // 'draft', 'scheduled', 'published', 'failed'
  scheduledAt  DateTime?
  publishedAt  DateTime?
  errorMessage String?
  metadata     Json?    // Platform-specific post data
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  // Relations
  connection   PlatformConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  metrics      PlatformMetrics[]
  
  @@unique([connectionId, platformId])
  @@map("platform_posts")
}

model PlatformMetrics {
  id          String   @id @default(cuid())
  postId      String
  likes       Int      @default(0)
  shares      Int      @default(0)
  comments    Int      @default(0)
  views       Int      @default(0)
  reach       Int      @default(0)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  saves       Int      @default(0)
  engagementRate Float?
  metadata    Json?    // Platform-specific metrics
  recordedAt  DateTime @default(now())

  // Relations
  post        PlatformPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  // Performance indices for analytics queries
  @@index([postId, recordedAt(sort: Desc)])
  @@index([recordedAt])
  @@map("platform_metrics")
}

//
// Team invitations (persistence for /api/teams/invite)
//
model TeamInvitation {
  id             String   @id @default(cuid())
  email          String
  role           String
  message        String?
  campaignAccess Json?
  status         String   @default("sent")
  sentAt         DateTime @default(now())

  // Optional relations (who invited, and org context), kept nullable to avoid blocking usage
  userId         String?
  organizationId String?
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([email])
  @@map("team_invitations")
}

// ==========================================
// Strategic Marketing Models
// ==========================================

model PsychologyPrinciple {
  id                   String   @id @default(uuid())
  name                 String   @unique
  category             String
  description          String?
  brandingApplication  Json     @default("{}")
  triggerWords         String[]
  audienceRelevance    Json     @default("{}")
  effectivenessScore   Decimal  @default(0.00) @db.Decimal(3, 2)
  usageCount           Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([category])
  @@index([effectivenessScore(sort: Desc)])
  @@map("psychology_principles")
}

model BrandGeneration {
  id                   String   @id @default(uuid())
  userId               String
  businessType         String
  targetAudience       Json
  brandGoals           String[]
  tonePreference       String?
  psychologyStrategy   Json
  brandNames           Json
  taglines             Json
  metadataPackages     Json     @default("{}")
  implementationGuide  Json     @default("{}")
  effectivenessScore   Decimal  @default(0.00) @db.Decimal(3, 2)
  status               String   @default("draft")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  psychologyMetrics    PsychologyMetric[]
  competitiveAnalyses  CompetitiveAnalysis[]

  @@index([userId])
  @@index([status])
  @@map("brand_generations")
}

model PsychologyMetric {
  id                   String   @id @default(uuid())
  generationId         String
  principleUsed        String
  variantType          String
  variantContent       String
  engagementScore      Decimal  @default(0.00) @db.Decimal(3, 2)
  conversionRate       Decimal  @default(0.00) @db.Decimal(5, 2)
  recallScore          Decimal  @default(0.00) @db.Decimal(3, 2)
  clickThroughRate     Decimal  @default(0.00) @db.Decimal(5, 2)
  clientSatisfaction   Int?
  testDurationHours    Int      @default(24)
  sampleSize           Int      @default(0)
  testedAt             DateTime @default(now())
  
  generation           BrandGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)

  @@index([generationId])
  @@index([principleUsed])
  @@map("psychology_metrics")
}

model UserPsychologyPreference {
  id                   String   @id @default(uuid())
  userId               String   @unique
  preferredPrinciples  String[]
  avoidedPrinciples    String[]
  industryFocus        String?
  targetDemographic    Json     @default("{}")
  successMetrics       Json     @default("{}")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_psychology_preferences")
}

model CompetitiveAnalysis {
  id                   String   @id @default(uuid())
  generationId         String
  competitorName       String
  competitorTagline    String?
  identifiedPrinciples String[]
  differentiationStrategy String?
  marketPosition       String?
  analyzedAt           DateTime @default(now())
  
  generation           BrandGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)

  @@map("competitive_analyses")
}

model AnalyticsEvent {
  id          String   @id @default(cuid())
  type        String   // Event type
  userId      String?
  sessionId   String
  timestamp   DateTime @default(now())
  metadata    Json?
  platform    String?
  contentId   String?
  campaignId  String?

  @@index([userId])
  @@index([sessionId])
  @@index([timestamp])
  @@map("analytics_events")
}

// ==========================================
// Quote Module - Content Quotes for Social Media
// @task UNI-418 - Quote Module Integration Tests
// ==========================================

model Quote {
  id           String   @id @default(cuid())
  text         String   @db.Text
  author       String?
  source       String?  // Where the quote is from (book, speech, etc.)
  category     String   // 'inspirational', 'motivational', 'business', 'humor', etc.
  tags         String[]
  isCustom     Boolean  @default(false)  // User-generated vs system
  isPublic     Boolean  @default(true)
  language     String   @default("en")

  // Engagement tracking
  usageCount   Int      @default(0)
  likeCount    Int      @default(0)
  shareCount   Int      @default(0)

  // AI metadata
  aiGenerated  Boolean  @default(false)
  sentiment    String?  // 'positive', 'neutral', 'negative'
  readingLevel String?  // 'easy', 'medium', 'advanced'

  // Relations
  userId       String?
  campaignId   String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  expiresAt    DateTime?  // Optional expiration for time-sensitive quotes

  @@index([category])
  @@index([userId])
  @@index([tags])
  @@index([aiGenerated])
  @@map("quotes")
}

model QuoteCollection {
  id           String   @id @default(cuid())
  name         String
  description  String?
  userId       String
  isPublic     Boolean  @default(false)
  quoteIds     String[]  // Array of quote IDs in this collection

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@map("quote_collections")
}

// ==========================================
// Task Management Module
// ==========================================

model Task {
  id           String   @id @default(cuid())
  title        String
  description  String?  @db.Text
  status       String   @default("todo") // 'todo', 'in-progress', 'review', 'done'
  priority     String   @default("medium") // 'low', 'medium', 'high', 'urgent'
  dueDate      DateTime?

  // Task metadata
  tags         String[]
  category     String?  // 'marketing', 'content', 'analytics', 'campaign'
  estimatedTime Int?     // In minutes
  actualTime   Int?      // In minutes
  progress     Int      @default(0) // 0-100 percent

  // Task organization
  columnId     String?  // For Kanban board columns
  order        Int      @default(0) // Position in list

  // Relations
  userId       String
  assigneeId   String?
  campaignId   String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  completedAt  DateTime?

  // Performance indices for common queries
  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([userId, status, dueDate])
  @@index([assigneeId, priority])
  @@map("tasks")
}

// ==========================================
// AI Persona Module
// ==========================================

model Persona {
  id           String   @id @default(cuid())
  name         String
  description  String?  @db.Text
  status       String   @default("draft") // 'draft', 'training', 'active', 'archived'

  // Persona attributes
  tone         String   @default("professional") // 'professional', 'casual', 'authoritative', etc.
  style        String   @default("formal") // 'formal', 'conversational', 'thought-provoking'
  vocabulary   String   @default("standard") // 'simple', 'standard', 'technical', 'sophisticated'
  emotion      String   @default("neutral") // 'neutral', 'friendly', 'confident', 'inspiring'

  // Training data stats
  trainingSourcesCount Int @default(0)
  trainingWordsCount   Int @default(0)
  trainingSamplesCount Int @default(0)

  // Performance metrics
  accuracy     Int      @default(0) // 0-100
  lastTrained  DateTime?

  // Relations
  userId       String

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@map("personas")
}

// ==========================================
// Role-Based Access Control (RBAC) Module
// ==========================================

model Role {
  id           String   @id @default(cuid())
  name         String
  description  String?
  permissions  String[] // Array of permission strings
  isDefault    Boolean  @default(false)
  isSystem     Boolean  @default(false) // System roles cannot be deleted
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Organization scope
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Relations
  userRoles      UserRole[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("roles")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  grantedAt DateTime @default(now())
  grantedBy String?  // ID of user who granted the role
  expiresAt DateTime?

  // Relations
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model PermissionAudit {
  id           String   @id @default(cuid())
  action       String   // 'grant', 'revoke', 'create_role', 'update_role', 'delete_role'
  targetUserId String?
  targetRoleId String?
  performedBy  String
  details      Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  // Organization scope
  organizationId String

  @@index([organizationId])
  @@index([performedBy])
  @@index([createdAt])
  @@map("permission_audits")
}

// ==========================================
// Content Calendar Module
// ==========================================

model CalendarPost {
  id             String   @id @default(cuid())
  title          String
  content        String   @db.Text
  platforms      String[] // Multi-platform support
  status         String   @default("draft") // 'draft', 'scheduled', 'published', 'failed', 'cancelled'
  scheduledFor   DateTime
  publishedAt    DateTime?

  // Media and content metadata
  mediaUrls      String[]
  tags           String[]
  hashtags       String[]
  mentions       String[]

  // Recurrence support
  recurrenceType String?  // 'none', 'daily', 'weekly', 'biweekly', 'monthly'
  recurrenceInterval Int?
  recurrenceEndDate DateTime?
  recurrenceOccurrences Int?
  recurrenceDaysOfWeek Int[] // 0-6 for Sunday-Saturday
  recurrenceDayOfMonth Int?
  parentPostId   String?  // Links to parent for recurring posts

  // Campaign and organization
  campaignId     String?
  organizationId String
  userId         String   // Created by

  // Metadata
  metadata       Json?    // Platform-specific settings
  analytics      Json?    // Engagement metrics after publish
  errorMessage   String?  // For failed posts

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Self-referential relation for recurring posts
  parentPost     CalendarPost?  @relation("RecurringPosts", fields: [parentPostId], references: [id], onDelete: SetNull)
  childPosts     CalendarPost[] @relation("RecurringPosts")

  // Performance indices
  @@index([organizationId, scheduledFor(sort: Desc)])
  @@index([userId, status])
  @@index([status, scheduledFor])
  @@index([campaignId])
  @@index([parentPostId])
  @@map("calendar_posts")
}
