  @@index([userId, category])
  @@index([unlockedAt])
  @@map("user_achievements")
}

// ==========================================
// Referral System — Viral growth loops
// Format: SYN-XXXX codes
// ==========================================

model Referral {
  id              String    @id @default(cuid())
  referrerId      String    @map("referrer_id")
  refereeId       String?   @unique @map("referee_id") // Set when referee signs up (one-to-one)
  refereeEmail    String    @map("referee_email") // Email invited

  // Referral code
  code            String    @unique // Format: SYN-XXXX

  // Status tracking
  status          String    @default("sent") // 'sent', 'clicked', 'signed_up', 'converted', 'expired'

  // Reward tracking
  referrerRewarded Boolean  @default(false) @map("referrer_rewarded")
  refereeRewarded  Boolean  @default(false) @map("referee_rewarded")
  rewardType       String?  @map("reward_type") // 'credits', 'discount', 'feature_unlock'
  rewardAmount     Int?     @map("reward_amount") // e.g., 500 for 500 AI credits

  // Metadata
  clickedAt       DateTime? @map("clicked_at")
  signedUpAt      DateTime? @map("signed_up_at")
  convertedAt     DateTime? @map("converted_at")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  referrer        User      @relation("ReferrerReferrals", fields: [referrerId], references: [id], onDelete: Cascade)
  referee         User?     @relation("RefereeReferral", fields: [refereeId], references: [id], onDelete: SetNull)

  @@index([referrerId])
  @@index([refereeEmail])
  @@index([status])
  @@map("referrals")
}

// ==========================================
// Loyalty Tiers — Long-term retention & rewards
// Bronze → Silver → Gold → Platinum
// ==========================================

model UserLoyaltyTier {
  id              String    @id @default(cuid())
  userId          String    @unique @map("user_id")

