  // Click data
  ipHash          String?   @map("ip_hash")     // Hashed IP for dedup
  userAgent       String?   @map("user_agent")
  referer         String?
  country         String?

  // Conversion
  converted       Boolean   @default(false)
  revenue         Decimal?  @db.Decimal(12, 2)
  orderId         String?   @map("order_id")

  createdAt       DateTime  @default(now()) @map("created_at")

  link            AffiliateLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId])
  @@index([linkId, createdAt])
  @@index([createdAt])
  @@map("affiliate_link_clicks")
}

// ──────────────────────────────────────────────────────────────────────────
// Business Vetting & API Credential Models
// ──────────────────────────────────────────────────────────────────────────

model BusinessVettingResult {
  id                  String   @id @default(cuid())
  userId              String   @map("user_id")
  organizationId      String?  @map("organization_id")
  
  // Vetting input data
  businessName        String   @map("business_name")
  website             String?
  abnNumber           String?  @map("abn_number")     // Australian Business Number
  businessLocation    String?  @map("business_location")
  
  // Health check scores (0-100)
  overallScore        Int      @map("overall_score")   // Average of component scores
  seoScore            Int?     @map("seo_score")       // SEO health
  aeoScore            Int?     @map("aeo_score")       // AI Engine Optimization
  geoScore            Int?     @map("geo_score")       // Geographic/Local SEO
  socialScore         Int?     @map("social_score")    // Social media presence
  
  // Detailed results (JSON for flexibility)
  seoDetails          Json?    @map("seo_details")     // { mobileReady, indexingStatus, coreWebVitals, etc }
  aeoDetails          Json?    @map("aeo_details")     // { schemaMarkup, entityData, eeatSignals, etc }
  geoDetails          Json?    @map("geo_details")     // { gbp, localCitations, mapSignals, etc }
  socialDetails       Json?    @map("social_details")  // { platforms: [{ name, handle, followers, etc }] }
  
  // Status and recommendations
  status              String   @default("pending")      // 'pending', 'completed', 'failed'
  recommendations     Json?                            // AI-generated recommendations
  vettingApprovedAt   DateTime? @map("vetting_approved_at") // When user approved vetting
  
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  
  // Relations
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization        Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  
  @@unique([userId, organizationId])
  @@index([userId])
  @@index([status])
  @@map("business_vetting_results")
}

model APICredential {
  id                  String   @id @default(cuid())
  userId              String   @map("user_id")
  organizationId      String?  @map("organization_id")
  
  // Provider type (openai, anthropic, google, openrouter)
  provider            String   // 'openai', 'anthropic', 'google', 'openrouter'
  
  // Encrypted key storage
  encryptedKey        String   @map("encrypted_key") @db.Text // AES-256-GCM encrypted
  encryptionKeyVersion Int    @default(1) @map("encryption_key_version")
  maskedKey           String?  @map("masked_key")    // Last 4 chars for display: "****abcd"
  
  // Key validation
  isValid             Boolean  @default(false) @map("is_valid")
  lastValidatedAt     DateTime? @map("last_validated_at")
  validationError     String?  @map("validation_error")
  
  // Usage tracking
  lastUsedAt          DateTime? @map("last_used_at")
  usageCount          Int       @default(0) @map("usage_count")
  
  // Status
  isActive            Boolean  @default(true) @map("is_active")
  revokedAt           DateTime? @map("revoked_at")
  
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  
  // Relations
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization        Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  
  @@unique([userId, provider, organizationId])
  @@index([userId])
  @@index([provider])
  @@index([isActive])
  @@map("api_credentials")
}

model PlatformOAuthCredential {
  id                   String   @id @default(cuid())

  // Platform identifier (twitter, linkedin, instagram, facebook, tiktok, youtube, pinterest, reddit, threads)
  platform             String   @unique

  // Encrypted OAuth credentials (AES-256-GCM via api-key-encryption)
  encryptedClientId    String   @map("encrypted_client_id") @db.Text
  encryptedClientSecret String  @map("encrypted_client_secret") @db.Text
  encryptionKeyVersion Int      @default(1) @map("encryption_key_version")

  // Display-safe masked values
  maskedClientId       String?  @map("masked_client_id")
  maskedClientSecret   String?  @map("masked_client_secret")

  // Status
  isActive             Boolean  @default(true) @map("is_active")

  // Audit trail
  configuredByUserId   String?  @map("configured_by_user_id")
  configuredBy         User?    @relation("PlatformOAuthConfiguredBy", fields: [configuredByUserId], references: [id], onDelete: SetNull)

  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@index([platform])
  @@index([isActive])
  @@map("platform_oauth_credentials")
}

model OnboardingProgress {
  id                  String   @id @default(cuid())
  userId              String   @map("user_id")
  organizationId      String   @map("organization_id")
  
  // Onboarding stage tracking
  currentStage        String   @default("vetting")     // 'vetting', 'api-setup', 'platforms', 'persona', 'complete'
  completedStages     String[] @map("completed_stages")
  
  // Vetting stage data
  businessName        String?  @map("business_name")
  website             String?
  abnNumber           String?  @map("abn_number")
  businessLocation    String?  @map("business_location")
  vettingApproved     Boolean  @default(false) @map("vetting_approved")
  vettingApprovedAt   DateTime? @map("vetting_approved_at")
  
  // API setup stage
  apiCredentialsAdded Boolean  @default(false) @map("api_credentials_added")
  apiSetupCompletedAt DateTime? @map("api_setup_completed_at")
  requiredProviders   String[]  @map("required_providers")  // Providers user must set up
  
  // Platforms stage
  selectedPlatforms   String[]  @map("selected_platforms")
  platformsApprovedAt DateTime? @map("platforms_approved_at")
  
  // Persona stage
  personaData         Json?    @map("persona_data")     // { name, tone, topics, etc }
  personaApprovedAt   DateTime? @map("persona_approved_at")

  // New onboarding data fields (UNI-1186 to UNI-1189)
  auditData           Json?    @map("audit_data")          // Website audit results: SEO, perf, competitors
  goalsData           Json?    @map("goals_data")          // Goals questionnaire + generated marketing plan
  postingMode         String?  @map("posting_mode")        // 'manual' | 'assisted' | 'auto'
  socialProfileUrls   Json?    @map("social_profile_urls") // { platform: url } verified social handles

  // Overall status
  status              String   @default("in-progress")  // 'in-progress', 'completed', 'abandoned'
  completedAt         DateTime? @map("completed_at")
  abandonedAt         DateTime? @map("abandoned_at")
  
  // Metadata
  metadata            Json?                           // Additional tracking data
  
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  
  // Relations
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  @@unique([userId, organizationId])
  @@index([userId])
  @@index([currentStage])
  @@index([status])
  @@map("onboarding_progress")
}

// ==========================================
// Video Generation Module
// AI-powered video script generation, rendering, and publishing
// ==========================================

model VideoGeneration {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  organizationId   String?  @map("organization_id")

  // Video details
  title            String
  topic            String
  style            String   // 'social-reel', 'explainer', 'how-to'
  duration         String   // '15-60s', '2-3m', '3-5m'

  // Generation state
  status           String   @default("pending") // 'pending', 'generating', 'rendered', 'published', 'failed'
  errorMessage     String?  @map("error_message")

  // Script content (generated by AI)
  scriptContent    Json?    @map("script_content") // { scenes: [...], voiceover: string, visualDescriptions: string[] }

  // Output assets
  videoUrl         String?  @map("video_url")
  thumbnailUrl     String?  @map("thumbnail_url")
  youtubeVideoId   String?  @map("youtube_video_id")

  // Scheduling metadata
  publishedAt      DateTime? @map("published_at")
  scheduledPlatforms String[] @map("scheduled_platforms") // ['youtube', 'instagram', 'linkedin']

  // General metadata
  metadata         Json?    // Additional config, AI model used, processing time, etc.

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization     Organization? @relation("OrganizationVideos", fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([organizationId])
  @@index([createdAt(sort: Desc)])
  @@map("video_generations")
}