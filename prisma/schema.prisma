}

// ==========================================
// GEO / E-E-A-T / Paper Banana Integration
// Author profiles, SEO audits, GEO analysis,
// research reports, visual assets, local case studies
// ==========================================

model AuthorProfile {
  id              Int       @id @default(autoincrement())
  userId          String    @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Identity
  name            String
  slug            String    @unique
  bio             String    @db.Text
  credentials     Json?     // [{type, title, institution, year}]
  socialLinks     Json?     @map("social_links") // {linkedin, twitter, youtube, wikipedia, scholar}
  avatarUrl       String?   @map("avatar_url")

  // Entity linking (Schema.org sameAs)
  sameAsUrls      String[]  @map("same_as_urls")
  expertiseAreas  String[]  @map("expertise_areas")

  // Verification
  verifiedAt      DateTime? @map("verified_at")
  eeatScore       Float?    @map("eeat_score") // Cached E-E-A-T score for this author

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  articles        ArticleAuthor[]
  geoAnalyses     GEOAnalysis[]

  @@index([userId])
  @@map("author_profiles")
}

model SEOAudit {
  id              Int       @id @default(autoincrement())
  userId          String    @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Audit target
  url             String
  auditType       String    @map("audit_type") // 'full', 'page', 'geo', 'eeat'

  // Scores
  overallScore    Float     @map("overall_score")
  eeatScore       Json?     @map("eeat_score") // {experience, expertise, authority, trust, overall}
  geoScore        Json?     @map("geo_score") // {citability, structure, multiModal, authority, technical, overall}
  technicalScore  Json?     @map("technical_score") // {performance, accessibility, seo, bestPractices}

  // Results
  recommendations Json      // [{priority, category, description, impact}]
  rawData         Json?     @db.JsonB @map("raw_data")

  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([userId, createdAt])
  @@index([auditType])
  @@map("seo_audits")
}

model ScheduledAuditTarget {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  url             String
  name            String    // Friendly name like "Main Site" or "Blog"
  frequency       String    // "daily", "weekly", "monthly"
  alertThreshold  Int       @default(10) @map("alert_threshold") // Score drop percentage to trigger alert
  enabled         Boolean   @default(true)

  lastRunAt       DateTime? @map("last_run_at")
  lastScore       Float?    @map("last_score")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([enabled, frequency])
  @@map("scheduled_audit_targets")
}

model GEOAnalysis {
  id              Int       @id @default(autoincrement())
  userId          String    @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Content reference
  contentId       String?   @map("content_id") // Reference to Post or custom content
  authorId        Int?      @map("author_id")
  author          AuthorProfile? @relation(fields: [authorId], references: [id])
  contentUrl      String?   @map("content_url")
  contentText     String    @db.Text @map("content_text")
  platform        String    // 'google_aio', 'chatgpt', 'perplexity', 'all'

  // Scores (0-100)
  overallScore    Float     @map("overall_score")
  citabilityScore Float     @map("citability_score") // Passage-level citability (25% weight)
  structureScore  Float     @map("structure_score") // Heading hierarchy, lists, tables (20% weight)
  multiModalScore Float     @map("multi_modal_score") // Images, video, interactive (15% weight)
  authorityScore  Float     @map("authority_score") // E-E-A-T + brand signals (20% weight)
  technicalScore  Float     @map("technical_score") // SSR, AI crawlers, llms.txt (20% weight)

  // Detailed findings
  citablePassages Json      @map("citable_passages") // [{text, wordCount, score, startIndex}]
  recommendations Json      // [{priority, action, impact, effort}]
  schemaIssues    Json?     @map("schema_issues") // Missing/invalid structured data

  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([platform])
  @@index([overallScore])
  @@map("geo_analyses")
}

model GEOResearchReport {
  id              Int       @id @default(autoincrement())
  userId          String    @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Report identity
  title           String
  slug            String    @unique
  status          String    @default("draft") // 'draft', 'review', 'published'
  sasScore        Float?    @map("sas_score") // Synthex Authority Score (0-10)

  // Content sections
  executiveSummary String?  @db.Text @map("executive_summary")
  methodology     String?   @db.Text
  findings        Json?     // [{finding, statistic, source, citationUrl}]
  recommendations Json?     // [{step, description, priority}]
  fullContent     String?   @db.Text @map("full_content")

  // Data & citations
  dataSources     Json?     @map("data_sources") // [{name, url, type, trustLevel}]
  citations       Json?     // [{text, source, url, accessedAt}]
  datasetUrl      String?   @map("dataset_url") // CSV/JSON download link

  // SEO metadata
  schemaMarkup    Json?     @map("schema_markup") // Full JSON-LD
  metaTitle       String?   @map("meta_title")
  metaDescription String?   @map("meta_description")

  // Timestamps
  publishedAt     DateTime? @map("published_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  visuals         VisualAsset[]

  @@index([userId])
  @@index([status])
  @@map("geo_research_reports")
