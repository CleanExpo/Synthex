// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
  previewFeatures = ["driverAdapters"]  // Enable driver adapters for Supabase pooler compatibility
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?  // Nullable for OAuth-only users
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Legacy Google OAuth fields (deprecated - use Account model)
  // Keep temporarily for migration
  googleId        String?  @unique @map("google_id")
  avatar          String?
  authProvider    String   @default("local") @map("auth_provider") // 'local', 'google'
  emailVerified   Boolean?   @default(false) @map("email_verified") // Boolean indicating if email is verified
  lastLogin       DateTime? @map("last_login")

  // API Keys (encrypted)
  openrouterApiKey String? @map("openrouter_api_key")
  anthropicApiKey  String? @map("anthropic_api_key")

  // User settings
  preferences      Json?

  // Password reset fields
  resetCode        String? @map("reset_code")
  resetCodeExpires DateTime? @map("reset_code_expires")
  resetToken       String? @map("reset_token")
  resetTokenExpires DateTime? @map("reset_token_expires")

  // Email verification
  verificationCode String? @map("verification_code")
  verificationExpires DateTime? @map("verification_expires")

  // Relations
  accounts         Account[]  // Multi-provider authentication accounts
  campaigns        Campaign[]
  projects         Project[]
  apiUsage         ApiUsage[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  platformConnections PlatformConnection[]
  organizationId   String? @map("organization_id")
  organization     Organization? @relation(fields: [organizationId], references: [id])
  teamInvitations  TeamInvitation[]
  brandGenerations BrandGeneration[]
  psychologyPreferences UserPsychologyPreference?
  reports          Report[]

  // Retention system relations
  aiConversations  AIConversation[]
  aiWeeklyDigests  AIWeeklyDigest[]
  healthScore      UserHealthScore?
  streak           UserStreak?
  achievements     UserAchievement[]
  referralsMade    Referral[]        @relation("ReferrerReferrals")
  referralReceived Referral?         @relation("RefereeReferral")
  loyaltyTier      UserLoyaltyTier?
  feedbackSurveys  FeedbackSurvey[]

  // GEO / E-E-A-T / Paper Banana relations
  authorProfiles   AuthorProfile[]
  seoAudits        SEOAudit[]
  geoAnalyses      GEOAnalysis[]
  researchReports  GEOResearchReport[]
  visualAssets     VisualAsset[]
  localCaseStudies LocalCaseStudy[]

  // Multi-business owner system
  isMultiBusinessOwner  Boolean   @default(false) @map("is_multi_business_owner")
  activeOrganizationId  String?   @map("active_organization_id")
  ownedBusinesses       BusinessOwnership[] @relation("OwnedBusinesses")

  @@index([organizationId])
  @@map("users")
}

// ==========================================
// OAuth Account Model for Multi-Provider Authentication
// Supports linking multiple auth methods to a single user
// ==========================================

model Account {
  id                String   @id @default(uuid())
  userId            String   @map("userId")
  type              String   // "oauth" or "credentials"
  provider          String   // "google", "github", "email"
  providerAccountId String   @map("providerAccountId") // Google ID, GitHub ID, or email

  // OAuth tokens (encrypted at rest in production)
  // Column names use snake_case in database
  accessToken       String?  @db.Text @map("access_token")
  refreshToken      String?  @db.Text @map("refresh_token")
  expiresAt         Int?     @map("expires_at") // Unix timestamp
  tokenType         String?  @map("token_type") // "Bearer", etc.
  scope             String?  // OAuth scopes granted
  idToken           String?  @db.Text @map("id_token") // OIDC ID token
  sessionState      String?  @map("session_state") // OIDC session state

  createdAt         DateTime @default(now()) @map("createdAt")
  updatedAt         DateTime @updatedAt @map("updatedAt")

  // Relations
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Constraints
  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  description String?
  platform    String   // 'instagram', 'twitter', 'linkedin', etc.
  status      String   @default("draft") // 'draft', 'active', 'paused', 'completed'
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Campaign data
  content     Json?    // Generated content, variations, etc.
  analytics   Json?    // Performance metrics
  settings    Json?    // Platform-specific settings

  // Relations
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts       Post[]

  // Organization (multi-tenant)
  organizationId String?
  organization   Organization? @relation("OrganizationCampaigns", fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([organizationId])
  @@map("campaigns")
}

model Post {
  id         String   @id @default(cuid())
  content    String
  platform   String
  status     String   @default("draft") // 'draft', 'scheduled', 'published', 'failed'
  scheduledAt DateTime?
  publishedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Post data
  metadata   Json?    // Images, hashtags, mentions, etc.
  analytics  Json?    // Engagement metrics

  // Relations
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  // Performance indices for common queries
  @@index([campaignId, createdAt(sort: Desc)])
  @@index([platform, status])
  @@index([scheduledAt])
  @@map("posts")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   // 'marketing', 'content', 'analytics'
  data        Json?    // Project configuration and data
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("projects")
}

model ApiUsage {
  id        String   @id @default(cuid())
  endpoint  String
  model     String?  // AI model used
  tokens    Int?     // Tokens consumed
  cost      Float?   // Cost in USD
  status    String   // 'success', 'error', 'rate_limited'
  createdAt DateTime @default(now())
  
  // Request/Response data
  requestData  Json?
  responseData Json?
  errorMessage String?
  
  // Relations
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@map("api_usage")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  @@map("sessions")
}

// OAuth PKCE state storage — survives serverless cold starts
// Replaces in-memory Map that fails across Vercel workers
model OAuthPKCEState {
  id            String   @id @default(cuid())
  state         String   @unique
  codeVerifier  String   @map("code_verifier")
  provider      String   // 'google', 'github', etc.
  redirectUri   String   @map("redirect_uri")
  linkToUserId  String?  @map("link_to_user_id")
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("oauth_pkce_states")
}

model Notification {
  id          String   @id @default(cuid())
  type        String   // 'info', 'warning', 'error', 'success'
  title       String
  message     String
  read        Boolean  @default(false)
  data        Json?    // Additional notification data
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read, createdAt])
  @@map("notifications")
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String   // 'user_login', 'post_publish', 'password_change', etc.
  resource    String   // 'authentication', 'user', 'post', 'api_key', etc.
  resourceId  String?  // ID of the affected resource
  entity      String?  // Backward compatibility - deprecated
  entityId    String?  // Backward compatibility - deprecated
  details     Json?    // Additional details about the action
  ipAddress   String?
  userAgent   String?
  severity    String   @default("medium") // 'low', 'medium', 'high', 'critical'
  category    String   @default("system") // 'auth', 'data', 'system', 'security', 'compliance', 'api'
  outcome     String   @default("success") // 'success', 'failure', 'warning'
  createdAt   DateTime @default(now())
  
  // Relations
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([createdAt])
  @@index([category])
  @@map("audit_logs")
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  plan        String   @default("free") // 'free', 'starter', 'pro', 'enterprise'
  status      String   @default("active") // 'active', 'suspended', 'pending', 'deleted'
  settings    Json?    // Organization-wide settings
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Domain configuration (multi-tenant)
  domain       String?  @unique // Primary subdomain (e.g., acme.synthex.app)
  customDomain String?  @unique // Custom domain (e.g., marketing.acme.com)

  // Branding
  logo         String?
  primaryColor String?
  favicon      String?

  // Billing
  stripeCustomerId String?
  billingEmail     String?
  billingStatus    String @default("active") // 'active', 'past_due', 'canceled'

  // Usage limits
  maxUsers      Int @default(5)
  maxPosts      Int @default(500)
  maxCampaigns  Int @default(10)

  // Relations
  users             User[]
  teamInvitations   TeamInvitation[]
  roles             Role[]
  campaigns         Campaign[]       @relation("OrganizationCampaigns")
  businessOwners    BusinessOwnership[] @relation("BusinessOwners")

  // Indices for multi-tenant queries
  @@index([slug])
  @@index([status])
  @@index([plan])
  @@map("organizations")
}

// Platform Integration Models
model PlatformConnection {
  id           String   @id @default(cuid())
  userId       String
  platform     String   // 'facebook', 'instagram', 'twitter', 'linkedin', 'tiktok', 'youtube', 'pinterest', 'reddit'
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  scope        String?  // Platform-specific permissions
  profileId    String?  // Platform user/page ID
  profileName  String?  // Platform username/page name
  isActive     Boolean  @default(true)
  lastSync     DateTime?
  metadata     Json?    // Platform-specific data
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  // Relations
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platformPosts PlatformPost[]
  
  @@unique([userId, platform, profileId])
  @@map("platform_connections")
}

model PlatformPost {
  id           String   @id @default(cuid())
  connectionId String
  platformId   String   // ID on the platform
  content      String   @db.Text
  mediaUrls    String[]
  hashtags     String[]
  mentions     String[]
  status       String   // 'draft', 'scheduled', 'published', 'failed'
  scheduledAt  DateTime?
  publishedAt  DateTime?
  errorMessage String?
  metadata     Json?    // Platform-specific post data
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  // Relations
  connection   PlatformConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  metrics      PlatformMetrics[]
  
  @@unique([connectionId, platformId])
  @@map("platform_posts")
}

model PlatformMetrics {
  id          String   @id @default(cuid())
  postId      String
  likes       Int      @default(0)
  shares      Int      @default(0)
  comments    Int      @default(0)
  views       Int      @default(0)
  reach       Int      @default(0)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  saves       Int      @default(0)
  engagementRate Float?
  metadata    Json?    // Platform-specific metrics
  recordedAt  DateTime @default(now())

  // Relations
  post        PlatformPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  // Performance indices for analytics queries
  @@index([postId, recordedAt(sort: Desc)])
  @@index([recordedAt])
  @@map("platform_metrics")
}

//
// Team invitations (persistence for /api/teams/invite)
//
model TeamInvitation {
  id             String   @id @default(cuid())
  email          String
  role           String
  message        String?
  campaignAccess Json?
  status         String   @default("sent")
  sentAt         DateTime @default(now())

  // Optional relations (who invited, and org context), kept nullable to avoid blocking usage
  userId         String?
  organizationId String?
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([organizationId, status])
  @@map("team_invitations")
}

// ==========================================
// Strategic Marketing Models
// ==========================================

model PsychologyPrinciple {
  id                   String   @id @default(uuid())
  name                 String   @unique
  category             String
  description          String?
  brandingApplication  Json     @default("{}")
  triggerWords         String[]
  audienceRelevance    Json     @default("{}")
  effectivenessScore   Decimal  @default(0.00) @db.Decimal(3, 2)
  usageCount           Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([category])
  @@index([effectivenessScore(sort: Desc)])
  @@map("psychology_principles")
}

model BrandGeneration {
  id                   String   @id @default(uuid())
  userId               String
  businessType         String
  targetAudience       Json
  brandGoals           String[]
  tonePreference       String?
  psychologyStrategy   Json
  brandNames           Json
  taglines             Json
  metadataPackages     Json     @default("{}")
  implementationGuide  Json     @default("{}")
  effectivenessScore   Decimal  @default(0.00) @db.Decimal(3, 2)
  status               String   @default("draft")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  psychologyMetrics    PsychologyMetric[]
  competitiveAnalyses  CompetitiveAnalysis[]

  @@index([userId])
  @@index([status])
  @@map("brand_generations")
}

model PsychologyMetric {
  id                   String   @id @default(uuid())
  generationId         String
  principleUsed        String
  variantType          String
  variantContent       String
  engagementScore      Decimal  @default(0.00) @db.Decimal(3, 2)
  conversionRate       Decimal  @default(0.00) @db.Decimal(5, 2)
  recallScore          Decimal  @default(0.00) @db.Decimal(3, 2)
  clickThroughRate     Decimal  @default(0.00) @db.Decimal(5, 2)
  clientSatisfaction   Int?
  testDurationHours    Int      @default(24)
  sampleSize           Int      @default(0)
  testedAt             DateTime @default(now())
  
  generation           BrandGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)

  @@index([generationId])
  @@index([principleUsed])
  @@map("psychology_metrics")
}

model UserPsychologyPreference {
  id                   String   @id @default(uuid())
  userId               String   @unique
  preferredPrinciples  String[]
  avoidedPrinciples    String[]
  industryFocus        String?
  targetDemographic    Json     @default("{}")
  successMetrics       Json     @default("{}")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_psychology_preferences")
}

model CompetitiveAnalysis {
  id                   String   @id @default(uuid())
  generationId         String
  competitorName       String
  competitorTagline    String?
  identifiedPrinciples String[]
  differentiationStrategy String?
  marketPosition       String?
  analyzedAt           DateTime @default(now())
  
  generation           BrandGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)

  @@map("competitive_analyses")
}

model AnalyticsEvent {
  id          String   @id @default(cuid())
  type        String   // Event type
  userId      String?
  sessionId   String
  timestamp   DateTime @default(now())
  metadata    Json?
  platform    String?
  contentId   String?
  campaignId  String?

  @@index([userId])
  @@index([sessionId])
  @@index([timestamp])
  @@index([userId, timestamp])
  @@map("analytics_events")
}

model Report {
  id             String   @id @default(cuid())
  userId         String
  organizationId String?
  name           String
  type           String   // campaign, analytics, ab-test, psychology, comprehensive
  status         String   @default("pending") // pending, generating, completed, failed
  format         String   @default("pdf") // pdf, csv, json
  dateRange      Json?    // { start, end }
  filters        Json?    // Report-specific filters
  data           Json?    // Cached report data
  fileUrl        String?  // URL to generated file
  fileSize       Int?     // File size in bytes
  generatedAt    DateTime?
  expiresAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([type])
  @@map("reports")
}

// ==========================================
// Scheduled Reports - Automated Report Generation
// ==========================================

model ScheduledReport {
  id             String    @id @default(cuid())
  userId         String
  organizationId String?
  name           String
  description    String?
  templateId     String?   // Reference to ReportTemplate
  reportType     String    // overview, engagement, content, audience, campaigns, growth, custom
  frequency      String    // daily, weekly, biweekly, monthly, quarterly
  schedule       Json      // { dayOfWeek?, dayOfMonth?, hour, minute, timezone }
  format         String    @default("pdf") // pdf, csv, json
  dateRangeType  String    @default("last_period") // last_period, custom, rolling_7d, rolling_30d
  filters        Json?     // Platform, campaign, and other filters
  metrics        String[]  // Selected metrics to include
  recipients     String[]  // Email addresses
  webhookUrl     String?   // Optional webhook delivery
  isActive       Boolean   @default(true)
  lastRunAt      DateTime?
  lastRunStatus  String?   // success, failed, skipped
  lastReportId   String?   // ID of last generated report
  nextRunAt      DateTime?
  runCount       Int       @default(0)
  failureCount   Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  template       ReportTemplate? @relation(fields: [templateId], references: [id])

  @@index([userId])
  @@index([isActive, nextRunAt])
  @@index([organizationId])
  @@map("scheduled_reports")
}

// ==========================================
// Report Templates - Reusable Report Configurations
// ==========================================

model ReportTemplate {
  id             String    @id @default(cuid())
  userId         String?   // null = system template
  organizationId String?
  name           String
  description    String?
  category       String    // performance, engagement, growth, content, custom
  reportType     String    // overview, engagement, content, audience, campaigns, growth, custom
  metrics        String[]  // Default metrics
  dimensions     String[]  // Grouping dimensions
  filters        Json?     // Default filters
  visualizations Json?     // Chart configurations
  layout         Json?     // Report layout settings
  branding       Json?     // Custom branding (logo, colors)
  isSystem       Boolean   @default(false) // System-provided template
  isPublic       Boolean   @default(false) // Shared with organization
  usageCount     Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  scheduledReports ScheduledReport[]

  @@index([userId])
  @@index([organizationId])
  @@index([isSystem])
  @@index([category])
  @@map("report_templates")
}

// ==========================================
// Report Delivery Log - Track Report Deliveries
// ==========================================

model ReportDelivery {
  id             String    @id @default(cuid())
  reportId       String
  scheduledReportId String?
  deliveryType   String    // email, webhook, download
  recipient      String    // Email address or webhook URL
  status         String    // pending, sent, delivered, failed, bounced
  sentAt         DateTime?
  deliveredAt    DateTime?
  failedAt       DateTime?
  failureReason  String?
  retryCount     Int       @default(0)
  metadata       Json?     // Provider response, message ID, etc.
  createdAt      DateTime  @default(now())

  @@index([reportId])
  @@index([scheduledReportId])
  @@index([status])
  @@map("report_deliveries")
}

// ==========================================
// Sentiment Analysis - Content & Engagement Optimization
// ==========================================

model SentimentAnalysis {
  id             String    @id @default(cuid())
  userId         String
  contentType    String    // 'post', 'comment', 'campaign', 'text'
  contentId      String?   // Reference to content being analyzed
  text           String    @db.Text // The analyzed text

  // Sentiment scores
  sentiment      String    // 'positive', 'neutral', 'negative', 'mixed'
  score          Float     // -100 to 100
  confidence     Float     // 0 to 1

  // Detailed analysis
  emotions       Json?     // Array of { emotion, intensity }
  toneIndicators Json?     // Array of tone indicators
  keyPhrases     String[]  // Key phrases extracted

  // Engagement prediction
  predictedEngagement Json? // { likes, comments, shares, engagementRate }
  actualEngagement    Json? // Populated after post goes live
  predictionAccuracy  Float? // How accurate was the prediction

  // Platform context
  platform       String?   // twitter, instagram, linkedin, etc.

  // Metadata
  analyzedAt     DateTime  @default(now())
  model          String?   // AI model used for analysis

  @@index([userId])
  @@index([contentType, contentId])
  @@index([sentiment])
  @@index([analyzedAt])
  @@map("sentiment_analyses")
}

model SentimentTrend {
  id             String    @id @default(cuid())
  userId         String
  organizationId String?
  platform       String?   // null = all platforms
  date           DateTime  @db.Date

  // Aggregated sentiment
  avgScore       Float     // Average sentiment score for the day
  positiveCount  Int       @default(0)
  neutralCount   Int       @default(0)
  negativeCount  Int       @default(0)
  mixedCount     Int       @default(0)
  totalAnalyzed  Int       @default(0)

  // Emotion distribution
  emotionCounts  Json?     // { joy: 10, anger: 2, sadness: 1, ... }

  // Engagement correlation
  avgEngagement  Float?    // Average engagement rate for content with this sentiment
  topPerforming  String?   // Sentiment type that performed best

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([userId, platform, date])
  @@index([userId, date])
  @@index([organizationId, date])
  @@map("sentiment_trends")
}

model EngagementPrediction {
  id             String    @id @default(cuid())
  userId         String
  contentType    String    // 'post', 'campaign'
  contentId      String?

  // Input features
  sentimentScore Float
  sentiment      String
  platform       String
  contentLength  Int
  hasMedia       Boolean   @default(false)
  hasHashtags    Boolean   @default(false)
  hasMentions    Boolean   @default(false)
  postHour       Int?      // Hour of day (0-23)
  postDayOfWeek  Int?      // Day of week (0-6)

  // Predictions
  predictedLikes     Int
  predictedComments  Int
  predictedShares    Int
  predictedReach     Int?
  predictedEngRate   Float   // Engagement rate
  confidenceLevel    Float   // 0 to 1

  // Actual results (populated after publishing)
  actualLikes        Int?
  actualComments     Int?
  actualShares       Int?
  actualReach        Int?
  actualEngRate      Float?

  // Accuracy tracking
  accuracy           Float?  // Overall prediction accuracy

  // Metadata
  predictedAt    DateTime  @default(now())
  publishedAt    DateTime?
  resultsAt      DateTime?

  @@index([userId])
  @@index([platform])
  @@index([predictedAt])
  @@map("engagement_predictions")
}

// ==========================================
// Quote Module - Content Quotes for Social Media
// @task UNI-418 - Quote Module Integration Tests
// ==========================================

model Quote {
  id           String   @id @default(cuid())
  text         String   @db.Text
  author       String?
  source       String?  // Where the quote is from (book, speech, etc.)
  category     String   // 'inspirational', 'motivational', 'business', 'humor', etc.
  tags         String[]
  isCustom     Boolean  @default(false)  // User-generated vs system
  isPublic     Boolean  @default(true)
  language     String   @default("en")

  // Engagement tracking
  usageCount   Int      @default(0)
  likeCount    Int      @default(0)
  shareCount   Int      @default(0)

  // AI metadata
  aiGenerated  Boolean  @default(false)
  sentiment    String?  // 'positive', 'neutral', 'negative'
  readingLevel String?  // 'easy', 'medium', 'advanced'

  // Relations
  userId       String?
  campaignId   String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  expiresAt    DateTime?  // Optional expiration for time-sensitive quotes

  @@index([category])
  @@index([userId])
  @@index([tags])
  @@index([aiGenerated])
  @@map("quotes")
}

model QuoteCollection {
  id           String   @id @default(cuid())
  name         String
  description  String?
  userId       String
  isPublic     Boolean  @default(false)
  quoteIds     String[]  // Array of quote IDs in this collection

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@map("quote_collections")
}

// ==========================================
// Task Management Module
// ==========================================

model Task {
  id           String   @id @default(cuid())
  title        String
  description  String?  @db.Text
  status       String   @default("todo") // 'todo', 'in-progress', 'review', 'done'
  priority     String   @default("medium") // 'low', 'medium', 'high', 'urgent'
  dueDate      DateTime?

  // Task metadata
  tags         String[]
  category     String?  // 'marketing', 'content', 'analytics', 'campaign'
  estimatedTime Int?     // In minutes
  actualTime   Int?      // In minutes
  progress     Int      @default(0) // 0-100 percent

  // Task organization
  columnId     String?  // For Kanban board columns
  order        Int      @default(0) // Position in list

  // Relations
  userId       String
  assigneeId   String?
  campaignId   String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  completedAt  DateTime?

  // Performance indices for common queries
  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([userId, status, dueDate])
  @@index([assigneeId, priority])
  @@map("tasks")
}

// ==========================================
// AI Persona Module
// ==========================================

model Persona {
  id           String   @id @default(cuid())
  name         String
  description  String?  @db.Text
  status       String   @default("draft") // 'draft', 'training', 'active', 'archived'

  // Persona attributes
  tone         String   @default("professional") // 'professional', 'casual', 'authoritative', etc.
  style        String   @default("formal") // 'formal', 'conversational', 'thought-provoking'
  vocabulary   String   @default("standard") // 'simple', 'standard', 'technical', 'sophisticated'
  emotion      String   @default("neutral") // 'neutral', 'friendly', 'confident', 'inspiring'

  // Training data stats
  trainingSourcesCount Int @default(0)
  trainingWordsCount   Int @default(0)
  trainingSamplesCount Int @default(0)

  // Performance metrics
  accuracy     Int      @default(0) // 0-100
  lastTrained  DateTime?

  // Relations
  userId       String

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  trainingData PersonaTrainingData[]

  @@index([userId])
  @@index([status])
  @@map("personas")
}

// Persona Training Data - stores training samples and extracted insights
model PersonaTrainingData {
  id           String   @id @default(cuid())
  personaId    String
  persona      Persona  @relation(fields: [personaId], references: [id], onDelete: Cascade)

  // Source information
  sourceType   String   // 'text', 'social_post', 'document', 'website', 'conversation'
  sourceUrl    String?
  platform     String?  // 'twitter', 'linkedin', 'instagram', etc.

  // Content
  content      String   @db.Text
  contentHash  String   // For deduplication

  // Extracted characteristics (JSON)
  extractedTone       Json?    // { primary, secondary, formality, energy, warmth, humor }
  extractedVocabulary Json?    // { complexity, preferredWords, jargonLevel }
  extractedPatterns   Json?    // { hooks, closings, ctas, signatures }

  // AI Analysis results
  aiAnalysis   Json?    // Full AI-generated analysis
  sentiment    String?  // 'positive', 'neutral', 'negative'
  topics       String[] // Extracted topics

  // Embedding for semantic search (stored as JSON array for now, can migrate to pgvector later)
  embedding    Json?    // Float array for semantic similarity

  // Metadata
  engagement   Int?     // Original engagement metrics if from social post
  processedAt  DateTime?
  confidence   Float    @default(0)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([personaId, contentHash])
  @@index([personaId])
  @@index([sourceType])
  @@map("persona_training_data")
}

// ==========================================
// Subscription & Billing Module
// ==========================================

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?

  // Subscription details
  plan                 String    @default("free") // 'free', 'professional', 'business', 'custom'
  status               String    @default("inactive") // 'active', 'inactive', 'past_due', 'cancelled', 'trialing'

  // Billing period
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  cancelledAt          DateTime?

  // Trial
  trialStart           DateTime?
  trialEnd             DateTime?

  // Usage limits (based on plan)
  maxSocialAccounts    Int       @default(2)
  maxAiPosts           Int       @default(10)
  maxPersonas          Int       @default(1)

  // Usage tracking
  currentAiPosts       Int       @default(0)
  lastResetAt          DateTime  @default(now())

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([status])
  @@index([plan])
  @@map("subscriptions")
}

// ==========================================
// Role-Based Access Control (RBAC) Module
// ==========================================

model Role {
  id           String   @id @default(cuid())
  name         String
  description  String?
  permissions  String[] // Array of permission strings
  isDefault    Boolean  @default(false)
  isSystem     Boolean  @default(false) // System roles cannot be deleted
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Organization scope
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Relations
  userRoles      UserRole[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("roles")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  grantedAt DateTime @default(now())
  grantedBy String?  // ID of user who granted the role
  expiresAt DateTime?

  // Relations
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model PermissionAudit {
  id           String   @id @default(cuid())
  action       String   // 'grant', 'revoke', 'create_role', 'update_role', 'delete_role'
  targetUserId String?
  targetRoleId String?
  performedBy  String
  details      Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  // Organization scope
  organizationId String

  @@index([organizationId])
  @@index([performedBy])
  @@index([createdAt])
  @@map("permission_audits")
}

// ==========================================
// Content Sharing & Collaboration Models
// ==========================================

model ContentShare {
  id             String   @id @default(cuid())
  contentType    String   // 'campaign', 'post', 'calendar_post', 'project'
  contentId      String   // ID of the shared content

  // Sharing target (one of these should be set)
  sharedWithUserId String?  // Direct user share
  sharedWithTeamId String?  // Team/org share
  sharedWithEmail  String?  // External share via email

  // Permissions
  permission     String   @default("view") // 'view', 'comment', 'edit', 'admin'
  canDownload    Boolean  @default(true)
  canReshare     Boolean  @default(false)

  // Access control
  accessLink     String?  @unique // Shareable link token
  password       String?  // Optional password protection (hashed)
  expiresAt      DateTime?
  maxViews       Int?     // Optional view limit
  viewCount      Int      @default(0)

  // Ownership
  sharedById     String   // Who created this share
  organizationId String?

  // Metadata
  message        String?  // Optional message with share
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lastAccessedAt DateTime?

  @@index([contentType, contentId])
  @@index([sharedWithUserId])
  @@index([sharedWithTeamId])
  @@index([sharedById])
  @@index([accessLink])
  @@map("content_shares")
}

model ContentComment {
  id             String   @id @default(cuid())
  contentType    String   // 'campaign', 'post', 'calendar_post', 'project'
  contentId      String   // ID of the content being commented on

  // Comment content
  content        String   @db.Text
  parentId       String?  // For threaded comments

  // Author
  authorId       String

  // Sentiment analysis
  sentiment      String?  // 'positive', 'neutral', 'negative', 'mixed'
  sentimentScore Float?   // -100 to 100
  emotions       Json?    // Array of detected emotions

  // Status
  isResolved     Boolean  @default(false)
  resolvedAt     DateTime?
  resolvedBy     String?

  // Mentions
  mentions       String[] // Array of user IDs mentioned

  // Metadata
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Self-reference for threads
  parent         ContentComment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies        ContentComment[] @relation("CommentThread")

  @@index([contentType, contentId])
  @@index([authorId])
  @@index([parentId])
  @@map("content_comments")
}

model ContentAccessLog {
  id             String   @id @default(cuid())
  contentType    String   // 'campaign', 'post', 'calendar_post', 'project'
  contentId      String

  // Access details
  action         String   // 'view', 'edit', 'download', 'share', 'comment'
  userId         String?  // May be null for anonymous/link access
  shareId        String?  // If accessed via share link

  // Context
  ipAddress      String?
  userAgent      String?
  referrer       String?

  createdAt      DateTime @default(now())

  @@index([contentType, contentId])
  @@index([userId])
  @@index([createdAt])
  @@map("content_access_logs")
}

model TeamNotification {
  id             String   @id @default(cuid())

  // Target
  userId         String   // Recipient
  organizationId String?  // Team/org context

  // Notification content
  type           String   // 'invitation', 'role_change', 'content_shared', 'mention', 'comment', 'access_request'
  title          String
  message        String
  actionUrl      String?

  // Related entities
  relatedUserId  String?  // The user who triggered this notification
  relatedContentType String?
  relatedContentId String?

  // Status
  read           Boolean  @default(false)
  readAt         DateTime?

  // Preferences
  emailSent      Boolean  @default(false)
  emailSentAt    DateTime?

  createdAt      DateTime @default(now())
  expiresAt      DateTime?

  @@index([userId, read])
  @@index([organizationId])
  @@index([createdAt])
  @@map("team_notifications")
}

// ==========================================
// Content Calendar Module
// ==========================================

model CalendarPost {
  id             String   @id @default(cuid())
  title          String
  content        String   @db.Text
  platforms      String[] // Multi-platform support
  status         String   @default("draft") // 'draft', 'scheduled', 'published', 'failed', 'cancelled'
  scheduledFor   DateTime
  publishedAt    DateTime?

  // Media and content metadata
  mediaUrls      String[]
  tags           String[]
  hashtags       String[]
  mentions       String[]

  // Recurrence support
  recurrenceType String?  // 'none', 'daily', 'weekly', 'biweekly', 'monthly'
  recurrenceInterval Int?
  recurrenceEndDate DateTime?
  recurrenceOccurrences Int?
  recurrenceDaysOfWeek Int[] // 0-6 for Sunday-Saturday
  recurrenceDayOfMonth Int?
  parentPostId   String?  // Links to parent for recurring posts

  // Campaign and organization
  campaignId     String?
  organizationId String
  userId         String   // Created by

  // Metadata
  metadata       Json?    // Platform-specific settings
  analytics      Json?    // Engagement metrics after publish
  errorMessage   String?  // For failed posts

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Self-referential relation for recurring posts
  parentPost     CalendarPost?  @relation("RecurringPosts", fields: [parentPostId], references: [id], onDelete: SetNull)
  childPosts     CalendarPost[] @relation("RecurringPosts")

  // Performance indices
  @@index([organizationId, scheduledFor(sort: Desc)])
  @@index([userId, status])
  @@index([status, scheduledFor])
  @@index([campaignId])
  @@index([parentPostId])
  @@map("calendar_posts")
}

// ==========================================
// A/B Testing Module
// ==========================================

model ABTest {
  id             String   @id @default(cuid())
  name           String
  hypothesis     String?  @db.Text
  status         String   @default("draft") // 'draft', 'running', 'paused', 'completed'

  // Test configuration
  duration       Int      @default(7) // Duration in days
  platform       String?  // Target platform: 'instagram', 'twitter', etc.
  targetAudience String?

  // Timing
  startDate      DateTime?
  endDate        DateTime?

  // Results
  winner         String?  // 'A', 'B', or 'inconclusive'
  confidence     Float    @default(0)

  // AI-generated recommendations
  recommendations String[]

  // Ownership
  userId         String
  organizationId String?
  campaignId     String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  variants       ABTestVariant[]
  results        ABTestResult[]

  @@index([userId])
  @@index([organizationId])
  @@index([status])
  @@map("ab_tests")
}

model ABTestVariant {
  id             String   @id @default(cuid())
  testId         String
  name           String   // 'A', 'B', 'C', etc.

  // Content
  content        String   @db.Text
  image          String?
  cta            String?  // Call to action
  hashtags       String[]

  // Metrics
  impressions    Int      @default(0)
  engagement     Int      @default(0)
  clicks         Int      @default(0)
  conversions    Int      @default(0)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  test           ABTest   @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@index([testId])
  @@map("ab_test_variants")
}

model ABTestResult {
  id             String   @id @default(cuid())
  testId         String
  variantId      String

  // Metrics snapshot
  timestamp      DateTime @default(now())
  impressions    Int      @default(0)
  engagement     Int      @default(0)
  clicks         Int      @default(0)
  conversions    Int      @default(0)

  // Statistical analysis
  conversionRate Float    @default(0)
  uplift         Float?   // Percentage improvement over control
  pValue         Float?   // Statistical significance

  // Relations
  test           ABTest   @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@index([testId])
  @@index([variantId])
  @@index([timestamp])
  @@map("ab_test_results")
}

// ==========================================
// Competitor Tracking Module (P1-004)
// Automated competitor monitoring and insights
// ==========================================

model TrackedCompetitor {
  id             String    @id @default(cuid())
  userId         String

  // Basic info
  name           String
  domain         String?
  logoUrl        String?
  description    String?   @db.Text
  industry       String?

  // Social handles
  twitterHandle  String?
  instagramHandle String?
  linkedinHandle String?
  facebookHandle String?
  youtubeHandle  String?
  tiktokHandle   String?

  // Tracking settings
  isActive       Boolean   @default(true)
  trackPosts     Boolean   @default(true)
  trackMetrics   Boolean   @default(true)
  trackingFrequency String @default("daily")  // 'hourly', 'daily', 'weekly'
  alertsEnabled  Boolean   @default(true)

  // Notes
  notes          String?   @db.Text
  tags           String[]

  // Timestamps
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastTrackedAt  DateTime?

  // Relations
  snapshots      CompetitorSnapshot[]
  posts          CompetitorPost[]
  alerts         CompetitorAlert[]

  @@unique([userId, domain])
  @@index([userId])
  @@index([isActive])
  @@map("tracked_competitors")
}

model CompetitorSnapshot {
  id              String    @id @default(cuid())
  competitorId    String

  // Platform metrics
  platform        String    // 'twitter', 'instagram', etc. or 'all'

  // Follower metrics
  followersCount  Int?
  followingCount  Int?
  followerGrowth  Int?      // Change since last snapshot

  // Engagement metrics
  totalPosts      Int?
  avgLikes        Float?
  avgComments     Float?
  avgShares       Float?
  engagementRate  Float?
  postFrequency   Float?    // Posts per day

  // Content metrics
  topHashtags     String[]
  contentTypes    Json?     // Distribution of content types
  postingTimes    Json?     // Typical posting times

  // Calculated scores
  performanceScore Float?   // 0-100 overall performance
  growthScore     Float?    // 0-100 growth trajectory
  engagementScore Float?    // 0-100 engagement health

  // Metadata
  snapshotAt      DateTime  @default(now())
  dataSource      String    @default("api")  // 'api', 'scraper', 'manual'

  // Relations
  competitor      TrackedCompetitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@index([competitorId])
  @@index([competitorId, snapshotAt])
  @@index([platform])
  @@index([snapshotAt])
  @@map("competitor_snapshots")
}

model CompetitorPost {
  id              String    @id @default(cuid())
  competitorId    String

  // Post details
  platform        String
  externalId      String?   // Platform-specific post ID
  postUrl         String?
  content         String?   @db.Text
  mediaUrls       String[]
  mediaType       String?   // 'image', 'video', 'carousel', 'text'

  // Engagement metrics
  likes           Int       @default(0)
  comments        Int       @default(0)
  shares          Int       @default(0)
  views           Int?
  saves           Int?
  engagementRate  Float?

  // Content analysis
  sentiment       String?   // 'positive', 'neutral', 'negative'
  hashtags        String[]
  mentions        String[]
  topics          String[]

  // Performance
  isTopPerforming Boolean   @default(false)
  performancePercentile Float?  // Where this post ranks (0-100)

  // Timestamps
  postedAt        DateTime?
  trackedAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  competitor      TrackedCompetitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@unique([competitorId, platform, externalId])
  @@index([competitorId])
  @@index([platform])
  @@index([postedAt])
  @@index([isTopPerforming])
  @@map("competitor_posts")
}

model CompetitorAlert {
  id              String    @id @default(cuid())
  userId          String
  competitorId    String

  // Alert details
  alertType       String    // 'viral_post', 'follower_spike', 'new_campaign', 'strategy_change', 'milestone'
  severity        String    @default("info")  // 'info', 'warning', 'important'
  title           String
  description     String    @db.Text

  // Related data
  relatedPostId   String?
  metrics         Json?     // Relevant metrics that triggered alert

  // Status
  isRead          Boolean   @default(false)
  isDismissed     Boolean   @default(false)
  actionTaken     String?   @db.Text

  // Timestamps
  createdAt       DateTime  @default(now())
  readAt          DateTime?

  // Relations
  competitor      TrackedCompetitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([competitorId])
  @@index([isRead])
  @@index([createdAt])
  @@map("competitor_alerts")
}

model CompetitorComparison {
  id              String    @id @default(cuid())
  userId          String

  // Comparison config
  name            String
  competitorIds   String[]
  metrics         String[]  // Which metrics to compare

  // Cached comparison data
  comparisonData  Json?
  lastUpdated     DateTime?

  // Settings
  autoRefresh     Boolean   @default(true)
  refreshFrequency String   @default("daily")

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@map("competitor_comparisons")
}

// ==========================================
// AI Project Manager — Per-Client AI PM (Business plan)
// Conversational interface that learns each client's business
// ==========================================

model AIConversation {
  id              String    @id @default(cuid())
  userId          String
  title           String    @default("New Conversation")
  status          String    @default("active") // 'active', 'archived', 'deleted'

  // Context snapshot at conversation start (compressed user data for continuity)
  contextSnapshot Json?

  // Stats
  messageCount    Int       @default(0)
  lastMessageAt   DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages        AIMessage[]

  @@index([userId, updatedAt(sort: Desc)])
  @@index([status])
  @@map("ai_conversations")
}

model AIMessage {
  id              String    @id @default(cuid())
  conversationId  String

  // Message content
  role            String    // 'user', 'assistant', 'system'
  content         String    @db.Text

  // AI metadata
  model           String?   // AI model used (e.g. 'claude-sonnet-4-20250514')
  tokensUsed      Int?      // Total tokens (prompt + completion)
  latencyMs       Int?      // Response time in milliseconds

  // Structured data extracted from AI responses
  actionItems     Json?     // [{ title, description, priority, completed }]
  suggestions     Json?     // [{ type, title, description, actionUrl }]

  // User feedback on AI response
  rating          Int?      // 1-5 thumbs rating
  feedback        String?   // Free-text feedback

  createdAt       DateTime  @default(now())

  // Relations
  conversation    AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([role])
  @@map("ai_messages")
}

// ==========================================
// AI Weekly Digest — Proactive value delivery
// Monday morning summaries generated by AI PM
// ==========================================

model AIWeeklyDigest {
  id              String    @id @default(cuid())
  userId          String

  // Time window
  weekStart       DateTime  @db.Date
  weekEnd         DateTime  @db.Date

  // AI-generated content
  summary         String    @db.Text       // Executive summary paragraph
  highlights      Json      // [{ metric, value, change, trend }]
  actionItems     Json      // [{ title, description, priority, actionUrl }]
  opportunities   Json      // [{ title, description, potentialImpact }]

  // Delivery tracking
  emailSent       Boolean   @default(false)
  emailSentAt     DateTime?
  opened          Boolean   @default(false)
  openedAt        DateTime?

  createdAt       DateTime  @default(now())

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId, createdAt(sort: Desc)])
  @@map("ai_weekly_digests")
}

// ==========================================
// Health Scoring — Churn prediction & re-engagement
// Weighted composite score: login + content + features + engagement + growth
// ==========================================

model UserHealthScore {
  id              String    @id @default(cuid())
  userId          String    @unique

  // Composite score (0-100)
  score           Int       @default(50)
  trend           String    @default("stable") // 'improving', 'stable', 'declining', 'critical'
  riskLevel       String    @default("medium") // 'healthy', 'medium', 'high', 'critical'

  // Component scores (0-100 each)
  loginScore      Int       @default(50)   // Login frequency (25% weight)
  contentScore    Int       @default(50)   // Content creation activity (25% weight)
  featureScore    Int       @default(50)   // Feature breadth usage (20% weight)
  engagementScore Int       @default(50)   // Platform engagement (20% weight)
  growthScore     Int       @default(50)   // Growth trajectory (10% weight)

  // Raw metrics used for scoring
  daysActive      Int       @default(0)    // Days active in last 30
  featuresUsed    Int       @default(0)    // Unique features used in last 30 days
  contentCreated  Int       @default(0)    // Content pieces created in last 30 days
  lastLoginDaysAgo Int      @default(0)    // Days since last login

  // Alert tracking
  alertSent       Boolean   @default(false)
  alertSentAt     DateTime?
  lastAlertType   String?   // 'email', 'notification', 'both'

  calculatedAt    DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([score])
  @@index([riskLevel])
  @@map("user_health_scores")
}

// ==========================================
// Gamification — DB-persisted streaks & achievements
// Replaces localStorage-only StreakCounter
// ==========================================

model UserStreak {
  id              String    @id @default(cuid())
  userId          String    @unique

  // Streak data
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  totalDays       Int       @default(0)
  lastActiveDate  DateTime? @db.Date

  // Leveling (based on total activity)
  level           Int       @default(1)
  points          Int       @default(0)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_streaks")
}

model UserAchievement {
  id              String    @id @default(cuid())
  userId          String

  // Achievement identity
  achievementId   String    // Unique key from achievements catalog (e.g. 'first_post', '7_day_streak')
  name            String
  description     String
  icon            String    // Emoji or icon name
  category        String    // 'content', 'engagement', 'consistency', 'exploration', 'social'
  rarity          String    @default("common") // 'common', 'uncommon', 'rare', 'epic', 'legendary'

  // Progress tracking
  progress        Int       @default(100) // 0-100 (100 = unlocked)
  unlockedAt      DateTime?
  pointsAwarded   Int       @default(0)

  createdAt       DateTime  @default(now())

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId, category])
  @@index([unlockedAt])
  @@map("user_achievements")
}

// ==========================================
// Referral System — Viral growth loops
// Format: SYN-XXXX codes
// ==========================================

model Referral {
  id              String    @id @default(cuid())
  referrerId      String
  refereeId       String?   @unique // Set when referee signs up (one-to-one)
  refereeEmail    String    // Email invited

  // Referral code
  code            String    @unique // Format: SYN-XXXX

  // Status tracking
  status          String    @default("sent") // 'sent', 'clicked', 'signed_up', 'converted', 'expired'

  // Reward tracking
  referrerRewarded Boolean  @default(false)
  refereeRewarded  Boolean  @default(false)
  rewardType       String?  // 'credits', 'discount', 'feature_unlock'
  rewardAmount     Int?     // e.g., 500 for 500 AI credits

  // Metadata
  clickedAt       DateTime?
  signedUpAt      DateTime?
  convertedAt     DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  referrer        User      @relation("ReferrerReferrals", fields: [referrerId], references: [id], onDelete: Cascade)
  referee         User?     @relation("RefereeReferral", fields: [refereeId], references: [id], onDelete: SetNull)

  @@index([referrerId])
  @@index([refereeEmail])
  @@index([status])
  @@map("referrals")
}

// ==========================================
// Loyalty Tiers — Long-term retention & rewards
// Bronze → Silver → Gold → Platinum
// ==========================================

model UserLoyaltyTier {
  id              String    @id @default(cuid())
  userId          String    @unique

  // Tier progression
  tier            String    @default("bronze") // 'bronze', 'silver', 'gold', 'platinum'
  points          Int       @default(0)         // Current period points
  lifetimePoints  Int       @default(0)         // All-time points
  monthsActive    Int       @default(0)         // Consecutive months subscribed

  // Tier benefits
  bonusAiCredits  Int       @default(0)         // Extra AI posts per month
  discountPercent Float     @default(0)         // Subscription discount %
  prioritySupport Boolean   @default(false)

  // Tracking
  lastTierChange  DateTime?
  nextTierAt      Int?      // Points needed for next tier

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tier])
  @@map("user_loyalty_tiers")
}

// ==========================================
// Feedback & NPS Surveys — Voice of customer
// Triggered at key moments (onboarding, milestones, monthly)
// ==========================================

model FeedbackSurvey {
  id              String    @id @default(cuid())
  userId          String

  // Survey type
  type            String    // 'nps', 'csat', 'feature_request', 'churn_exit'
  triggerEvent    String?   // What triggered this survey (e.g. 'day_7', 'first_publish', 'cancel')

  // Response data
  score           Int?      // NPS: 0-10, CSAT: 1-5
  comment         String?   @db.Text
  tags            String[]  // Categorized feedback tags

  // Follow-up
  followUpSent    Boolean   @default(false)
  followUpAt      DateTime?
  resolved        Boolean   @default(false)
  resolvedAt      DateTime?

  createdAt       DateTime  @default(now())

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([score])
  @@index([createdAt])
  @@map("feedback_surveys")
}

// ==========================================
// GEO / E-E-A-T / Paper Banana Integration
// Author profiles, SEO audits, GEO analysis,
// research reports, visual assets, local case studies
// ==========================================

model AuthorProfile {
  id              Int       @id @default(autoincrement())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Identity
  name            String
  slug            String    @unique
  bio             String    @db.Text
  credentials     Json?     // [{type, title, institution, year}]
  socialLinks     Json?     // {linkedin, twitter, youtube, wikipedia, scholar}
  avatarUrl       String?

  // Entity linking (Schema.org sameAs)
  sameAsUrls      String[]
  expertiseAreas  String[]

  // Verification
  verifiedAt      DateTime?
  eeatScore       Float?    // Cached E-E-A-T score for this author

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  articles        ArticleAuthor[]
  geoAnalyses     GEOAnalysis[]

  @@index([userId])
  @@map("author_profiles")
}

model SEOAudit {
  id              Int       @id @default(autoincrement())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Audit target
  url             String
  auditType       String    // 'full', 'page', 'geo', 'eeat'

  // Scores
  overallScore    Float
  eeatScore       Json?     // {experience, expertise, authority, trust, overall}
  geoScore        Json?     // {citability, structure, multiModal, authority, technical, overall}
  technicalScore  Json?     // {performance, accessibility, seo, bestPractices}

  // Results
  recommendations Json      // [{priority, category, description, impact}]
  rawData         Json?     @db.JsonB

  createdAt       DateTime  @default(now())

  @@index([userId])
  @@index([userId, createdAt])
  @@index([auditType])
  @@map("seo_audits")
}

model GEOAnalysis {
  id              Int       @id @default(autoincrement())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Content reference
  contentId       String?   // Reference to Post or custom content
  authorId        Int?
  author          AuthorProfile? @relation(fields: [authorId], references: [id])
  contentUrl      String?
  contentText     String    @db.Text
  platform        String    // 'google_aio', 'chatgpt', 'perplexity', 'all'

  // Scores (0-100)
  overallScore    Float
  citabilityScore Float     // Passage-level citability (25% weight)
  structureScore  Float     // Heading hierarchy, lists, tables (20% weight)
  multiModalScore Float     // Images, video, interactive (15% weight)
  authorityScore  Float     // E-E-A-T + brand signals (20% weight)
  technicalScore  Float     // SSR, AI crawlers, llms.txt (20% weight)

  // Detailed findings
  citablePassages Json      // [{text, wordCount, score, startIndex}]
  recommendations Json      // [{priority, action, impact, effort}]
  schemaIssues    Json?     // Missing/invalid structured data

  createdAt       DateTime  @default(now())

  @@index([userId])
  @@index([platform])
  @@index([overallScore])
  @@map("geo_analyses")
}

model GEOResearchReport {
  id              Int       @id @default(autoincrement())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Report identity
  title           String
  slug            String    @unique
  status          String    @default("draft") // 'draft', 'review', 'published'
  sasScore        Float?    // Synthex Authority Score (0-10)

  // Content sections
  executiveSummary String?  @db.Text
  methodology     String?   @db.Text
  findings        Json?     // [{finding, statistic, source, citationUrl}]
  recommendations Json?     // [{step, description, priority}]
  fullContent     String?   @db.Text

  // Data & citations
  dataSources     Json?     // [{name, url, type, trustLevel}]
  citations       Json?     // [{text, source, url, accessedAt}]
  datasetUrl      String?   // CSV/JSON download link

  // SEO metadata
  schemaMarkup    Json?     // Full JSON-LD
  metaTitle       String?
  metaDescription String?

  // Timestamps
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  visuals         VisualAsset[]

  @@index([userId])
  @@index([status])
  @@map("geo_research_reports")
}

model VisualAsset {
  id              Int       @id @default(autoincrement())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Report link (optional)
  reportId        Int?
  report          GEOResearchReport? @relation(fields: [reportId], references: [id])

  // Paper Banana metadata
  type            String    // 'diagram', 'plot', 'infographic', 'before_after'
  prompt          String    @db.Text
  imageUrl        String
  thumbnailUrl    String?
  metadata        Json?     // Paper Banana response metadata

  // Quality
  qualityScore    Float?    // Paper Banana Critic evaluation (0-100)
  altText         String?   // SEO alt text
  caption         String?

  // Status
  status          String    @default("generated") // 'generated', 'approved', 'published'

  createdAt       DateTime  @default(now())

  @@index([userId])
  @@index([reportId])
  @@index([type])
  @@map("visual_assets")
}

model LocalCaseStudy {
  id              Int       @id @default(autoincrement())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Identity
  title           String
  slug            String    @unique

  // Location
  suburb          String
  city            String
  state           String
  postcode        String
  coordinates     Json?     // {lat, lng}

  // Content sections
  summary         String    @db.Text
  challenge       String?   @db.Text
  solution        String?   @db.Text
  results         String?   @db.Text
  testimonial     String?   @db.Text

  // Visuals
  beforeImages    String[]
  afterImages     String[]
  diagrams        String[]  // Paper Banana generated URLs

  // Schema & SEO
  schemaMarkup    Json?     // LocalBusiness + Service schema
  napData         Json?     // {name, address, phone} for consistency checking

  // Timestamps
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([city, state])
  @@map("local_case_studies")
}

model ArticleAuthor {
  id              Int       @id @default(autoincrement())
  postId          String    // References Post.id (cuid)
  authorId        Int
  author          AuthorProfile @relation(fields: [authorId], references: [id], onDelete: Cascade)
  role            String    @default("author") // 'author', 'reviewer', 'contributor'

  createdAt       DateTime  @default(now())

  @@unique([postId, authorId])
  @@index([postId])
  @@index([authorId])
  @@map("article_authors")
}

// ==========================================
// Multi-Business Owner System
// Allows custom-plan users to own and manage multiple
// organizations (businesses) from a single login.
// Each child business = $249/month additional.
// ==========================================

model BusinessOwnership {
  id               String       @id @default(cuid())
  ownerId          String       @map("owner_id")
  organizationId   String       @map("organization_id")
  displayName      String?      @map("display_name")     // Owner's custom label
  isActive         Boolean      @default(true)
  billingStatus    String       @default("active")        // 'active', 'past_due', 'cancelled'
  monthlyRate      Float        @default(249.0)           // $249/month per business
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  owner            User         @relation("OwnedBusinesses", fields: [ownerId], references: [id], onDelete: Cascade)
  organization     Organization @relation("BusinessOwners", fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([ownerId, organizationId])
  @@index([ownerId])
  @@index([organizationId])
  @@map("business_ownerships")
}
