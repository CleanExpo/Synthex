// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?  // Nullable for OAuth-only users
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Legacy Google OAuth fields (deprecated - use Account model)
  // Keep temporarily for migration
  googleId        String?  @unique @map("google_id")
  avatar          String?
  authProvider    String   @default("local") @map("auth_provider") // 'local', 'google'
  emailVerified   Boolean?   @default(false) @map("email_verified") // Boolean indicating if email is verified
  lastLogin       DateTime? @map("last_login")

  // API Keys (encrypted)
  openrouterApiKey String? @map("openrouter_api_key")
  anthropicApiKey  String? @map("anthropic_api_key")
  openaiApiKey     String? @map("openai_api_key")
  geminiApiKey     String? @map("gemini_api_key")

  // Profile fields (migrated from Supabase profiles table)
  company          String?
  jobRole          String?  @map("job_role")
  bio              String?
  phone            String?
  website          String?
  socialLinks      Json?    @map("social_links")

  // User settings (stores notification, privacy, theme preferences)
  preferences      Json?
  settings         Json?    @map("user_settings") // Migrated from Supabase user_settings table

  // Password reset fields
  resetCode        String? @map("reset_code")
  resetCodeExpires DateTime? @map("reset_code_expires")
  resetToken       String? @map("reset_token")
  resetTokenExpires DateTime? @map("reset_token_expires")

  // Email verification
  verificationCode String? @map("verification_code")
  verificationExpires DateTime? @map("verification_expires")

  // Relations
  accounts         Account[]  // Multi-provider authentication accounts
  campaigns        Campaign[]
  projects         Project[]
  apiUsage         ApiUsage[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  platformConnections PlatformConnection[]
  organizationId   String? @map("organization_id")
  organization     Organization? @relation(fields: [organizationId], references: [id])
  teamInvitations  TeamInvitation[]
  brandGenerations BrandGeneration[]
  psychologyPreferences UserPsychologyPreference?
  reports          Report[]

  // Retention system relations
  aiConversations  AIConversation[]
  aiWeeklyDigests  AIWeeklyDigest[]
  healthScore      UserHealthScore?
  streak           UserStreak?
  achievements     UserAchievement[]
  referralsMade    Referral[]        @relation("ReferrerReferrals")
  referralReceived Referral?         @relation("RefereeReferral")
  loyaltyTier      UserLoyaltyTier?
  feedbackSurveys  FeedbackSurvey[]

  // GEO / E-E-A-T / Paper Banana relations
  authorProfiles   AuthorProfile[]
  seoAudits        SEOAudit[]
  scheduledAuditTargets ScheduledAuditTarget[]
  geoAnalyses      GEOAnalysis[]
  researchReports  GEOResearchReport[]
  visualAssets     VisualAsset[]
  localCaseStudies LocalCaseStudy[]

  // Content library
  contentLibrary   ContentLibrary[]
  contentDrafts    ContentDraft[]

  // Prompt templates
  promptTemplates  PromptTemplate[]

  // Webhook subscriptions
  webhookEndpoints WebhookEndpoint[]

  // Approval workflows
  submittedApprovals ApprovalRequest[] @relation("SubmittedApprovals")

  // Multi-business owner system
  isMultiBusinessOwner  Boolean   @default(true) @map("is_multi_business_owner")
  activeOrganizationId  String?   @map("active_organization_id")
  ownedBusinesses       BusinessOwnership[] @relation("OwnedBusinesses")

  // Social listening
  trackedKeywords       TrackedKeyword[]
  socialMentions        SocialMention[]

  // Link in Bio
  linkBioPages          LinkBioPage[]

  // Revenue tracking
  revenueEntries        RevenueEntry[]

  // ROI tracking
  contentInvestments    ContentInvestment[]

  // Sponsor CRM
  sponsors              Sponsor[]

  // Affiliate links
  affiliateNetworks     AffiliateNetwork[]
  affiliateLinks        AffiliateLink[]

  // Business vetting & API credentials
  vettingResults        BusinessVettingResult[]
  apiCredentials        APICredential[]
  platformOAuthCredentials PlatformOAuthCredential[] @relation("PlatformOAuthConfiguredBy")
  onboardingProgress    OnboardingProgress[]

  // Video generation
  videoGenerations      VideoGeneration[]

  // Onboarding state (UNI-920)
  onboardingComplete      Boolean   @default(false) @map("onboarding_complete")
  onboardingStep          Int       @default(0)     @map("onboarding_step")       // 0=not started, 1=business, 2=api-key, 3=socials, 4=goals
  businessProfileComplete Boolean   @default(false) @map("business_profile_complete")
  apiKeyConfigured        Boolean   @default(false) @map("api_key_configured")
  apiKeyValid             Boolean   @default(false) @map("api_key_valid")
  apiKeyLastValidated     DateTime? @map("api_key_last_validated")
  timezone                String    @default("Australia/Brisbane")

  @@index([organizationId])
  @@index([onboardingComplete])
  @@map("users")
}

// ==========================================
// OAuth Account Model for Multi-Provider Authentication
// Supports linking multiple auth methods to a single user
// ==========================================

model Account {
  id                String   @id @default(uuid())
  userId            String   @map("userId")
  type              String   // "oauth" or "credentials"
  provider          String   // "google", "github", "email"
  providerAccountId String   @map("providerAccountId") // Google ID, GitHub ID, or email

  // OAuth tokens (encrypted at rest in production)
  // Column names use snake_case in database
  accessToken       String?  @db.Text @map("access_token")
  refreshToken      String?  @db.Text @map("refresh_token")
  expiresAt         Int?     @map("expires_at") // Unix timestamp
  tokenType         String?  @map("token_type") // "Bearer", etc.
  scope             String?  // OAuth scopes granted
  idToken           String?  @db.Text @map("id_token") // OIDC ID token
  sessionState      String?  @map("session_state") // OIDC session state

  createdAt         DateTime @default(now()) @map("createdAt")
  updatedAt         DateTime @updatedAt @map("updatedAt")

  // Relations
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Constraints
  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  description String?
  platform    String   // 'instagram', 'twitter', 'linkedin', etc.
  status      String   @default("draft") // 'draft', 'active', 'paused', 'completed'
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Campaign data
  content     Json?    // Generated content, variations, etc.
  analytics   Json?    // Performance metrics
  settings    Json?    // Platform-specific settings

  // Relations
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts       Post[]

  // Organization (multi-tenant)
  organizationId String? @map("organization_id")
  organization   Organization? @relation("OrganizationCampaigns", fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([organizationId])
  @@map("campaigns")
}

model Post {
  id         String   @id @default(cuid())
  content    String
  platform   String
  status     String   @default("draft") // 'draft', 'scheduled', 'published', 'failed'
  scheduledAt DateTime? @map("scheduled_at")
  publishedAt DateTime? @map("published_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Post data
  metadata   Json?    // Images, hashtags, mentions, etc.
  analytics  Json?    // Engagement metrics

  // Relations
  campaignId String   @map("campaign_id")
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  // Performance indices for common queries
  @@index([campaignId, createdAt(sort: Desc)])
  @@index([platform, status])
  @@index([scheduledAt])
  @@map("posts")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   // 'marketing', 'content', 'analytics'
  data        Json?    // Project configuration and data
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("projects")
}

model ApiUsage {
  id        String   @id @default(cuid())
  endpoint  String
  model     String?  // AI model used
  tokens    Int?     // Tokens consumed
  cost      Float?   // Cost in USD
  status    String   // 'success', 'error', 'rate_limited'
  createdAt DateTime @default(now()) @map("created_at")

  // Request/Response data
  requestData  Json?  @map("request_data")
  responseData Json?  @map("response_data")
  errorMessage String? @map("error_message")

  // Relations
  userId    String   @map("user_id")
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@map("api_usage")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("sessions")
}

// OAuth PKCE state storage — survives serverless cold starts
// Replaces in-memory Map that fails across Vercel workers
model OAuthPKCEState {
  id            String   @id @default(cuid())
  state         String   @unique
  codeVerifier  String   @map("code_verifier")
  provider      String   // 'google', 'github', etc.
  redirectUri   String   @map("redirect_uri")
  linkToUserId  String?  @map("link_to_user_id")
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("oauth_pkce_states")
}

model Notification {
  id          String   @id @default(cuid())
  type        String   // 'info', 'warning', 'error', 'success'
  title       String
  message     String
  read        Boolean  @default(false)
  data        Json?    // Additional notification data
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read, createdAt])
  @@map("notifications")
}

model WebhookEndpoint {
  id              String   @id @default(cuid())
  url             String
  secret          String
  description     String?
  events          Json     // Array of WebhookEventType strings stored as JSON
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  lastDeliveredAt DateTime? @map("last_delivered_at")
  failureCount    Int      @default(0) @map("failure_count")
  metadata        Json?    // Additional config (headers, timeout overrides)

  // Relations
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, active])
  @@map("webhook_endpoints")
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String   // 'user_login', 'post_publish', 'password_change', etc.
  resource    String   // 'authentication', 'user', 'post', 'api_key', etc.
  resourceId  String?  @map("resource_id") // ID of the affected resource
  entity      String?  // Backward compatibility - deprecated
  entityId    String?  @map("entity_id") // Backward compatibility - deprecated
  details     Json?    // Additional details about the action
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  severity    String   @default("medium") // 'low', 'medium', 'high', 'critical'
  category    String   @default("system") // 'auth', 'data', 'system', 'security', 'compliance', 'api'
  outcome     String   @default("success") // 'success', 'failure', 'warning'
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  userId      String?  @map("user_id")
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([category])
  @@map("audit_logs")
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  plan        String   @default("free") // 'free', 'starter', 'pro', 'enterprise'
  status      String   @default("active") // 'active', 'suspended', 'pending', 'deleted'
  settings    Json?    // Organization-wide settings
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Domain configuration (multi-tenant)
  domain       String?  @unique // Primary subdomain (e.g., acme.synthex.app)
  customDomain String?  @unique @map("custom_domain") // Custom domain (e.g., marketing.acme.com)

  // Business identity
  website        String?
  industry       String?
  abn            String?                       // Australian Business Number
  teamSize       String?   @map("team_size")

  // AI-generated metadata
  aiGeneratedData  Json?   @map("ai_generated_data")   // Full AI analysis snapshot
  socialHandles    Json?   @map("social_handles")       // { twitter: "@handle", ... }

  // Branding
  logo         String?
  primaryColor String?  @map("primary_color")
  favicon      String?

  // Billing
  stripeCustomerId String? @map("stripe_customer_id")
  billingEmail     String? @map("billing_email")
  billingStatus    String @default("active") @map("billing_status") // 'active', 'past_due', 'canceled'

  // Usage limits
  maxUsers      Int @default(5) @map("max_users")
  maxPosts      Int @default(500) @map("max_posts")
  maxCampaigns  Int @default(10) @map("max_campaigns")

  // Relations
  users             User[]
  teamInvitations   TeamInvitation[]
  roles             Role[]
  campaigns         Campaign[]       @relation("OrganizationCampaigns")
  businessOwners    BusinessOwnership[] @relation("BusinessOwners")
  promptTemplates   PromptTemplate[]

  // Approval workflows
  approvalRequests   ApprovalRequest[]
  workflowTemplates  WorkflowTemplate[]

  // Social listening
  trackedKeywords    TrackedKeyword[]

  // Platform connections (business-scoped social accounts)
  platformConnections PlatformConnection[]

  // Business vetting & API credentials
  vettingResults     BusinessVettingResult[]
  apiCredentials     APICredential[]
  onboardingProgress OnboardingProgress[]

  // Video generation
  videoGenerations   VideoGeneration[] @relation("OrganizationVideos")

  // Indices for multi-tenant queries
  @@index([slug])
  @@index([status])
  @@index([plan])
  @@map("organizations")
}

// Platform Integration Models
model PlatformConnection {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  organizationId String?  @map("organization_id") // NULL = personal, non-NULL = business-scoped
  platform       String   // 'facebook', 'instagram', 'twitter', 'linkedin', 'tiktok', 'youtube', 'pinterest', 'reddit'
  accessToken    String   @map("access_token")
  refreshToken   String?  @map("refresh_token")
  expiresAt      DateTime? @map("expires_at")
  scope          String?  // Platform-specific permissions
  profileId      String?  @map("profile_id") // Platform user/page ID
  profileName    String?  @map("profile_name") // Platform username/page name
  accountType    String   @default("personal") @map("account_type") // 'personal' | 'business_page' | 'company'
  isActive       Boolean  @default(true) @map("is_active")
  lastSync       DateTime? @map("last_sync")
  metadata       Json?    // Platform-specific data
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization?  @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  platformPosts  PlatformPost[]

  // One connection per platform per organization (or per user if no org)
  @@unique([userId, platform, organizationId], name: "unique_user_platform_org")
  @@index([organizationId, platform])
  @@map("platform_connections")
}

model PlatformPost {
  id           String   @id @default(cuid())
  connectionId String   @map("connection_id")
  platformId   String   @map("platform_id") // ID on the platform
  content      String   @db.Text
  mediaUrls    String[] @map("media_urls")
  hashtags     String[]
  mentions     String[]
  status       String   // 'draft', 'scheduled', 'published', 'failed'
  scheduledAt  DateTime? @map("scheduled_for")
  publishedAt  DateTime? @map("published_at")
  errorMessage String?  @map("error_message")
  metadata     Json?    // Platform-specific post data
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  connection   PlatformConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  metrics      PlatformMetrics[]

  @@unique([connectionId, platformId])
  @@map("platform_posts")
}

model PlatformMetrics {
  id          String   @id @default(cuid())
  postId      String   @map("post_id")
  likes       Int      @default(0)
  shares      Int      @default(0)
  comments    Int      @default(0)
  views       Int      @default(0)
  reach       Int      @default(0)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  saves       Int      @default(0)
  engagementRate Float? @map("engagement_rate")
  metadata    Json?    // Platform-specific metrics
  recordedAt  DateTime @default(now()) @map("recorded_at")

  // Relations
  post        PlatformPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  // Performance indices for analytics queries
  @@index([postId, recordedAt(sort: Desc)])
  @@index([recordedAt])
  @@map("platform_metrics")
}

//
// Team invitations (persistence for /api/teams/invite)
//
model TeamInvitation {
  id             String   @id @default(cuid())
  email          String
  role           String
  message        String?
  campaignAccess Json?    @map("campaign_access")
  status         String   @default("sent")
  sentAt         DateTime @default(now()) @map("sent_at")

  // Optional relations (who invited, and org context), kept nullable to avoid blocking usage
  userId         String?  @map("user_id")
  organizationId String?  @map("organization_id")
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([organizationId, status])
  @@map("team_invitations")
}

// ==========================================
// Strategic Marketing Models
// ==========================================

model PsychologyPrinciple {
  id                   String   @id @default(uuid())
  name                 String   @unique
  category             String
  description          String?
  brandingApplication  Json     @default("{}") @map("branding_application")
  triggerWords         String[] @map("trigger_words")
  audienceRelevance    Json     @default("{}") @map("audience_relevance")
  effectivenessScore   Decimal  @default(0.00) @db.Decimal(3, 2) @map("effectiveness_score")
  usageCount           Int      @default(0) @map("usage_count")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([effectivenessScore(sort: Desc)])
  @@map("psychology_principles")
}

model BrandGeneration {
  id                   String   @id @default(uuid())
  userId               String   @map("user_id")
  businessType         String   @map("business_type")
  targetAudience       Json     @map("target_audience")
  brandGoals           String[] @map("brand_goals")
  tonePreference       String?  @map("tone_preference")
  psychologyStrategy   Json     @map("psychology_strategy")
  brandNames           Json     @map("brand_names")
  taglines             Json
  metadataPackages     Json     @default("{}") @map("metadata_packages")
  implementationGuide  Json     @default("{}") @map("implementation_guide")
  effectivenessScore   Decimal  @default(0.00) @db.Decimal(3, 2) @map("effectiveness_score")
  status               String   @default("draft")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  psychologyMetrics    PsychologyMetric[]
  competitiveAnalyses  CompetitiveAnalysis[]

  @@index([userId])
  @@index([status])
  @@map("brand_generations")
}

model PsychologyMetric {
  id                   String   @id @default(uuid())
  generationId         String   @map("generation_id")
  principleUsed        String   @map("principle_used")
  variantType          String   @map("variant_type")
  variantContent       String   @map("variant_content")
  engagementScore      Decimal  @default(0.00) @db.Decimal(3, 2) @map("engagement_score")
  conversionRate       Decimal  @default(0.00) @db.Decimal(5, 2) @map("conversion_rate")
  recallScore          Decimal  @default(0.00) @db.Decimal(3, 2) @map("recall_score")
  clickThroughRate     Decimal  @default(0.00) @db.Decimal(5, 2) @map("click_through_rate")
  clientSatisfaction   Int?     @map("client_satisfaction")
  testDurationHours    Int      @default(24) @map("test_duration_hours")
  sampleSize           Int      @default(0) @map("sample_size")
  testedAt             DateTime @default(now()) @map("tested_at")

  generation           BrandGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)

  @@index([generationId])
  @@index([principleUsed])
  @@map("psychology_metrics")
}

model UserPsychologyPreference {
  id                   String   @id @default(uuid())
  userId               String   @unique @map("user_id")
  preferredPrinciples  String[] @map("preferred_principles")
  avoidedPrinciples    String[] @map("avoided_principles")
  industryFocus        String?  @map("industry_focus")
  targetDemographic    Json     @default("{}") @map("target_demographic")
  successMetrics       Json     @default("{}") @map("success_metrics")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_psychology_preferences")
}

model CompetitiveAnalysis {
  id                   String   @id @default(uuid())
  generationId         String   @map("generation_id")
  competitorName       String   @map("competitor_name")
  competitorTagline    String?  @map("competitor_tagline")
  identifiedPrinciples String[] @map("identified_principles")
  differentiationStrategy String? @map("differentiation_strategy")
  marketPosition       String?  @map("market_position")
  analyzedAt           DateTime @default(now()) @map("analyzed_at")

  generation           BrandGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)

  @@map("competitive_analyses")
}

model AnalyticsEvent {
  id          String   @id @default(cuid())
  type        String   // Event type
  userId      String?  @map("user_id")
  sessionId   String   @map("session_id")
  timestamp   DateTime @default(now())
  metadata    Json?
  platform    String?
  contentId   String?  @map("content_id")
  campaignId  String?  @map("campaign_id")

  @@index([userId])
  @@index([sessionId])
  @@index([timestamp])
  @@index([userId, timestamp])
  @@map("analytics_events")
}

model Report {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  organizationId String?  @map("organization_id")
  name           String
  type           String   // campaign, analytics, ab-test, psychology, comprehensive
  status         String   @default("pending") // pending, generating, completed, failed
  format         String   @default("pdf") // pdf, csv, json
  dateRange      Json?    @map("date_range") // { start, end }
  filters        Json?    // Report-specific filters
  data           Json?    // Cached report data
  fileUrl        String?  @map("file_url") // URL to generated file
  fileSize       Int?     @map("file_size") // File size in bytes
  generatedAt    DateTime? @map("generated_at")
  expiresAt      DateTime? @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([type])
  @@map("reports")
}

// ==========================================
// Scheduled Reports - Automated Report Generation
// ==========================================

model ScheduledReport {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  organizationId String?   @map("organization_id")
  name           String
  description    String?
  templateId     String?   @map("template_id") // Reference to ReportTemplate
  reportType     String    @map("report_type") // overview, engagement, content, audience, campaigns, growth, custom
  frequency      String    // daily, weekly, biweekly, monthly, quarterly
  schedule       Json      // { dayOfWeek?, dayOfMonth?, hour, minute, timezone }
  format         String    @default("pdf") // pdf, csv, json
  dateRangeType  String    @default("last_period") @map("date_range_type") // last_period, custom, rolling_7d, rolling_30d
  filters        Json?     // Platform, campaign, and other filters
  metrics        String[]  // Selected metrics to include
  recipients     String[]  // Email addresses
  webhookUrl     String?   @map("webhook_url") // Optional webhook delivery
  isActive       Boolean   @default(true) @map("is_active")
  lastRunAt      DateTime? @map("last_run_at")
  lastRunStatus  String?   @map("last_run_status") // success, failed, skipped
  lastReportId   String?   @map("last_report_id") // ID of last generated report
  nextRunAt      DateTime? @map("next_run_at")
  runCount       Int       @default(0) @map("run_count")
  failureCount   Int       @default(0) @map("failure_count")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  template       ReportTemplate? @relation(fields: [templateId], references: [id])

  @@index([userId])
  @@index([isActive, nextRunAt])
  @@index([organizationId])
  @@map("scheduled_reports")
}

// ==========================================
// Report Templates - Reusable Report Configurations
// ==========================================

model ReportTemplate {
  id             String    @id @default(cuid())
  userId         String?   @map("user_id") // null = system template
  organizationId String?   @map("organization_id")
  name           String
  description    String?
  category       String    // performance, engagement, growth, content, custom
  reportType     String    @map("report_type") // overview, engagement, content, audience, campaigns, growth, custom
  metrics        String[]  // Default metrics
  dimensions     String[]  // Grouping dimensions
  filters        Json?     // Default filters
