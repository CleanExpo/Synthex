  discountPercent Float     @default(0) @map("discount_percent")        // Subscription discount %
  prioritySupport Boolean   @default(false) @map("priority_support")

  // Tracking
  lastTierChange  DateTime? @map("last_tier_change")
  nextTierAt      Int?      @map("next_tier_at") // Points needed for next tier

