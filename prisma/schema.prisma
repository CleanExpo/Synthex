  isPublic       Boolean   @default(false) @map("is_public") // Shared with organization
  usageCount     Int       @default(0) @map("usage_count")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  scheduledReports ScheduledReport[]

  @@index([userId])
  @@index([organizationId])
  @@index([isSystem])
  @@index([category])
  @@map("report_templates")
}

// ==========================================
// Report Delivery Log - Track Report Deliveries
// ==========================================

model ReportDelivery {
  id             String    @id @default(cuid())
  reportId       String    @map("report_id")
  scheduledReportId String? @map("scheduled_report_id")
  deliveryType   String    @map("delivery_type") // email, webhook, download
  recipient      String    // Email address or webhook URL
  status         String    // pending, sent, delivered, failed, bounced
  sentAt         DateTime? @map("sent_at")
  deliveredAt    DateTime? @map("delivered_at")
  failedAt       DateTime? @map("failed_at")
