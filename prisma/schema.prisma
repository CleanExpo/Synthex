// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Google OAuth fields
  googleId        String?  @unique
  avatar          String?
  authProvider    String   @default("local") // 'local', 'google'
  emailVerified   Boolean  @default(false)
  lastLogin       DateTime?
  
  // API Keys (encrypted)
  openrouterApiKey String?
  anthropicApiKey  String?
  
  // User settings
  preferences      Json?
  
  // Password reset fields
  resetCode        String?
  resetCodeExpires DateTime?
  resetToken       String?
  resetTokenExpires DateTime?
  
  // Email verification
  verificationCode String?
  verificationExpires DateTime?
  
  // Relations
  campaigns        Campaign[]
  projects         Project[]
  apiUsage         ApiUsage[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id])
  
  @@map("users")
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  description String?
  platform    String   // 'instagram', 'twitter', 'linkedin', etc.
  status      String   @default("draft") // 'draft', 'active', 'paused', 'completed'
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Campaign data
  content     Json?    // Generated content, variations, etc.
  analytics   Json?    // Performance metrics
  settings    Json?    // Platform-specific settings
  
  // Relations
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts       Post[]
  
  @@map("campaigns")
}

model Post {
  id         String   @id @default(cuid())
  content    String
  platform   String
  status     String   @default("draft") // 'draft', 'scheduled', 'published', 'failed'
  scheduledAt DateTime?
  publishedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  // Post data
  metadata   Json?    // Images, hashtags, mentions, etc.
  analytics  Json?    // Engagement metrics
  
  // Relations
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  
  @@map("posts")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   // 'marketing', 'content', 'analytics'
  data        Json?    // Project configuration and data
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("projects")
}

model ApiUsage {
  id        String   @id @default(cuid())
  endpoint  String
  model     String?  // AI model used
  tokens    Int?     // Tokens consumed
  cost      Float?   // Cost in USD
  status    String   // 'success', 'error', 'rate_limited'
  createdAt DateTime @default(now())
  
  // Request/Response data
  requestData  Json?
  responseData Json?
  errorMessage String?
  
  // Relations
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("api_usage")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  @@map("sessions")
}

model Notification {
  id          String   @id @default(cuid())
  type        String   // 'info', 'warning', 'error', 'success'
  title       String
  message     String
  read        Boolean  @default(false)
  data        Json?    // Additional notification data
  createdAt   DateTime @default(now())
  
  // Relations
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("notifications")
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String   // 'user_login', 'post_publish', 'password_change', etc.
  resource    String   // 'authentication', 'user', 'post', 'api_key', etc.
  resourceId  String?  // ID of the affected resource
  entity      String?  // Backward compatibility - deprecated
  entityId    String?  // Backward compatibility - deprecated
  details     Json?    // Additional details about the action
  ipAddress   String?
  userAgent   String?
  severity    String   @default("medium") // 'low', 'medium', 'high', 'critical'
  category    String   @default("system") // 'auth', 'data', 'system', 'security', 'compliance', 'api'
  outcome     String   @default("success") // 'success', 'failure', 'warning'
  createdAt   DateTime @default(now())
  
  // Relations
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("audit_logs")
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  plan        String   @default("free") // 'free', 'starter', 'pro', 'enterprise'
  settings    Json?    // Organization-wide settings
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Billing
  stripeCustomerId String?
  billingEmail     String?
  billingStatus    String @default("active") // 'active', 'past_due', 'canceled'
  
  // Relations
  users       User[]
  
  @@map("organizations")
}