  @@index([scheduledReportId])
  @@index([status])
  @@map("report_deliveries")
}

// ==========================================
// Sentiment Analysis - Content & Engagement Optimization
// ==========================================

model SentimentAnalysis {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  contentType    String    @map("content_type") // 'post', 'comment', 'campaign', 'text'
  contentId      String?   @map("content_id") // Reference to content being analyzed
  text           String    @db.Text // The analyzed text

  // Sentiment scores
  sentiment      String    // 'positive', 'neutral', 'negative', 'mixed'
  score          Float     // -100 to 100
  confidence     Float     // 0 to 1

  // Detailed analysis
  emotions       Json?     // Array of { emotion, intensity }
  toneIndicators Json?     @map("tone_indicators") // Array of tone indicators
  keyPhrases     String[]  @map("key_phrases") // Key phrases extracted

  // Engagement prediction
  predictedEngagement Json? @map("predicted_engagement") // { likes, comments, shares, engagementRate }
  actualEngagement    Json? @map("actual_engagement") // Populated after post goes live
  predictionAccuracy  Float? @map("prediction_accuracy") // How accurate was the prediction

  // Platform context
  platform       String?   // twitter, instagram, linkedin, etc.

  // Metadata
  analyzedAt     DateTime  @default(now()) @map("analyzed_at")
  model          String?   // AI model used for analysis

  @@index([userId])
  @@index([contentType, contentId])
  @@index([sentiment])
  @@index([analyzedAt])
  @@map("sentiment_analyses")
}

model SentimentTrend {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  organizationId String?   @map("organization_id")
  platform       String?   // null = all platforms
  date           DateTime  @db.Date

  // Aggregated sentiment
  avgScore       Float     @map("avg_score") // Average sentiment score for the day
  positiveCount  Int       @default(0) @map("positive_count")
  neutralCount   Int       @default(0) @map("neutral_count")
  negativeCount  Int       @default(0) @map("negative_count")
  mixedCount     Int       @default(0) @map("mixed_count")
  totalAnalyzed  Int       @default(0) @map("total_analyzed")

  // Emotion distribution
  emotionCounts  Json?     @map("emotion_counts") // { joy: 10, anger: 2, sadness: 1, ... }

  // Engagement correlation
  avgEngagement  Float?    @map("avg_engagement") // Average engagement rate for content with this sentiment
  topPerforming  String?   @map("top_performing") // Sentiment type that performed best

  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@unique([userId, platform, date])
  @@index([userId, date])
  @@index([organizationId, date])
  @@map("sentiment_trends")
}

model EngagementPrediction {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  contentType    String    @map("content_type") // 'post', 'campaign'
  contentId      String?   @map("content_id")

  // Input features
  sentimentScore Float     @map("sentiment_score")
  sentiment      String
  platform       String
  contentLength  Int       @map("content_length")
  hasMedia       Boolean   @default(false) @map("has_media")
  hasHashtags    Boolean   @default(false) @map("has_hashtags")
  hasMentions    Boolean   @default(false) @map("has_mentions")
  postHour       Int?      @map("post_hour") // Hour of day (0-23)
  postDayOfWeek  Int?      @map("post_day_of_week") // Day of week (0-6)

  // Predictions
  predictedLikes     Int   @map("predicted_likes")
  predictedComments  Int   @map("predicted_comments")
  predictedShares    Int   @map("predicted_shares")
  predictedReach     Int?  @map("predicted_reach")
  predictedEngRate   Float @map("predicted_eng_rate") // Engagement rate
  confidenceLevel    Float @map("confidence_level") // 0 to 1

  // Actual results (populated after publishing)
  actualLikes        Int?  @map("actual_likes")
  actualComments     Int?  @map("actual_comments")
  actualShares       Int?  @map("actual_shares")
  actualReach        Int?  @map("actual_reach")
  actualEngRate      Float? @map("actual_eng_rate")

  // Accuracy tracking
  accuracy           Float?  // Overall prediction accuracy

  // Metadata
  predictedAt    DateTime  @default(now()) @map("predicted_at")
  publishedAt    DateTime? @map("published_at")
  resultsAt      DateTime? @map("results_at")

  @@index([userId])
  @@index([platform])
  @@index([predictedAt])
  @@map("engagement_predictions")
}

// ==========================================
// Quote Module - Content Quotes for Social Media
// @task UNI-418 - Quote Module Integration Tests
// ==========================================

model Quote {
  id           String   @id @default(cuid())
  text         String   @db.Text
