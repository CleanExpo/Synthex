  isPublic     Boolean  @default(false) @map("is_public")
  quoteIds     String[] @map("quote_ids") // Array of quote IDs in this collection

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("quote_collections")
}

// ==========================================
// Content Library Module
// Save, organize, and reuse content (posts, captions, templates)
// ==========================================

model ContentLibrary {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  title        String
  content      String   @db.Text
  contentType  String   @map("content_type") // 'post', 'caption', 'story', 'thread', 'template', 'snippet'
  platform     String?  // Target platform: 'instagram', 'twitter', 'linkedin', etc.
  category     String?  // User-defined category
  tags         String[] // Array of tags for organization
  status       String   @default("active") // 'active', 'archived', 'deleted'
  metadata     Json?    // Flexible storage for hashtags, mentions, media refs, etc.
  usageCount   Int      @default(0) @map("usage_count") // Track how often content is used
  lastUsedAt   DateTime? @map("last_used_at")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, contentType])
  @@index([userId, status])
  @@map("content_library")
}

// Content Drafts — saved-but-unpublished content from the generator (UNI-847)
model ContentDraft {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  organizationId  String?   @map("organization_id")
  platform        String                               // 'twitter', 'instagram', etc.
  content         String    @db.Text                   // Full generated text
  title           String?                              // Optional title / topic
  hashtags        String[]  @default([])               // Extracted hashtags
  hookType        String?   @map("hook_type")          // e.g. 'question', 'story'
  tone            String?                              // e.g. 'casual', 'professional'
  topic           String?                              // User's input topic
  targetLength    String?   @map("target_length")      // 'short', 'medium', 'long'
  status          String    @default("draft")          // 'draft' | 'scheduled' | 'published'
  metadata        Json?                                // Flexible: engagement score, psychology, etc.
  scheduledPostId String?   @unique @map("scheduled_post_id")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, platform])
  @@index([createdAt])
  @@map("content_drafts")
}

// ==========================================
// Prompt Templates Module
// Reusable AI prompt templates for content generation
// ==========================================

model PromptTemplate {
  id              String   @id @default(cuid())
  userId          String?  @map("user_id")  // Null for system templates
  organizationId  String?  @map("organization_id")  // For team-shared templates

  name            String
  description     String?
  icon            String?  // Emoji icon
  category        String   // 'marketing', 'engagement', 'educational', 'promotional', 'personal'
  platforms       String[] // ['twitter', 'linkedin', 'instagram', etc.]

  // Template structure (JSON matching ContentTemplate interface)
  structure       Json     // { hook, body, cta?, hashtags?, mediaType? }
  variables       String[] // Placeholder names to fill in
  tips            String[] // Usage tips

  // Visibility & sharing
  isPublic        Boolean  @default(false) @map("is_public")  // Available to all users
  isSystem        Boolean  @default(false) @map("is_system")  // Built-in template

  // Usage tracking
  usageCount      Int      @default(0) @map("usage_count")
  lastUsedAt      DateTime? @map("last_used_at")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  user            User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([organizationId])
  @@index([category])
  @@index([isPublic])
  @@index([isSystem])
  @@map("prompt_templates")
}

// ==========================================
// Task Management Module
// ==========================================

model Task {
  id           String   @id @default(cuid())
  title        String
  description  String?  @db.Text
  status       String   @default("todo") // 'todo', 'in-progress', 'review', 'done'
  priority     String   @default("medium") // 'low', 'medium', 'high', 'urgent'
  dueDate      DateTime? @map("due_date")

  // Task metadata
  tags         String[]
  category     String?  // 'marketing', 'content', 'analytics', 'campaign'
  estimatedTime Int?    @map("estimated_time") // In minutes
  actualTime   Int?     @map("actual_time") // In minutes
  progress     Int      @default(0) // 0-100 percent

  // Task organization
  columnId     String?  @map("column_id") // For Kanban board columns
  order        Int      @default(0) // Position in list

  // Relations
  userId       String   @map("user_id")
  assigneeId   String?  @map("assignee_id")
  campaignId   String?  @map("campaign_id")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  completedAt  DateTime? @map("completed_at")

  // Performance indices for common queries
  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([userId, status, dueDate])
  @@index([assigneeId, priority])
  @@map("tasks")
}

// ==========================================
// AI Persona Module
// ==========================================

model Persona {
  id           String   @id @default(cuid())
  name         String
  description  String?  @db.Text
  status       String   @default("draft") // 'draft', 'training', 'active', 'archived'

  // Persona attributes
  tone         String   @default("professional") // 'professional', 'casual', 'authoritative', etc.
  style        String   @default("formal") // 'formal', 'conversational', 'thought-provoking'
  vocabulary   String   @default("standard") // 'simple', 'standard', 'technical', 'sophisticated'
  emotion      String   @default("neutral") // 'neutral', 'friendly', 'confident', 'inspiring'

  // Training data stats
  trainingSourcesCount Int @default(0) @map("training_sources_count")
  trainingWordsCount   Int @default(0) @map("training_words_count")
  trainingSamplesCount Int @default(0) @map("training_samples_count")

  // Performance metrics
  accuracy     Int      @default(0) // 0-100
  lastTrained  DateTime? @map("last_trained")

  // Relations
  userId       String   @map("user_id")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  trainingData PersonaTrainingData[]

  @@index([userId])
  @@index([status])
  @@map("personas")
}

// Persona Training Data - stores training samples and extracted insights
model PersonaTrainingData {
  id           String   @id @default(cuid())
  personaId    String   @map("persona_id")
  persona      Persona  @relation(fields: [personaId], references: [id], onDelete: Cascade)

  // Source information
  sourceType   String   @map("source_type") // 'text', 'social_post', 'document', 'website', 'conversation'
  sourceUrl    String?  @map("source_url")
  platform     String?  // 'twitter', 'linkedin', 'instagram', etc.

  // Content
  content      String   @db.Text
  contentHash  String   @map("content_hash") // For deduplication

  // Extracted characteristics (JSON)
  extractedTone       Json?    @map("extracted_tone") // { primary, secondary, formality, energy, warmth, humor }
  extractedVocabulary Json?    @map("extracted_vocabulary") // { complexity, preferredWords, jargonLevel }
  extractedPatterns   Json?    @map("extracted_patterns") // { hooks, closings, ctas, signatures }

  // AI Analysis results
  aiAnalysis   Json?    @map("ai_analysis") // Full AI-generated analysis
  sentiment    String?  // 'positive', 'neutral', 'negative'
  topics       String[] // Extracted topics

  // Embedding for semantic search (stored as JSON array for now, can migrate to pgvector later)
  embedding    Json?    // Float array for semantic similarity

  // Metadata
  engagement   Int?     // Original engagement metrics if from social post
  processedAt  DateTime? @map("processed_at")
  confidence   Float    @default(0)

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([personaId, contentHash])
  @@index([personaId])
  @@index([sourceType])
  @@map("persona_training_data")
}

// ==========================================
// Subscription & Billing Module
// ==========================================

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique @map("user_id")
  stripeCustomerId     String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id")
  stripePriceId        String?   @map("stripe_price_id")

  // Subscription details
  plan                 String    @default("free") // 'free', 'professional', 'business', 'custom'
  status               String    @default("inactive") // 'active', 'inactive', 'past_due', 'cancelled', 'trialing'

  // Billing period
  currentPeriodStart   DateTime? @map("current_period_start")
  currentPeriodEnd     DateTime? @map("current_period_end")
  cancelAtPeriodEnd    Boolean   @default(false) @map("cancel_at_period_end")
  cancelledAt          DateTime? @map("cancelled_at")

  // Trial
  trialStart           DateTime? @map("trial_start")
  trialEnd             DateTime? @map("trial_end")

  // Usage limits (based on plan)
  maxSocialAccounts    Int       @default(2) @map("max_social_accounts")
  maxAiPosts           Int       @default(10) @map("max_ai_posts")
  maxPersonas          Int       @default(1) @map("max_personas")

  // Usage tracking
  currentAiPosts       Int       @default(0) @map("current_ai_posts")
  lastResetAt          DateTime  @default(now()) @map("last_reset_at")

  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([plan])
  @@map("subscriptions")
}

// ==========================================
// Revenue Tracking Module
// ==========================================

model RevenueEntry {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")

  // Revenue details
  source      String   // 'sponsorship', 'affiliate', 'ads', 'tips', 'merchandise', 'other'
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("USD")
  description String?

  // Optional associations
  platform    String?  // Platform that generated the revenue
  postId      String?  @map("post_id") // Link to specific content
  brandName   String?  @map("brand_name") // For sponsorships

  // Dates
  paidAt      DateTime @map("paid_at") // When payment was received
  periodStart DateTime? @map("period_start") // For recurring/period-based income
  periodEnd   DateTime? @map("period_end")

  // Metadata
  metadata    Json?    // Source-specific details
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sponsorDeal SponsorDeal?

  @@index([userId])
  @@index([userId, source])
  @@index([userId, paidAt])
  @@map("revenue_entries")
}

model ContentInvestment {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")

  // Investment details
  type        String   // 'time', 'money'
  category    String   // 'creation', 'equipment', 'software', 'promotion', 'other'
  amount      Decimal  @db.Decimal(12, 2) // hours for time, currency for money
  currency    String?  // Only for money investments
  description String?

  // Optional associations
  platform    String?  // Platform the investment relates to
  postId      String?  @map("post_id") // Link to specific content

  // Date
  investedAt  DateTime @map("invested_at") // When the investment was made

  // Metadata
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, type])
  @@index([userId, investedAt])
  @@map("content_investments")
}

// ==========================================
// Sponsor CRM Module
// ==========================================

model Sponsor {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")

  // Brand info
  name        String
  company     String?
  email       String?
  phone       String?
  website     String?
  logo        String?  // URL to logo

  // Relationship
  status      String   @default("lead") // lead, active, past
  notes       String?

  // Metadata
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  deals       SponsorDeal[]

  @@index([userId])
  @@index([userId, status])
  @@map("sponsors")
}

model SponsorDeal {
  id          String   @id @default(cuid())
  sponsorId   String   @map("sponsor_id")

  // Deal info
  title       String
  description String?
  value       Decimal  @db.Decimal(12, 2)
  currency    String   @default("USD")

  // Pipeline
  stage       String   @default("negotiation") // negotiation, contracted, in_progress, delivered, paid, cancelled

  // Dates
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  paidAt      DateTime? @map("paid_at")

  // Payment tracking
  revenueEntryId String? @unique @map("revenue_entry_id") // Link to RevenueEntry when paid

  // Metadata
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  sponsor      Sponsor          @relation(fields: [sponsorId], references: [id], onDelete: Cascade)
  deliverables DealDeliverable[]
  revenueEntry RevenueEntry?    @relation(fields: [revenueEntryId], references: [id])

  @@index([sponsorId])
  @@index([sponsorId, stage])
  @@map("sponsor_deals")
}

model DealDeliverable {
  id          String   @id @default(cuid())
  dealId      String   @map("deal_id")

  // Deliverable info
  title       String
  description String?
  type        String   // post, story, reel, video, mention, review, other
  platform    String?  // YouTube, Instagram, TikTok, etc.

  // Status
  status      String   @default("pending") // pending, in_progress, submitted, approved, rejected
  dueDate     DateTime? @map("due_date")
  completedAt DateTime? @map("completed_at")

  // Content link
  contentUrl  String?  @map("content_url") // URL to published content
  postId      String?  @map("post_id") // Link to internal Post if applicable

  // Metadata
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  deal        SponsorDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@index([dealId, status])
  @@map("deal_deliverables")
}

// ==========================================
// Role-Based Access Control (RBAC) Module
// ==========================================

model Role {
  id           String   @id @default(cuid())
  name         String
  description  String?
  permissions  String[] // Array of permission strings
  isDefault    Boolean  @default(false) @map("is_default")
  isSystem     Boolean  @default(false) @map("is_system") // System roles cannot be deleted
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Organization scope
  organizationId String @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Relations
  userRoles      UserRole[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("roles")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  grantedAt DateTime @default(now()) @map("granted_at")
  grantedBy String?  @map("granted_by") // ID of user who granted the role
  expiresAt DateTime? @map("expires_at")

  // Relations
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model PermissionAudit {
  id           String   @id @default(cuid())
  action       String   // 'grant', 'revoke', 'create_role', 'update_role', 'delete_role'
  targetUserId String?  @map("target_user_id")
  targetRoleId String?  @map("target_role_id")
  performedBy  String   @map("performed_by")
  details      Json?
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")

  // Organization scope
  organizationId String @map("organization_id")

  @@index([organizationId])
  @@index([performedBy])
  @@index([createdAt])
  @@map("permission_audits")
}

// ==========================================
// Content Sharing & Collaboration Models
// ==========================================

model ContentShare {
  id             String   @id @default(cuid())
  contentType    String   @map("content_type") // 'campaign', 'post', 'calendar_post', 'project'
  contentId      String   @map("content_id") // ID of the shared content

  // Sharing target (one of these should be set)
  sharedWithUserId String? @map("shared_with_user_id") // Direct user share
  sharedWithTeamId String? @map("shared_with_team_id") // Team/org share
  sharedWithEmail  String? @map("shared_with_email") // External share via email

  // Permissions
  permission     String   @default("view") // 'view', 'comment', 'edit', 'admin'
  canDownload    Boolean  @default(true) @map("can_download")
  canReshare     Boolean  @default(false) @map("can_reshare")

  // Access control
  accessLink     String?  @unique @map("access_link") // Shareable link token
  password       String?  // Optional password protection (hashed)
  expiresAt      DateTime? @map("expires_at")
  maxViews       Int?     @map("max_views") // Optional view limit
  viewCount      Int      @default(0) @map("view_count")

  // Ownership
  sharedById     String   @map("shared_by_id") // Who created this share
  organizationId String?  @map("organization_id")

  // Metadata
  message        String?  // Optional message with share
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  lastAccessedAt DateTime? @map("last_accessed_at")

  @@index([contentType, contentId])
  @@index([sharedWithUserId])
  @@index([sharedWithTeamId])
  @@index([sharedById])
  @@index([accessLink])
  @@map("content_shares")
}

model ContentComment {
  id             String   @id @default(cuid())
  contentType    String   @map("content_type") // 'campaign', 'post', 'calendar_post', 'project'
  contentId      String   @map("content_id") // ID of the content being commented on

  // Comment content
  content        String   @db.Text
  parentId       String?  @map("parent_id") // For threaded comments

  // Author
  authorId       String   @map("author_id")

  // Sentiment analysis
  sentiment      String?  // 'positive', 'neutral', 'negative', 'mixed'
  sentimentScore Float?   @map("sentiment_score") // -100 to 100
  emotions       Json?    // Array of detected emotions

  // Status
  isResolved     Boolean  @default(false) @map("is_resolved")
  resolvedAt     DateTime? @map("resolved_at")
  resolvedBy     String?  @map("resolved_by")

  // Mentions
  mentions       String[] // Array of user IDs mentioned

  // Metadata
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Self-reference for threads
  parent         ContentComment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies        ContentComment[] @relation("CommentThread")

  @@index([contentType, contentId])
  @@index([authorId])
  @@index([parentId])
  @@map("content_comments")
}

model ContentAccessLog {
  id             String   @id @default(cuid())
  contentType    String   @map("content_type") // 'campaign', 'post', 'calendar_post', 'project'
  contentId      String   @map("content_id")

  // Access details
  action         String   // 'view', 'edit', 'download', 'share', 'comment'
  userId         String?  @map("user_id") // May be null for anonymous/link access
  shareId        String?  @map("share_id") // If accessed via share link

  // Context
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  referrer       String?

  createdAt      DateTime @default(now()) @map("created_at")

  @@index([contentType, contentId])
  @@index([userId])
  @@index([createdAt])
  @@map("content_access_logs")
}

model TeamNotification {
  id             String   @id @default(cuid())

  // Target
  userId         String   @map("user_id") // Recipient
  organizationId String?  @map("organization_id") // Team/org context

  // Notification content
  type           String   // 'invitation', 'role_change', 'content_shared', 'mention', 'comment', 'access_request'
  title          String
  message        String
  actionUrl      String?  @map("action_url")

  // Related entities
  relatedUserId  String?  @map("related_user_id") // The user who triggered this notification
  relatedContentType String? @map("related_content_type")
  relatedContentId String? @map("related_content_id")

  // Status
  read           Boolean  @default(false)
  readAt         DateTime? @map("read_at")

  // Preferences
  emailSent      Boolean  @default(false) @map("email_sent")
  emailSentAt    DateTime? @map("email_sent_at")

  createdAt      DateTime @default(now()) @map("created_at")
  expiresAt      DateTime? @map("expires_at")

  @@index([userId, read])
  @@index([organizationId])
  @@index([createdAt])
  @@map("team_notifications")
}

// ==========================================
// Approval Workflow Module
// ==========================================

model ApprovalRequest {
  id            String   @id @default(cuid())

  // Content reference
  contentId     String   @map("content_id") // ID of Post, Campaign, etc.
  contentType   String   @map("content_type") // 'post', 'campaign', 'media', 'template'

  // Workflow
  workflowId    String?  @map("workflow_id") // Optional WorkflowTemplate reference

  // Submitter
  submittedBy   String   @map("submitted_by") // User ID who submitted
  submitter     User     @relation("SubmittedApprovals", fields: [submittedBy], references: [id], onDelete: Cascade)

  // Status
  status        String   @default("pending") // 'pending', 'in_review', 'approved', 'rejected', 'revision_requested'
  priority      String   @default("normal")  // 'low', 'normal', 'high', 'urgent'

  // Progress
  currentStep   Int      @default(0) @map("current_step")
  totalSteps    Int      @default(1) @map("total_steps")

  // Steps stored as JSON array (matches existing service structure)
  steps         Json     @default("[]")

  // Metadata
  title         String
  description   String?
  dueDate       DateTime? @map("due_date")
  metadata      Json?    // platforms, scheduledTime, tags, etc.

  // Organization scope
  organizationId String? @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  // Timestamps
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([submittedBy])
  @@index([organizationId])
  @@index([status])
  @@index([contentId])
  @@map("approval_requests")
}

model WorkflowTemplate {
  id             String   @id @default(cuid())

  // Organization scope
  organizationId String   @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Template info
  name           String
  description    String?

  // Steps stored as JSON array
  steps          Json     @default("[]")

  // Configuration
  isDefault      Boolean  @default(false) @map("is_default")
  contentTypes   Json     @default("[\"post\"]") @map("content_types") // Array of content types this applies to

  // Timestamps
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([isDefault])
  @@map("workflow_templates")
}

// ==========================================
// Content Calendar Module
// ==========================================

model CalendarPost {
  id             String   @id @default(cuid())
  title          String
  content        String   @db.Text
  platforms      String[] // Multi-platform support
  status         String   @default("draft") // 'draft', 'scheduled', 'published', 'failed', 'cancelled'
  scheduledFor   DateTime @map("scheduled_for")
  publishedAt    DateTime? @map("published_at")

  // Media and content metadata
  mediaUrls      String[] @map("media_urls")
  tags           String[]
  hashtags       String[]
  mentions       String[]

  // Recurrence support
  recurrenceType String?  @map("recurrence_type") // 'none', 'daily', 'weekly', 'biweekly', 'monthly'
  recurrenceInterval Int? @map("recurrence_interval")
  recurrenceEndDate DateTime? @map("recurrence_end_date")
  recurrenceOccurrences Int? @map("recurrence_occurrences")
  recurrenceDaysOfWeek Int[] @map("recurrence_days_of_week") // 0-6 for Sunday-Saturday
  recurrenceDayOfMonth Int? @map("recurrence_day_of_month")
  parentPostId   String?  @map("parent_post_id") // Links to parent for recurring posts

  // Campaign and organization
  campaignId     String?  @map("campaign_id")
  organizationId String   @map("organization_id")
  userId         String   @map("user_id") // Created by

  // Metadata
  metadata       Json?    // Platform-specific settings
  analytics      Json?    // Engagement metrics after publish
  errorMessage   String?  @map("error_message") // For failed posts

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Self-referential relation for recurring posts
  parentPost     CalendarPost?  @relation("RecurringPosts", fields: [parentPostId], references: [id], onDelete: SetNull)
  childPosts     CalendarPost[] @relation("RecurringPosts")

  // Performance indices
  @@index([organizationId, scheduledFor(sort: Desc)])
  @@index([userId, status])
  @@index([status, scheduledFor])
  @@index([campaignId])
  @@index([parentPostId])
  @@map("calendar_posts")
}

// ==========================================
// A/B Testing Module
// ==========================================

model ABTest {
  id             String   @id @default(cuid())
  name           String
  hypothesis     String?  @db.Text
  status         String   @default("draft") // 'draft', 'running', 'paused', 'completed'

  // Test configuration
  duration       Int      @default(7) // Duration in days
  platform       String?  // Target platform: 'instagram', 'twitter', etc.
  targetAudience String?  @map("target_audience")

  // Timing
  startDate      DateTime? @map("start_date")
  endDate        DateTime? @map("end_date")

  // Results
  winner         String?  // 'A', 'B', or 'inconclusive'
  confidence     Float    @default(0)

  // AI-generated recommendations
  recommendations String[]

  // Ownership
  userId         String   @map("user_id")
  organizationId String?  @map("organization_id")
  campaignId     String?  @map("campaign_id")

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  variants       ABTestVariant[]
  results        ABTestResult[]

  @@index([userId])
  @@index([organizationId])
  @@index([status])
  @@map("ab_tests")
}

model ABTestVariant {
  id             String   @id @default(cuid())
  testId         String   @map("test_id")
  name           String   // 'A', 'B', 'C', etc.

  // Content
  content        String   @db.Text
  image          String?
  cta            String?  // Call to action
  hashtags       String[]

  // Metrics
  impressions    Int      @default(0)
  engagement     Int      @default(0)
  clicks         Int      @default(0)
  conversions    Int      @default(0)

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  test           ABTest   @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@index([testId])
  @@map("ab_test_variants")
}

model ABTestResult {
  id             String   @id @default(cuid())
  testId         String   @map("test_id")
  variantId      String   @map("variant_id")

  // Metrics snapshot
  timestamp      DateTime @default(now())
  impressions    Int      @default(0)
  engagement     Int      @default(0)
  clicks         Int      @default(0)
  conversions    Int      @default(0)

  // Statistical analysis
  conversionRate Float    @default(0) @map("conversion_rate")
  uplift         Float?   // Percentage improvement over control
  pValue         Float?   @map("p_value") // Statistical significance

  // Relations
  test           ABTest   @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@index([testId])
  @@index([variantId])
  @@index([timestamp])
  @@map("ab_test_results")
}

// ==========================================
// Competitor Tracking Module (P1-004)
// Automated competitor monitoring and insights
// ==========================================

model TrackedCompetitor {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")

  // Basic info
  name           String
  domain         String?
  logoUrl        String?   @map("logo_url")
  description    String?   @db.Text
  industry       String?

  // Social handles
  twitterHandle  String?   @map("twitter_handle")
  instagramHandle String?  @map("instagram_handle")
  linkedinHandle String?   @map("linkedin_handle")
  facebookHandle String?   @map("facebook_handle")
  youtubeHandle  String?   @map("youtube_handle")
  tiktokHandle   String?   @map("tiktok_handle")

  // Tracking settings
  isActive       Boolean   @default(true) @map("is_active")
  trackPosts     Boolean   @default(true) @map("track_posts")
  trackMetrics   Boolean   @default(true) @map("track_metrics")
  trackingFrequency String @default("daily") @map("tracking_frequency") // 'hourly', 'daily', 'weekly'
  alertsEnabled  Boolean   @default(true) @map("alerts_enabled")

  // Notes
  notes          String?   @db.Text
  tags           String[]

  // Timestamps
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  lastTrackedAt  DateTime? @map("last_tracked_at")

  // Relations
  snapshots      CompetitorSnapshot[]
  posts          CompetitorPost[]
  alerts         CompetitorAlert[]

  @@unique([userId, domain])
  @@index([userId])
  @@index([isActive])
  @@map("tracked_competitors")
}

model CompetitorSnapshot {
  id              String    @id @default(cuid())
  competitorId    String    @map("competitor_id")

  // Platform metrics
  platform        String    // 'twitter', 'instagram', etc. or 'all'

  // Follower metrics
  followersCount  Int?      @map("followers_count")
  followingCount  Int?      @map("following_count")
  followerGrowth  Int?      @map("follower_growth") // Change since last snapshot

  // Engagement metrics
  totalPosts      Int?      @map("total_posts")
  avgLikes        Float?    @map("avg_likes")
  avgComments     Float?    @map("avg_comments")
  avgShares       Float?    @map("avg_shares")
  engagementRate  Float?    @map("engagement_rate")
  postFrequency   Float?    @map("post_frequency") // Posts per day

  // Content metrics
  topHashtags     String[]  @map("top_hashtags")
  contentTypes    Json?     @map("content_types") // Distribution of content types
  postingTimes    Json?     @map("posting_times") // Typical posting times

  // Calculated scores
  performanceScore Float?   @map("performance_score") // 0-100 overall performance
  growthScore     Float?    @map("growth_score") // 0-100 growth trajectory
  engagementScore Float?    @map("engagement_score") // 0-100 engagement health

  // Metadata
  snapshotAt      DateTime  @default(now()) @map("snapshot_at")
  dataSource      String    @default("api") @map("data_source") // 'api', 'scraper', 'manual'

  // Relations
  competitor      TrackedCompetitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@index([competitorId])
  @@index([competitorId, snapshotAt])
  @@index([platform])
  @@index([snapshotAt])
  @@map("competitor_snapshots")
}

model CompetitorPost {
  id              String    @id @default(cuid())
  competitorId    String    @map("competitor_id")

  // Post details
  platform        String
  externalId      String?   @map("external_id") // Platform-specific post ID
  postUrl         String?   @map("post_url")
  content         String?   @db.Text
  mediaUrls       String[]  @map("media_urls")
  mediaType       String?   @map("media_type") // 'image', 'video', 'carousel', 'text'

  // Engagement metrics
  likes           Int       @default(0)
  comments        Int       @default(0)
  shares          Int       @default(0)
  views           Int?
  saves           Int?
  engagementRate  Float?    @map("engagement_rate")

  // Content analysis
  sentiment       String?   // 'positive', 'neutral', 'negative'
  hashtags        String[]
  mentions        String[]
  topics          String[]

  // Performance
  isTopPerforming Boolean   @default(false) @map("is_top_performing")
  performancePercentile Float? @map("performance_percentile") // Where this post ranks (0-100)

  // Timestamps
  postedAt        DateTime? @map("posted_at")
  trackedAt       DateTime  @default(now()) @map("tracked_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  competitor      TrackedCompetitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@unique([competitorId, platform, externalId])
  @@index([competitorId])
  @@index([platform])
  @@index([postedAt])
  @@index([isTopPerforming])
  @@map("competitor_posts")
}

model CompetitorAlert {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  competitorId    String    @map("competitor_id")

  // Alert details
  alertType       String    @map("alert_type") // 'viral_post', 'follower_spike', 'new_campaign', 'strategy_change', 'milestone'
  severity        String    @default("info")  // 'info', 'warning', 'important'
  title           String
  description     String    @db.Text

  // Related data
  relatedPostId   String?   @map("related_post_id")
  metrics         Json?     // Relevant metrics that triggered alert

  // Status
  isRead          Boolean   @default(false) @map("is_read")
  isDismissed     Boolean   @default(false) @map("is_dismissed")
  actionTaken     String?   @db.Text @map("action_taken")

  // Timestamps
  createdAt       DateTime  @default(now()) @map("created_at")
  readAt          DateTime? @map("read_at")

  // Relations
  competitor      TrackedCompetitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([competitorId])
  @@index([isRead])
  @@index([createdAt])
  @@map("competitor_alerts")
}

model CompetitorComparison {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")

  // Comparison config
  name            String
  competitorIds   String[]  @map("competitor_ids")
  metrics         String[]  // Which metrics to compare

  // Cached comparison data
  comparisonData  Json?     @map("comparison_data")
  lastUpdated     DateTime? @map("last_updated")

  // Settings
  autoRefresh     Boolean   @default(true) @map("auto_refresh")
  refreshFrequency String   @default("daily") @map("refresh_frequency")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@map("competitor_comparisons")
}

// ==========================================
// AI Project Manager — Per-Client AI PM (Business plan)
// Conversational interface that learns each client's business
// ==========================================

model AIConversation {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  title           String    @default("New Conversation")
  status          String    @default("active") // 'active', 'archived', 'deleted'

  // Context snapshot at conversation start (compressed user data for continuity)
  contextSnapshot Json?     @map("context_snapshot")

  // Stats
  messageCount    Int       @default(0) @map("message_count")
  lastMessageAt   DateTime? @map("last_message_at")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages        AIMessage[]

  @@index([userId, updatedAt(sort: Desc)])
  @@index([status])
  @@map("ai_conversations")
}

model AIMessage {
  id              String    @id @default(cuid())
  conversationId  String    @map("conversation_id")

  // Message content
  role            String    // 'user', 'assistant', 'system'
  content         String    @db.Text

  // AI metadata
  model           String?   // AI model used (e.g. 'claude-sonnet-4-20250514')
  tokensUsed      Int?      @map("tokens_used") // Total tokens (prompt + completion)
  latencyMs       Int?      @map("latency_ms") // Response time in milliseconds

  // Structured data extracted from AI responses
  actionItems     Json?     @map("action_items") // [{ title, description, priority, completed }]
  suggestions     Json?     // [{ type, title, description, actionUrl }]

  // User feedback on AI response
  rating          Int?      // 1-5 thumbs rating
  feedback        String?   // Free-text feedback

  createdAt       DateTime  @default(now()) @map("created_at")

  // Relations
  conversation    AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([role])
  @@map("ai_messages")
}

// ==========================================
// AI Weekly Digest — Proactive value delivery
// Monday morning summaries generated by AI PM
// ==========================================

model AIWeeklyDigest {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")

  // Time window
  weekStart       DateTime  @db.Date @map("week_start")
  weekEnd         DateTime  @db.Date @map("week_end")

  // AI-generated content
  summary         String    @db.Text       // Executive summary paragraph
  highlights      Json      // [{ metric, value, change, trend }]
  actionItems     Json      @map("action_items") // [{ title, description, priority, actionUrl }]
  opportunities   Json      // [{ title, description, potentialImpact }]

  // Delivery tracking
  emailSent       Boolean   @default(false) @map("email_sent")
  emailSentAt     DateTime? @map("email_sent_at")
  opened          Boolean   @default(false)
  openedAt        DateTime? @map("opened_at")

  createdAt       DateTime  @default(now()) @map("created_at")

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId, createdAt(sort: Desc)])
  @@map("ai_weekly_digests")
}

// ==========================================
// Health Scoring — Churn prediction & re-engagement
// Weighted composite score: login + content + features + engagement + growth
// ==========================================

model UserHealthScore {
  id              String    @id @default(cuid())
  userId          String    @unique @map("user_id")

  // Composite score (0-100)
  score           Int       @default(50)
  trend           String    @default("stable") // 'improving', 'stable', 'declining', 'critical'
  riskLevel       String    @default("medium") @map("risk_level") // 'healthy', 'medium', 'high', 'critical'

  // Component scores (0-100 each)
  loginScore      Int       @default(50) @map("login_score")   // Login frequency (25% weight)
  contentScore    Int       @default(50) @map("content_score")   // Content creation activity (25% weight)
  featureScore    Int       @default(50) @map("feature_score")   // Feature breadth usage (20% weight)
  engagementScore Int       @default(50) @map("engagement_score")   // Platform engagement (20% weight)
  growthScore     Int       @default(50) @map("growth_score")   // Growth trajectory (10% weight)

  // Raw metrics used for scoring
  daysActive      Int       @default(0) @map("days_active")    // Days active in last 30
  featuresUsed    Int       @default(0) @map("features_used")    // Unique features used in last 30 days
  contentCreated  Int       @default(0) @map("content_created")    // Content pieces created in last 30 days
  lastLoginDaysAgo Int      @default(0) @map("last_login_days_ago")    // Days since last login

  // Alert tracking
  alertSent       Boolean   @default(false) @map("alert_sent")
  alertSentAt     DateTime? @map("alert_sent_at")
  lastAlertType   String?   @map("last_alert_type") // 'email', 'notification', 'both'

  calculatedAt    DateTime  @default(now()) @map("calculated_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([score])
  @@index([riskLevel])
  @@map("user_health_scores")
}

// ==========================================
// Gamification — DB-persisted streaks & achievements
// Replaces localStorage-only StreakCounter
// ==========================================

model UserStreak {
  id              String    @id @default(cuid())
  userId          String    @unique @map("user_id")

  // Streak data
  currentStreak   Int       @default(0) @map("current_streak")
  longestStreak   Int       @default(0) @map("longest_streak")
  totalDays       Int       @default(0) @map("total_days")
  lastActiveDate  DateTime? @db.Date @map("last_active_date")

  // Leveling (based on total activity)
  level           Int       @default(1)
  points          Int       @default(0)

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_streaks")
}

model UserAchievement {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")

  // Achievement identity
  achievementId   String    @map("achievement_id") // Unique key from achievements catalog (e.g. 'first_post', '7_day_streak')
  name            String
  description     String
  icon            String    // Emoji or icon name
  category        String    // 'content', 'engagement', 'consistency', 'exploration', 'social'
  rarity          String    @default("common") // 'common', 'uncommon', 'rare', 'epic', 'legendary'

  // Progress tracking
  progress        Int       @default(100) // 0-100 (100 = unlocked)
