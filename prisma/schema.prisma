  userId          String    @map("user_id")
  networkId       String?   @map("network_id")

  // Link details
  name            String              // Display name
  originalUrl     String    @map("original_url")  // Original product/page URL
  affiliateUrl    String    @map("affiliate_url") // URL with tracking params
  shortCode       String?   @unique @map("short_code") // For link cloaking

