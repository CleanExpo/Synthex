  organizationId   String       @map("organization_id")
  displayName      String?      @map("display_name")     // Owner's custom label
  isActive         Boolean      @default(true) @map("is_active")
  billingStatus    String       @default("active") @map("billing_status")       // 'active', 'past_due', 'cancelled'
  monthlyRate      Float        @default(249.0) @map("monthly_rate")          // $249/month per business
  createdAt        DateTime     @default(now()) @map("created_at")
