  imageUrl        String    @map("image_url")
  thumbnailUrl    String?   @map("thumbnail_url")
  metadata        Json?     // Paper Banana response metadata

  // Quality
  qualityScore    Float?    @map("quality_score") // Paper Banana Critic evaluation (0-100)
  altText         String?   @map("alt_text") // SEO alt text
  caption         String?

  // Status
  status          String    @default("generated") // 'generated', 'approved', 'published'

  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([reportId])
  @@index([type])
  @@map("visual_assets")
}

model LocalCaseStudy {
  id              Int       @id @default(autoincrement())
