  "validationRules": {
    "brandName": {
      "minLength": 2,
      "maxLength": 30,
      "allowNumbers": false,
      "allowSpecialChars": false,
      "requireUniqueness": true
    },
    "tagline": {
      "minWords": 3,
      "maxWords": 7,
      "requireActionableLanguage": true,
      "requireEmotionalTrigger": true
    },
    "metadata": {
      "requireKeywords": true,
      "minKeywords": 5,
      "maxKeywords": 15,
      "requireHashtags": true,
      "platformSpecific": true
    }
  },
