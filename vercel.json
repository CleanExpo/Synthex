{
  "version": 2,
  "buildCommand": "npm install && npm run build:prod",
  "outputDirectory": "public",
  "framework": null,
  "functions": {
    "api/vercel.js": {
      "maxDuration": 10,
      "includeFiles": "dist/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/vercel.js"
    },
    {
      "source": "/auth/:path*",
      "destination": "/api/vercel.js"
    }
  ]
}