{
  "version": 2,
  "buildCommand": "echo 'Skipping build - using static files'",
  "outputDirectory": "public",
  "framework": null,
  "functions": {
    "api/main.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/main.js"
    }
  ]
}