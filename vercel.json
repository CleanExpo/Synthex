{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "app/api/cron/analyze-patterns/route.ts": {
      "maxDuration": 60
    },
    "app/api/content/generate/route.ts": {
      "maxDuration": 30
    },
    "app/api/patterns/analyze/route.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/analyze-patterns",
      "schedule": "0 */6 * * *"
    }
  ]
}