# =============================================================================
# Synthex Kubernetes Secrets — TEMPLATE (DO NOT COMMIT WITH REAL VALUES)
# =============================================================================
#
# SETUP:
#   1. Copy this file: cp k8s/manifests/secrets.yaml.example k8s/manifests/secrets.yaml
#   2. Fill in real base64-encoded values (see below for encoding)
#   3. Apply: kubectl apply -f k8s/manifests/secrets.yaml
#
# ENCODE VALUES:
#   echo -n "your-value" | base64
#
# IMPORTANT: secrets.yaml is in .gitignore — never commit real secrets
# =============================================================================
apiVersion: v1
kind: Secret
metadata:
  name: synthex-secrets
  namespace: synthex
type: Opaque
data:
  # DATABASE_URL: echo -n "postgresql://user:pass@host:6543/db?pgbouncer=true" | base64
  DATABASE_URL: cG9zdGdyZXNxbDovL3BsYWNlaG9sZGVy

  # DIRECT_URL: echo -n "postgresql://user:pass@host:5432/db" | base64
  DIRECT_URL: cG9zdGdyZXNxbDovL3BsYWNlaG9sZGVy

  # JWT_SECRET: echo -n "your-32-char-minimum-jwt-secret" | base64
  JWT_SECRET: eW91ci0zMi1jaGFyLW1pbmltdW0tandrLXNlY3JldA==

  # NEXTAUTH_SECRET: echo -n "your-nextauth-secret" | base64
  NEXTAUTH_SECRET: eW91ci1uZXh0YXV0aC1zZWNyZXQ=

  # NEXT_PUBLIC_SUPABASE_ANON_KEY: echo -n "eyJhbGci..." | base64
  NEXT_PUBLIC_SUPABASE_ANON_KEY: cGxhY2Vob2xkZXI=

  # SUPABASE_SERVICE_ROLE_KEY: echo -n "eyJhbGci..." | base64
  SUPABASE_SERVICE_ROLE_KEY: cGxhY2Vob2xkZXI=

  # STRIPE_SECRET_KEY: echo -n "sk_test_..." | base64
  STRIPE_SECRET_KEY: cGxhY2Vob2xkZXI=

  # STRIPE_WEBHOOK_SECRET: echo -n "whsec_..." | base64
  STRIPE_WEBHOOK_SECRET: cGxhY2Vob2xkZXI=

  # NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY: echo -n "pk_test_..." | base64
  NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY: cGxhY2Vob2xkZXI=

  # STRIPE_PROFESSIONAL_PRICE_ID: echo -n "price_..." | base64
  STRIPE_PROFESSIONAL_PRICE_ID: cGxhY2Vob2xkZXI=

  # STRIPE_BUSINESS_PRICE_ID: echo -n "price_..." | base64
  STRIPE_BUSINESS_PRICE_ID: cGxhY2Vob2xkZXI=

  # OPENAI_API_KEY or OPENROUTER_API_KEY: echo -n "sk-..." | base64
  OPENROUTER_API_KEY: cGxhY2Vob2xkZXI=

  # RESEND_API_KEY: echo -n "re_..." | base64
  RESEND_API_KEY: cGxhY2Vob2xkZXI=
