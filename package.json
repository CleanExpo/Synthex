    "@types/nodemailer": "^6.4.17",
    "agenda": "^5.0.0",
    "axios": "^1.6.2",
    "bcryptjs": "^3.0.2",
    "body-parser": "^1.20.2",
    "bull": "^4.12.0",
    "cache-manager": "^5.4.0",
    "cache-manager-redis-store": "^3.0.1",
    "chalk": "^4.1.2",
    "cloudinary": "^2.0.0",
    "compression": "^1.7.4",
    "connect-redis": "^7.1.0",
    "cors": "^2.8.5",
    "cron": "^3.1.6",
    "crypto-js": "^4.2.0",
    "csv-writer": "^1.6.0",
    "dayjs": "^1.11.10",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.0.1",
    "express-session": "^1.18.2",
    "express-validator": "^7.2.1",
    "firebase-admin": "^12.0.0",
    "graphql": "^16.8.0",
    "helmet": "^8.0.0",
    "i18next": "^23.8.0",
    "ioredis": "^5.4.1",
    "jimp": "^0.22.0",
    "jsonwebtoken": "^9.0.2",
    "luxon": "^3.4.0",
    "mailgun.js": "^10.0.0",
    "moment-timezone": "^0.5.45",
    "multer": "^1.4.5-lts.1",
    "natural": "^8.1.0",
    "node-cron": "^3.0.3",
    "node-schedule": "^2.1.1",
    "nodemailer": "^7.0.5",
    "openai": "^4.104.0",
    "ora": "^5.4.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "passport-oauth2": "^1.8.0",
    "pdfkit": "^0.14.0",
    "pg": "^8.11.0",
    "prisma": "^6.13.0",
    "prom-client": "^15.1.0",
    "puppeteer": "^24.15.0",
    "pusher": "^5.2.0",
    "rate-limiter-flexible": "^5.0.0",
    "redis": "^4.6.0",
    "sharp": "^0.33.0",
    "simple-statistics": "^7.8.0",
    "socket.io": "^4.6.1",
    "socket.io-client": "^4.6.1",
    "stripe": "^14.14.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^4.20.0",
    "twitter-api-v2": "^1.15.2",
    "uuid": "^9.0.1",
