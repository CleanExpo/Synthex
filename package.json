{
  "name": "auto-marketing-platform",
  "version": "1.0.0",
  "description": "Unified Platform Automation System for Multi-Platform Marketing",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "dev": "set DATABASE_URL=file:./prisma/dev.db&& ts-node src/index.ts",
    "dev:watch": "set DATABASE_URL=file:./prisma/dev.db&& nodemon --exec ts-node src/index.ts",
    "build": "node build.js",
    "build:prod": "node build.js",
    "build:watch": "tsc --watch",
    "clean": "npx rimraf dist",
    "prebuild": "npm run clean",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --testPathPattern=testing --runInBand",
    "test:unit": "jest --testPathPattern=spec --testPathIgnorePatterns=testing",
    "test:api": "jest src/testing/api-tests.ts --runInBand",
    "test:ci": "jest --ci --coverage --watchAll=false --runInBand",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "vercel-build": "prisma generate && npm run build:prod",
    "postinstall": "prisma generate",
    "deploy:dev": "npm run build && echo 'Deploying to development...'",
    "deploy:staging": "npm run test && npm run build && echo 'Deploying to staging...'",
    "deploy:prod": "npm run test && npm run lint && npm run build:prod && echo 'Deploying to production...'",
    "rollback": "echo 'Rolling back deployment...'",
    "setup:production": "tsx scripts/setup-production-env.ts",
    "env:validate": "tsx src/agents/env-management/validate-production.ts",
    "env:scan": "tsx src/agents/env-management/security-scan.ts",
    "env:check": "npm run env:validate && npm run env:scan",
    "mcp:init": "npx @modelcontextprotocol/inspector",
    "ttd:test": "npm run test -- --testNamePattern",
    "install-deps": "npm install",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "ts-node src/migrations/run-migration.ts",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "ts-node src/migrations/seed-database.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "db:migrations:run": "node database/run-migrations.js up",
    "db:migrations:rollback": "node database/run-migrations.js down",
    "db:migrations:status": "node database/run-migrations.js status",
    "verify-env": "node verify-env.js",
    "pre-deploy": "ts-node scripts/pre-deploy-check.ts",
    "deploy:smart": "powershell -ExecutionPolicy Bypass -File scripts/smart-deploy.ps1",
    "deploy:check": "npm run pre-deploy",
    "deploy:safe": "npm run pre-deploy && npm run build:prod && git push origin main",
    "deploy:real": "ts-node scripts/real-deploy-check.ts",
    "deploy:no-bs": "ts-node scripts/no-bullshit-deploy.ts",
    "test:local": "ts-node scripts/no-bullshit-deploy.ts --local-only",
    "test:production": "ts-node scripts/real-deploy-check.ts --production-only",
    "deploy:ultimate": "ts-node scripts/ultimate-deploy.ts",
    "deploy:quick": "ts-node scripts/ultimate-deploy.ts --skip-local",
    "deploy:force": "ts-node scripts/ultimate-deploy.ts --force",
    "build:autonomous": "ts-node start-autonomous-build.ts",
    "agent:start": "ts-node src/agents/marketing-orchestrator.ts",
    "health:monitor": "node monitoring/health-check.js",
    "health:start": "pm2 start monitoring/health-check.js --name health-monitor",
    "health:stop": "pm2 stop health-monitor",
    "features:activate": "node scripts/feature-activation.js",
    "features:list": "node scripts/feature-activation.js --list",
    "i18n:compile": "node src/lib/i18n.js --compile",
    "api:docs": "swagger-jsdoc -d docs/swagger.js -o docs/api-spec.json",
    "test:v2": "jest tests/integration/api-v2.test.ts --runInBand",
    "cache:clear": "redis-cli FLUSHDB",
    "monitoring:dashboard": "open http://localhost:3000/admin-dashboard.html"
  },
  "keywords": [
    "marketing",
    "automation",
    "social-media",
    "content-generation",
    "ai",
    "platform-optimization"
  ],
  "author": "Auto Marketing Team",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@google-cloud/storage": "^7.7.0",
    "@google-cloud/translate": "^8.0.0",
    "@magneticwatermelon/mcp-toolkit": "^1.1.4",
    "@modelcontextprotocol/sdk": "^1.17.1",
    "@modelcontextprotocol/server-sequential-thinking": "^2025.7.1",
    "@optimizely/optimizely-sdk": "^5.0.0",
    "@prisma/client": "^6.13.0",
    "@prisma/extension-accelerate": "^2.0.2",
    "@sendgrid/mail": "^8.1.0",
