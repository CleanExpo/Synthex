    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.563.0",
    "next": "^15.5.12",
    "next-auth": "^4.24.11",
    "next-themes": "^0.2.1",
    "nodemailer": "^7.0.12",
    "openai": "^4.104.0",
    "pg": "^8.18.0",
    "react": "^18.2.0",
    "react-day-picker": "^8.10.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.0",
    "react-hook-form": "^7.48.0",
    "react-hot-toast": "^2.4.1",
    "react-intersection-observer": "^9.5.0",
    "react-markdown": "^9.0.0",
    "react-use": "^17.4.0",
    "recharts": "^2.10.3",
    "redis": "^5.11.0",
    "resend": "^6.9.1",
    "server-only": "^0.0.1",
    "sonner": "^1.3.0",
    "stripe": "^18.4.0",
    "swr": "^2.2.0",
    "tailwind-merge": "^2.2.0",
    "twitter-api-v2": "^1.24.0",
    "uuid": "^13.0.0",
    "ws": "^8.14.0",
    "zod": "^3.25.76",
    "zustand": "^4.4.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
