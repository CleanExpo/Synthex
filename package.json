    "cmdk": "^0.2.0",
    "date-fns": "^3.0.0",
    "dompurify": "^3.0.0",
    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^12.23.12",
    "get-video-duration": "^5.0.0",
    "googleapis": "^171.4.0",
