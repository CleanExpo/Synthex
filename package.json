{
  "name": "synthex",
  "version": "2.0.1",
  "description": "AI-Powered Social Media Automation Platform",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "validate:env": "node scripts/validate-env.js",
    "validate:claude": "node scripts/validate-claude-settings.js",
    "validate:all": "npm run validate:env && npm run validate:claude",
    "build": "next build",
    "build:force": "next build",
    "build:vercel": "npx prisma generate && next build",
    "vercel-build": "npm ci --legacy-peer-deps && npx prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "typecheck": "npm run type-check",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "test": "jest",
    "test:unit": "npm test",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "postinstall": "npx prisma generate || echo 'Prisma generation skipped'",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "analyze": "ANALYZE=true next build",
    "clean": "rm -rf .next out dist node_modules",
    "clean:cache": "node -e \"process.platform === 'win32' ? require('child_process').execSync('scripts\\\\clear-build-cache.bat', {stdio: 'inherit'}) : require('child_process').execSync('sh scripts/clear-build-cache.sh', {stdio: 'inherit'})\"",
    "build:fresh": "npm run clean:cache && npm run build",
    "reinstall": "npm run clean && npm install",
    "setup:db": "echo \"Run the SQL from supabase/complete-schema.sql in Supabase dashboard\"",
    "test:integration": "node test-integration.mjs",
    "dev:api": "next dev",
    "check:env": "node -e \"console.log(Object.keys(process.env).filter(k => k.includes('SUPABASE') || k.includes('OPENROUTER')))\"",
    "deploy:prod": "vercel --prod --yes",
    "ws:dev": "npx tsx scripts/websocket-server.ts",
    "ws:prod": "NODE_ENV=production npx tsx scripts/websocket-server.ts",
    "dev:full": "concurrently \"npm run dev\" \"npm run ws:dev\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "storybook:build": "npm run build-storybook",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "test:e2e": "npm run e2e",
    "test:e2e:ui": "npm run e2e:ui",
    "test:e2e:staging": "BASE_URL=${STAGING_URL:-http://localhost:3000} npm run e2e",
    "audit": "npm audit --omit=dev",
    "release:check": "npm run type-check && npm run lint && npm test && npm run e2e && npm run build",
    "ci:verify": "node agents/tools/ci-verify.js",
    "validate:env:enhanced": "node scripts/validate-env-enhanced.js",
    "env:generate": "node scripts/generate-env-docs.js",
    "security:audit": "npm run env:generate && npm run validate:env:enhanced && npm audit",
    "security:check": "node scripts/validate-env-enhanced.js",
    "build:production": "NODE_ENV=production next build",
    "build:prod": "npm run build:production",
    "build:emergency": "next build || true",
    "deploy": "node scripts/deploy-assistant.js",
    "diagnose": "node scripts/diagnose-build.js",
    "check:quick": "bash scripts/final-check.sh",
    "check:deploy": "node scripts/diagnose-build.js && bash scripts/final-check.sh",
    "deploy:safe": "npm run check:deploy && git add -A && git commit -m 'chore: deploy to production' && git push origin main",
    "deploy:push": "git add -A && git commit -m 'chore: deploy to production' && git push origin main",
    "deploy:emergency": "git add -A && git commit -m 'emergency: force deployment' --no-verify && git push origin main",
    "fix:deps": "rm -rf node_modules package-lock.json && npm install --legacy-peer-deps",
    "db:validate": "npx prisma validate && npx prisma generate"
  },
