# ============================================
# SYNTHEX Production Environment Variables
# SECURITY: Never commit this file to version control
# Deploy these via Vercel Dashboard > Settings > Environment Variables
# ============================================

# ============================================
# CORE CONFIGURATION (REQUIRED)
# ============================================

# Environment
NODE_ENV=production
PORT=3000
VERCEL=1

# ============================================
# DATABASE (REQUIRED - Use your actual values)
# ============================================

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[YOUR-ANON-KEY]
SUPABASE_SERVICE_ROLE_KEY=[YOUR-SERVICE-ROLE-KEY]

# Database URLs
DATABASE_PROVIDER=postgresql
# Prisma Accelerate for serverless (recommended for Vercel)
DATABASE_URL=prisma+postgres://accelerate.prisma-data.net/?api_key=[YOUR-ACCELERATE-KEY]
# Direct connection (for migrations only)
DIRECT_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
# Connection pooling (fallback)
POSTGRES_URL_POOLING=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# ============================================
# AUTHENTICATION (REQUIRED)
# ============================================

# JWT Secret (Generate new: openssl rand -base64 64)
JWT_SECRET=[GENERATE-NEW-SECRET]

# Google OAuth (From Google Cloud Console)
GOOGLE_CLIENT_ID=[YOUR-GOOGLE-CLIENT-ID]
GOOGLE_CLIENT_SECRET=[YOUR-GOOGLE-CLIENT-SECRET]
GOOGLE_CALLBACK_URL=https://[YOUR-DOMAIN]/auth/google/callback

# GitHub OAuth (Optional)
GITHUB_CLIENT_ID=[YOUR-GITHUB-CLIENT-ID]
GITHUB_CLIENT_SECRET=[YOUR-GITHUB-CLIENT-SECRET]

# ============================================
# AI SERVICES (REQUIRED)
# ============================================

# OpenRouter Configuration
OPENROUTER_API_KEY=[YOUR-OPENROUTER-KEY]
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://[YOUR-DOMAIN]
OPENROUTER_SITE_NAME=SYNTHEX

# Model-Specific APIs (Optional - for direct access)
OPENAI_API_KEY=[YOUR-OPENAI-KEY]
ANTHROPIC_API_KEY=[YOUR-ANTHROPIC-KEY]
GOOGLE_API_KEY=[YOUR-GOOGLE-AI-KEY]

# ============================================
# SECURITY & RATE LIMITING (REQUIRED)
# ============================================

# Rate Limiting
RATE_LIMIT_WINDOW_GENERAL=900000  # 15 minutes
RATE_LIMIT_MAX_GENERAL=100
RATE_LIMIT_WINDOW_API=60000       # 1 minute
RATE_LIMIT_MAX_API=50
RATE_LIMIT_WINDOW_CONTENT=60000
RATE_LIMIT_MAX_CONTENT=20

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://[YOUR-DOMAIN]
HELMET_ENABLED=true
CSRF_PROTECTION=true

# ============================================
# MCP CONFIGURATION (RECOMMENDED)
# ============================================

MCP_SEQUENTIAL_THINKING_ENABLED=true
MCP_CONTEXT7_ENABLED=true
MCP_MAX_CONTEXT_WINDOWS=7
MCP_MAX_TOKENS_PER_WINDOW=4000
MCP_MEMORY_RETENTION=0.95

# ============================================
# MLE STAR CONFIGURATION (RECOMMENDED)
# ============================================

MLE_STAR_MIN_PRODUCTION_SCORE=70
MLE_STAR_AUTO_EVALUATE=true
MLE_STAR_MONITORING_ENABLED=true

# ============================================
# PERFORMANCE & MONITORING (RECOMMENDED)
# ============================================

# Caching
CACHE_ENABLED=true
CACHE_TTL=3600
COMPRESSION_ENABLED=true
REQUEST_TIMEOUT=30000

# Analytics
ANALYTICS_ENABLED=true
ANALYTICS_RETENTION_DAYS=90
ANALYTICS_BATCH_SIZE=100

# Monitoring (Add your service keys)
SENTRY_DSN=[YOUR-SENTRY-DSN]
LOG_LEVEL=error

# Database Performance
DATABASE_POOL_SIZE=10
DATABASE_SSL=true

# ============================================
# COST MANAGEMENT (RECOMMENDED)
# ============================================

DAILY_BUDGET_LIMIT=50.00
MONTHLY_BUDGET_LIMIT=1000.00
MAX_CONCURRENT_REQUESTS=5

# ============================================
# DEPLOYMENT (RECOMMENDED)
# ============================================

AUTO_ROLLBACK_ENABLED=true
HEALTH_CHECK_INTERVAL=60000
HEALTH_CHECK_TIMEOUT=5000
GRACEFUL_SHUTDOWN_TIMEOUT=30000

# ============================================
# FEATURE FLAGS (OPTIONAL)
# ============================================

FEATURE_AB_TESTING=false
FEATURE_SMART_SCHEDULING=false
FEATURE_COMPETITOR_ANALYSIS=false
FEATURE_MULTI_LANGUAGE=false
FEATURE_VOICE_CONTENT=false

# ============================================
# EXTERNAL INTEGRATIONS (OPTIONAL)
# ============================================

# Webhooks
SLACK_WEBHOOK_URL=[YOUR-SLACK-WEBHOOK]
WEBHOOK_SECRET=[GENERATE-WEBHOOK-SECRET]

# Email (Optional)
SMTP_HOST=[YOUR-SMTP-HOST]
SMTP_PORT=587
SMTP_USER=[YOUR-SMTP-USER]
SMTP_PASSWORD=[YOUR-SMTP-PASSWORD]
EMAIL_FROM=noreply@[YOUR-DOMAIN]

# ============================================
# IMPORTANT SECURITY NOTES:
# ============================================
# 1. NEVER commit this file to version control
# 2. Generate new secrets for production (don't reuse development secrets)
# 3. Use Vercel's environment variables UI to set these values
# 4. Enable secret rotation (every 30-90 days)
# 5. Use different API keys for development and production
# 6. Monitor API usage and set up alerts for unusual activity
# ============================================