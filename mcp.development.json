{
  "mcpServers": {
    "ide": {
      "command": "npx",
      "args": ["@modelcontextprotocol/server-ide"],
      "env": {},
      "capabilities": {
        "tools": true,
        "prompts": false,
        "resources": true
      },
      "description": "VS Code integration for real-time diagnostics and code execution"
    },
    "context7": {
      "command": "npx",
      "args": ["@modelcontextprotocol/server-context7"],
      "env": {},
      "capabilities": {
        "tools": true,
        "prompts": true,
        "resources": true
      },
      "description": "Library documentation for React, Next.js, Tailwind, Supabase"
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["@modelcontextprotocol/server-sequential-thinking"],
      "env": {},
      "capabilities": {
        "tools": true,
        "prompts": true,
        "resources": false
      },
      "description": "Complex problem solving and architecture planning"
    },
    "filesystem": {
      "command": "npx",
      "args": ["@modelcontextprotocol/server-filesystem", "--allowed-directories", "D:\\Synthex"],
      "env": {},
      "capabilities": {
        "tools": true,
        "prompts": false,
        "resources": true
      }
    }
  },
  "development": {
    "linting": {
      "autoFix": true,
      "preCommitHook": true,
      "rules": ["eslint", "prettier", "typescript"]
    },
    "testing": {
      "framework": "jest",
      "coverage": {
        "threshold": 80,
        "enforceOnCommit": false
      }
    },
    "debugging": {
      "breakpoints": true,
      "liveReload": true,
      "sourceMap": true
    }
  }
}